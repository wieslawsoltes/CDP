<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>Chrome.DevTools.Xaml.LanguageServer</PackageId>
    <Title>Chrome.DevTools.Xaml.LanguageServer</Title>
    <Description>XAML Language Server Protocol (LSP) implementation utilizing the XAML compiler AST.</Description>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageTags>xaml;lsp;language-server;compiler;ast</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Xaml.Compiler\Xaml.Compiler.csproj" />
  </ItemGroup>
</Project>
