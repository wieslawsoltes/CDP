<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>Chrome.DevTools.Protocol</PackageId>
    <Title>Chrome.DevTools.Protocol</Title>
    <Description>Chrome DevTools Protocol (CDP) core server and session logic.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageTags>cdp;chrome-devtools-protocol;diagnostics;server;core</PackageTags>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <IsTrimmable>true</IsTrimmable>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <EnableAotAnalyzer>true</EnableAotAnalyzer>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="YamlDotNet" />
    <PackageReference Include="SkiaSharp" />
    <PackageReference Include="Jint" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Diagnostics.NETCore.Client" />
    <PackageReference Include="Microsoft.Diagnostics.Tracing.TraceEvent" />
    <PackageReference Include="JetBrains.Profiler.SelfApi" />
    <PackageReference Include="JetBrains.Profiler.Api" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Chrome.DevTools.Protocol" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Xaml.Compiler/Xaml.Compiler.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Mutation/INodeMap.cs" />
  </ItemGroup>

</Project>
