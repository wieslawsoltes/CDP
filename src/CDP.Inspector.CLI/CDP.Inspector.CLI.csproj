<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>cdp-cli</ToolCommandName>
    <PackageId>Chrome.DevTools.Cli</PackageId>
    <Title>Chrome.DevTools.Cli</Title>
    <Description>Chrome DevTools Protocol (CDP) client CLI for Avalonia UI applications.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageTags>avalonia;cdp;chrome-devtools-protocol;cli;tool;automation;testing</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Headless" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="Avalonia.Fonts.Inter" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" />
    <PackageReference Include="System.CommandLine" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CDP.Inspector.Shared\CDP.Inspector.Shared.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="" />
  </ItemGroup>

  <!-- Filter out third-party/native non-portable PDBs from the tool package to prevent NuGet publish failures -->
  <Target Name="FilterToolPackPdbs" AfterTargets="PackTool">
    <ItemGroup>
      <_PdbsToRemove Include="@(TfmSpecificPackageFile)" Condition="'%(Extension)' == '.pdb' and '%(Filename)' != 'CDP.Inspector.CLI' and '%(Filename)' != 'CDP.Inspector.Shared' and '%(Filename)' != 'Avalonia.Diagnostics.Cdp'" />
      <TfmSpecificPackageFile Remove="@(_PdbsToRemove)" />
    </ItemGroup>
  </Target>
</Project>
