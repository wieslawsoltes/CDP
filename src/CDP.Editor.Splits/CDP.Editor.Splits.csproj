<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>CDP.Editor.Splits</PackageId>
    <Title>CDP.Editor.Splits</Title>
    <Description>Dynamic binary split layout container for Avalonia applications.</Description>
    <PackageTags>avalonia;editor;split;layout</PackageTags>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
  </ItemGroup>

</Project>
