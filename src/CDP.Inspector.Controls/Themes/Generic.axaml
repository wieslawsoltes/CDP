        <StreamGeometry x:Key="PinIcon">M16.2425 2.93189L21.0682 7.75765C22.3955 9.08491 22.0324 11.3224 20.3535 12.1619L15.4826 14.5973C15.3073 14.685 15.1732 14.8379 15.1092 15.0232L13.6699 19.1895C13.3684 20.0622 12.2574 20.3181 11.6045 19.6653L8.50002 16.5607L4.06074 21.0001H3L3.00008 19.9394L7.43936 15.5001L4.33487 12.3956C3.682 11.7427 3.93791 10.6317 4.81061 10.3302L8.97688 8.89096C9.16223 8.82694 9.31512 8.69287 9.40281 8.51748L11.8382 3.6466C12.6777 1.96772 14.9152 1.60462 16.2425 2.93189ZM20.0076 8.81831L15.1818 3.99255C14.5785 3.38924 13.5614 3.55429 13.1799 4.31742L10.7445 9.18829C10.4814 9.71446 10.0227 10.1167 9.46666 10.3087L5.67812 11.6175L12.3826 18.322L13.6914 14.5335C13.8835 13.9774 14.2857 13.5188 14.8118 13.2557L19.6827 10.8202C20.4458 10.4387 20.6109 9.42161 20.0076 8.81831Z</StreamGeometry>
        <StreamGeometry x:Key="PinOffIcon">M3.28035 2.21967C2.98746 1.92678 2.51258 1.92677 2.21968 2.21966C1.92678 2.51255 1.92677 2.98742 2.21967 3.28032L8.12461 9.18526L4.81064 10.3301C3.93794 10.6315 3.68202 11.7426 4.3349 12.3954L7.43942 15.4999L3.00009 19.9392L3.00001 20.9999H4.06077L8.50009 16.5605L11.6046 19.665C12.2575 20.3179 13.3686 20.062 13.67 19.1893L14.8148 15.8755L20.7196 21.7803C21.0125 22.0732 21.4874 22.0732 21.7803 21.7803C22.0732 21.4874 22.0732 21.0126 21.7803 20.7197L3.28035 2.21967ZM13.6353 14.696L12.3827 18.3218L5.67816 11.6174L9.30412 10.3648L13.6353 14.696ZM19.6829 10.8201L15.8957 12.7137L17.0137 13.8317L20.3537 12.1617C22.0326 11.3223 22.3957 9.08476 21.0684 7.75751L16.2426 2.93179C14.9153 1.60453 12.6778 1.96763 11.8383 3.6465L10.1684 6.98637L11.2864 8.10441L13.18 4.31731C13.5616 3.55419 14.5786 3.38914 15.1819 3.99244L20.0078 8.81817C20.6111 9.42146 20.446 10.4385 19.6829 10.8201Z</StreamGeometry>
    </Styles.Resources>

    <!-- Accordion Styling -->
    <Style Selector="controls|Accordion">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ItemsPresenter ItemsPanel="{TemplateBinding ItemsPanel}"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- AccordionItem Styling -->
    <Style Selector="controls|AccordionItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <Grid RowDefinitions="Auto, *">
                        <!-- Header Toggle Button -->
                        <ToggleButton Name="PART_HeaderButton"
                                      Grid.Row="0"
                                      IsChecked="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsExpanded, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      Background="#2d2d2d"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      Padding="8,6"
                                      CornerRadius="0">
                            <ToggleButton.Styles>
                                <Style Selector="ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="#35363a"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Style>
                                <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="#252526"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#8ab4f8"/>
                                </Style>
                                <Style Selector="ToggleButton TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Foreground" Value="#e8eaed"/>
                                </Style>
                                <Style Selector="ToggleButton:checked TextBlock">
                                    <Setter Property="Foreground" Value="#8ab4f8"/>
                                </Style>
                            </ToggleButton.Styles>
                            <Grid ColumnDefinitions="*, Auto">
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding Header}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                  VerticalAlignment="Center"/>
                                <PathIcon Grid.Column="1"
                                          Data="{StaticResource ChevronDownIcon}"
                                          Width="10"
                                          Height="10"
                                          Foreground="#9aa0a6"
                                          VerticalAlignment="Center">
                                    <PathIcon.Transitions>
                                        <Transitions>
                                            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
                                        </Transitions>
                                    </PathIcon.Transitions>
                                </PathIcon>
                            </Grid>
                        </ToggleButton>
                        
                        <!-- Content Border -->
                        <Border Grid.Row="1"
                                Name="PART_ContentBorder"
                                Background="#202124"
                                IsVisible="{TemplateBinding IsExpanded}">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Padding="8,4,8,8"/>
                        </Border>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="controls|AccordionItem /template/ PathIcon">
        <Setter Property="RenderTransform" Value="rotate(0deg)"/>
    </Style>
    <Style Selector="controls|AccordionItem[IsExpanded=true] /template/ PathIcon">
        <Setter Property="RenderTransform" Value="rotate(180deg)"/>
        <Setter Property="Foreground" Value="#8ab4f8"/>
    </Style>

    <!-- Remove border on the very last AccordionItem -->
    <Style Selector="controls|Accordion > controls|AccordionItem:nth-last-child(1)">
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- EditableComboBox Styling -->
    <Style Selector="controls|EditableComboBox">
        <Setter Property="Background" Value="#2d2d2d"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Name="PART_RootGrid" ColumnDefinitions="*,Auto">
                    <!-- Dropdown Toggle Button under the text box for full clickability -->
                    <ToggleButton Name="PART_ToggleButton"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="2"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  CornerRadius="{TemplateBinding CornerRadius}"
                                  IsChecked="{Binding $parent[controls:EditableComboBox].IsDropDownOpen, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  HorizontalContentAlignment="Right"
                                  Padding="0,0,10,0"
                                  ClickMode="Release"
                                  ZIndex="0">
                        <ToggleButton.Template>
                             <ControlTemplate>
                                <Border Name="templateRoot"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="{TemplateBinding CornerRadius}">
                                    <Grid HorizontalAlignment="Right" VerticalAlignment="Center" Width="30">
                                        <PathIcon Data="{StaticResource ChevronDownIcon}"
                                                  Width="8"
                                                  Height="8"
                                                  Foreground="#9aa0a6"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>

                    <!-- Editable TextBox overlay on the left -->
                    <TextBox Name="PART_EditableTextBox"
                             Grid.Column="0"
                             Text="{Binding $parent[controls:EditableComboBox].Text, Mode=TwoWay}"
                             PlaceholderText="{TemplateBinding PlaceholderText}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{TemplateBinding Foreground}"
                             Padding="{TemplateBinding Padding}"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Stretch"
                             Margin="2,2,30,2"
                             ZIndex="1"/>

                    <!-- Popup list -->
                    <Popup Name="PART_Popup"
                           Grid.Column="0"
                           IsOpen="{TemplateBinding IsDropDownOpen, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=PART_ToggleButton}"
                           Placement="Bottom"
                           IsLightDismissEnabled="True">
                        <Border Background="#2a2a2b"
                                BorderBrush="#3c4043"
                                BorderThickness="1"
                                CornerRadius="4"
                                MinWidth="{Binding ElementName=PART_ToggleButton, Path=Bounds.Width}"
                                Margin="0,4,0,4">
                            <ScrollViewer MaxHeight="300">
                                <ItemsPresenter Name="PART_ItemsPresenter"
                                                ItemsPanel="{TemplateBinding ItemsPanel}"/>
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="controls|EditableComboBox:focus-within /template/ ToggleButton#PART_ToggleButton">
        <Setter Property="BorderBrush" Value="#8ab4f8"/>
    </Style>

    <!-- DockSplitPanel Styling -->
    <Style Selector="controls|DockSplitPanel">
        <Setter Property="Background" Value="#202124"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Name="PART_RootGrid" Background="{TemplateBinding Background}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinPanelHeight}" MaxHeight="{TemplateBinding MaxPanelHeight}"/>
                    </Grid.RowDefinitions>

                    <!-- Main Content (Screencast Viewport, etc.) - Single ContentPresenter -->
                    <ContentPresenter Name="PART_MainContentPresenter"
                                      Grid.Row="0"
                                      Content="{TemplateBinding MainContent}"
                                      ContentTemplate="{TemplateBinding MainContentTemplate}"/>

                    <!-- Inline Splitter Handle (visible when Pinned & Expanded) -->
                    <GridSplitter Name="PART_GridSplitter"
                                  Grid.Row="1"
                                  Height="4"
                                  Background="#28292c"
                                  ResizeDirection="Rows"
                                  HorizontalAlignment="Stretch"/>

                    <!-- Bottom Panel Container (Header + Content) -->
                    <Border Name="PART_BottomPanelHost"
                            Grid.Row="2"
                            Background="#28292c"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <Grid RowDefinitions="Auto, Auto, *">
                            <!-- Overlay Top Resize Grip (visible when Unpinned & Expanded) -->
                            <Border Name="PART_OverlayGrip"
                                    Grid.Row="0"
                                    Height="6"
                                    Background="#35363a"
                                    Cursor="SizeNorthSouth"
                                    HorizontalAlignment="Stretch"/>

                            <!-- Header Bar -->
                            <Border Name="PART_HeaderBar" Grid.Row="1" Background="#28292c" Padding="8,5" BackgroundSizing="InnerBorderEdge">
                                <Grid ColumnDefinitions="*, Auto">
                                    <!-- Title / Header toggle button -->
                                    <Button Name="PART_HeaderButton"
                                            Grid.Column="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalAlignment="Left"
                                            HorizontalContentAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <PathIcon Data="{StaticResource ChevronDownIcon}"
                                                      Width="10"
                                                      Height="10"
                                                      Foreground="#9aa0a6"
                                                      Name="PART_ChevronIcon"/>
                                            <ContentPresenter Content="{TemplateBinding Header}"
                                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                              FontSize="11"
                                                              FontWeight="SemiBold"
                                                              Foreground="#e8eaed"
                                                              VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Pin/Unpin Toggle Button -->
                                    <Button Name="PART_PinButton"
                                            Grid.Column="1"
                                            ToolTip.Tip="Toggle Pin (Inline / Overlay)"
                                            Width="26" Height="26"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Margin="4,0,0,0">
                                        <PathIcon Name="PART_PinIcon"
                                                  Data="{StaticResource PinIcon}"
                                                  Width="12" Height="12"
                                                  Foreground="#8ab4f8"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Panel Content Area - Single ContentPresenter -->
                            <Border Name="PART_ContentHost"
                                    Grid.Row="2"
                                    Height="{TemplateBinding PanelHeight}"
                                    IsVisible="{TemplateBinding IsExpanded}">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Pinned (Inline) Mode Styles -->
    <Style Selector="controls|DockSplitPanel:pinned /template/ ContentPresenter#PART_MainContentPresenter">
        <Setter Property="Grid.Row" Value="0"/>
        <Setter Property="Grid.RowSpan" Value="1"/>
    </Style>
    <Style Selector="controls|DockSplitPanel:pinned /template/ Border#PART_BottomPanelHost">
        <Setter Property="Grid.Row" Value="2"/>
        <Setter Property="Grid.RowSpan" Value="1"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="BoxShadow" Value="none"/>
    </Style>
    <Style Selector="controls|DockSplitPanel:pinned /template/ Border#PART_OverlayGrip">
        <Setter Property="IsVisible" Value="False"/>
    </Style>
    <Style Selector="controls|DockSplitPanel:pinned /template/ PathIcon#PART_PinIcon">
        <Setter Property="Data" Value="{StaticResource PinIcon}"/>
        <Setter Property="Foreground" Value="#8ab4f8"/>
    </Style>
    <Style Selector="controls|DockSplitPanel:pinned:expanded /template/ GridSplitter#PART_GridSplitter">
        <Setter Property="IsVisible" Value="True"/>
    </Style>
    <Style Selector="controls|DockSplitPanel:pinned:collapsed /template/ GridSplitter#PART_GridSplitter">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- Unpinned (Overlay) Mode Styles -->
    <Style Selector="controls|DockSplitPanel:unpinned /template/ ContentPresenter#PART_MainContentPresenter">
        <Setter Property="Grid.Row" Value="0"/>
        <Setter Property="Grid.RowSpan" Value="3"/>
    </Style>
    <Style Selector="controls|DockSplitPanel:unpinned /template/ Border#PART_BottomPanelHost">
        <Setter Property="Grid.Row" Value="0"/>
        <Setter Property="Grid.RowSpan" Value="3"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="BoxShadow" Value="0 -4 12 #60000000"/>
    </Style>
    <Style Selector="controls|DockSplitPanel:unpinned /template/ GridSplitter#PART_GridSplitter">
        <Setter Property="IsVisible" Value="False"/>
    </Style>
    <Style Selector="controls|DockSplitPanel:unpinned /template/ PathIcon#PART_PinIcon">
        <Setter Property="Data" Value="{StaticResource PinOffIcon}"/>
        <Setter Property="Foreground" Value="#9aa0a6"/>
    </Style>
    <Style Selector="controls|DockSplitPanel:unpinned:expanded /template/ Border#PART_OverlayGrip">
        <Setter Property="IsVisible" Value="True"/>
    </Style>
    <Style Selector="controls|DockSplitPanel:unpinned:collapsed /template/ Border#PART_OverlayGrip">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- Chevron Icon Expand/Collapse Styles -->
    <Style Selector="controls|DockSplitPanel /template/ PathIcon#PART_ChevronIcon">
        <Setter Property="RenderTransform" Value="rotate(0deg)"/>
    </Style>
    <Style Selector="controls|DockSplitPanel:expanded /template/ PathIcon#PART_ChevronIcon">
        <Setter Property="RenderTransform" Value="rotate(180deg)"/>
        <Setter Property="Foreground" Value="#8ab4f8"/>
    </Style>

    <!-- Hover Accent Highlights -->
    <Style Selector="controls|DockSplitPanel /template/ Border#PART_OverlayGrip:pointerover">
        <Setter Property="Background" Value="#8ab4f8"/>
    </Style>
    <Style Selector="controls|DockSplitPanel /template/ GridSplitter#PART_GridSplitter:pointerover">
        <Setter Property="Background" Value="#8ab4f8"/>
    </Style>
</Styles>
