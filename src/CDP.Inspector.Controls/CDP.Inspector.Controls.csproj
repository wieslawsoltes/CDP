<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>Chrome.DevTools.Inspector.Controls</PackageId>
    <Title>Chrome.DevTools.Inspector.Controls</Title>
    <Description>Custom controls for the CDP Inspector client.</Description>
    <PackageTags>avalonia;cdp;chrome-devtools-protocol;inspector;controls</PackageTags>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.AvaloniaEdit" />
    <PackageReference Include="AvaloniaEdit.TextMate" />
    <PackageReference Include="TextMateSharp.Grammars" />
    <PackageReference Include="SkiaSharp" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../CDP.Editor.Splits/CDP.Editor.Splits.csproj" />
    <ProjectReference Include="../CDP.Html.Parser/CDP.Html.Parser.csproj" />
    <ProjectReference Include="../CDP.Css.Parser/CDP.Css.Parser.csproj" />
    <ProjectReference Include="../CDP.Html.Renderer/CDP.Html.Renderer.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="" />
  </ItemGroup>

</Project>
