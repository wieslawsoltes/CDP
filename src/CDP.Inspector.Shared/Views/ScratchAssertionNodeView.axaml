<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CdpInspectorApp.ViewModels"
             x:Class="CdpInspectorApp.Views.ScratchAssertionNodeView"
             x:DataType="vm:ScratchAssertionNodeViewModel"
             x:CompileBindings="True">
    <Grid RowDefinitions="Auto, *" Margin="8" Width="140" Height="80">
        <Border Grid.Row="0" Background="{Binding PassedBrush}" CornerRadius="3" Padding="4,2" HorizontalAlignment="Left">
            <TextBlock Text="{Binding PassedText}" FontSize="10" FontWeight="Bold" Foreground="White"/>
        </Border>
        <TextBlock Grid.Row="1" Text="{Binding Message}" FontSize="10" Foreground="#e8eaed" Margin="0,6,0,0" TextWrapping="Wrap" MaxLines="2"/>
    </Grid>
</UserControl>
