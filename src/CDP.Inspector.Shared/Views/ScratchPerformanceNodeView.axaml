<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CdpInspectorApp.ViewModels"
             x:Class="CdpInspectorApp.Views.ScratchPerformanceNodeView"
             x:DataType="vm:ScratchPerformanceNodeViewModel"
             x:CompileBindings="True">
    <Grid RowDefinitions="Auto, Auto" Margin="8" Width="140" Height="80">
        <Border Background="#1a73e8" CornerRadius="3" Padding="4,2" HorizontalAlignment="Left">
            <TextBlock Text="Performance" FontSize="10" FontWeight="Bold" Foreground="White"/>
        </Border>
        <TextBlock Grid.Row="1" Text="{Binding DataSummary}" FontSize="11" Foreground="#e8eaed" Margin="0,6,0,0" TextWrapping="Wrap"/>
    </Grid>
</UserControl>
