<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CdpInspectorApp.ViewModels"
             xmlns:controls="clr-namespace:CdpInspectorApp.Controls;assembly=CDP.Inspector.Controls"
             x:Class="CdpInspectorApp.Views.HtmlPreviewView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="True">

    <Grid ColumnDefinitions="*, 4, *">
        <!-- Left Column: Settings and editors -->
        <Grid Grid.Column="0" Margin="12">
            <TabControl Name="tabSelection">
                <!-- Live Inspected Element -->
                <TabItem Header="Selected Outer HTML">
                    <Grid RowDefinitions="Auto, *">
                        <TextBlock Grid.Row="0" Text="Inspected DOM Node HTML Source (Read-only)" FontSize="11" Foreground="#9aa0a6" Margin="0,6,0,6"/>
                        <TextBox Grid.Row="1"
                                 Text="{Binding HtmlPreview.OuterHtml, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 FontFamily="Courier New"
                                 FontSize="12"
                                 Foreground="#e8eaed"
                                 Background="#161616"
                                 BorderBrush="#2d2d2d"
                                 TextWrapping="Wrap"/>
                    </Grid>
                </TabItem>

                <!-- Sandbox -->
                <TabItem Header="Custom Sandbox">
                    <Grid RowDefinitions="Auto, *, 4, *">
                        <CheckBox Grid.Row="0" Name="chkCustomMode" Content="Use Custom Sandbox Preview" IsChecked="{Binding HtmlPreview.IsCustomMode}" Margin="0,6"/>
                        
                        <Grid Grid.Row="1" RowDefinitions="Auto, *">
                            <TextBlock Grid.Row="0" Text="Sandbox HTML" FontSize="11" Foreground="#9aa0a6" Margin="0,0,0,4"/>
                            <TextBox Grid.Row="1"
                                     Name="txtCustomHtml"
                                     Text="{Binding HtmlPreview.CustomHtml, Mode=TwoWay}"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     FontFamily="Courier New"
                                     FontSize="12"
                                     Foreground="#e8eaed"
                                     Background="#161616"
                                     BorderBrush="#2d2d2d"
                                     TextWrapping="Wrap"
                                     IsEnabled="{Binding HtmlPreview.IsCustomMode}"/>
                        </Grid>

                        <GridSplitter Grid.Row="2" Background="#2d2d2d" ResizeDirection="Rows" Margin="0,4"/>

                        <Grid Grid.Row="3" RowDefinitions="Auto, *">
                            <TextBlock Grid.Row="0" Text="Sandbox CSS" FontSize="11" Foreground="#9aa0a6" Margin="0,0,0,4"/>
                            <TextBox Grid.Row="1"
                                     Name="txtCustomCss"
                                     Text="{Binding HtmlPreview.CustomCss, Mode=TwoWay}"
                                     AcceptsReturn="True"
                                     AcceptsTab="True"
                                     FontFamily="Courier New"
                                     FontSize="12"
                                     Foreground="#e8eaed"
                                     Background="#161616"
                                     BorderBrush="#2d2d2d"
                                     TextWrapping="Wrap"
                                     IsEnabled="{Binding HtmlPreview.IsCustomMode}"/>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Background="#2d2d2d" ResizeDirection="Columns"/>

        <!-- Right Column: HTML Skia canvas preview -->
        <Grid Grid.Column="2" RowDefinitions="Auto, *" Margin="12">
            <TextBlock Grid.Row="0" Text="Live HTML Skia Canvas Render" FontSize="11" Foreground="#9aa0a6" Margin="0,0,0,6"/>
            <Border Grid.Row="1" Background="#1c1c1c" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="4" Padding="8">
                <controls:HtmlCanvas HtmlText="{Binding HtmlPreview.HtmlText}" CssText="{Binding HtmlPreview.CssText}" ClipToBounds="True"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
