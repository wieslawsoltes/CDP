<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:CdpInspectorApp.Views"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:controls="clr-namespace:CdpInspectorApp.Controls"
             xmlns:dgdd="clr-namespace:Avalonia.Controls.DataGridDragDrop;assembly=Avalonia.Controls.DataGrid"
             xmlns:map="using:XamlPlayground.Editor.Minimap"
             x:Class="CdpInspectorApp.Views.RecorderView"
             x:CompileBindings="False">
    <Grid RowDefinitions="Auto, *" Margin="10">
        <!-- Top Mode Switcher -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12" VerticalAlignment="Center">
            <ToggleSwitch Name="toggleRecorderMode" OnContent="Test Studio Mode" OffContent="Standard Recorder Mode" IsChecked="{Binding Recorder.IsTestStudioActive, Mode=TwoWay}" Foreground="#e8eaed" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Standard Recorder Mode Content -->
        <Grid Grid.Row="1" ColumnDefinitions="*, 4, *" IsVisible="{Binding !Recorder.IsTestStudioActive}">
            <!-- Steps List (Left Side) -->
            <Grid Grid.Column="0" RowDefinitions="Auto, *" Margin="0,0,10,0">
                <!-- Recorder Toolbar -->
                <WrapPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                    <Button Name="btnToggleRecord" Command="{Binding Recorder.ToggleRecordCommand}" Content="{Binding Recorder.ToggleRecordButtonText}" Background="{Binding Recorder.ToggleRecordButtonBackground}" BorderBrush="{Binding Recorder.ToggleRecordButtonBorderBrush}" Foreground="White" Margin="0,2,8,2"/>
                    <Button Name="btnReplay" Command="{Binding Recorder.ReplayCommand}" Content="Replay" Background="#0f9d58" Foreground="White" BorderBrush="#0f9d58" IsEnabled="{Binding Recorder.IsReplayEnabled}" Margin="0,2,8,2"/>
                    <Button Name="btnClear" Command="{Binding Recorder.ClearCommand}" Content="Clear" Background="#3c4043" Foreground="White" BorderBrush="#3c4043" Margin="0,2,8,2"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,2,0,2">
                        <TextBlock Text="Format:" VerticalAlignment="Center" Foreground="#e8eaed" Margin="8,0,8,0"/>
                        <ComboBox Name="cbFormat" ItemsSource="{Binding Recorder.AvailableFormats}" SelectedItem="{Binding Recorder.SelectedFormat, Mode=TwoWay}" VerticalAlignment="Center" Width="150" Background="#2d2d2d" Foreground="White" BorderBrush="#3c4043"/>
                    </StackPanel>
                </WrapPanel>
                
                <Grid Grid.Row="1" RowDefinitions="Auto, *">
                    <TextBlock Text="Recorded Steps" Classes="panel-header" Margin="0,0,0,8" Foreground="#e8eaed" FontSize="14" FontWeight="Bold"/>
                    <DataGrid Name="lstRecordedSteps" Grid.Row="1"
                              ItemsSource="{Binding Recorder.RecordedSteps}"
                              SelectedItem="{Binding Recorder.SelectedRecordedStep, Mode=TwoWay}"
                              CanUserReorderRows="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              RowDragHandle="RowHeaderAndRow"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowDetailsVisibilityMode="VisibleWhenSelected"
                              Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                        <DataGrid.RowDropHandler>
                            <dgdd:DataGridRowReorderHandler />
                        </DataGrid.RowDropHandler>
                        <DataGrid.Columns>
                            <!-- Type Badge Column -->
                            <DataGridTemplateColumn Header="Type" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="#3c4043" CornerRadius="2" Padding="4,2" HorizontalAlignment="Left" Margin="4">
                                            <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="Bold" Foreground="#e8eaed"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Target / Selector Column -->
                            <DataGridTemplateColumn Header="Selector" Width="1.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SelectorDisplay}" FontWeight="Normal" Foreground="#8ab4f8" FontSize="12" VerticalAlignment="Center" Margin="12,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Details Column -->
                            <DataGridTemplateColumn Header="Details" Width="2.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DetailDisplay}" FontSize="12" Foreground="#e8eaed" VerticalAlignment="Center" Margin="12,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>

                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Background="#202124" BorderBrush="#3c4043" BorderThickness="0,1,0,0" Padding="12">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                                            <Border Background="#1a73e8" CornerRadius="2" Padding="4,2">
                                                <TextBlock Text="EDIT" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                            </Border>
                                            <TextBlock Text="{Binding Type}" FontWeight="Bold" Foreground="#e8eaed" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Type Field -->
                                        <Grid ColumnDefinitions="120, *">
                                            <TextBlock Grid.Column="0" Text="Type:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                            <TextBox Grid.Column="1" Text="{Binding Type, Mode=TwoWay}" FontSize="11" Height="24" Padding="4,2"/>
                                        </Grid>

                                        <!-- Selector Field -->
                                        <Grid ColumnDefinitions="120, *" IsVisible="{Binding Type, Converter={x:Static views:RecorderView.IsSelectorVisibleConverter}}">
                                            <TextBlock Grid.Column="0" Text="Selector:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                            <TextBox Grid.Column="1" Text="{Binding Selector, Mode=TwoWay}" FontSize="11" Height="24" Padding="4,2"/>
                                        </Grid>

                                        <!-- Value Field -->
                                        <Grid ColumnDefinitions="120, *" IsVisible="{Binding Type, Converter={x:Static views:RecorderView.IsValueVisibleConverter}}">
                                            <TextBlock Grid.Column="0" Text="Value:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                            <TextBox Grid.Column="1" Text="{Binding Value, Mode=TwoWay}" FontSize="11" Height="24" Padding="4,2"/>
                                        </Grid>

                                        <!-- URL Field -->
                                        <Grid ColumnDefinitions="120, *" IsVisible="{Binding Type, Converter={x:Static views:RecorderView.IsUrlVisibleConverter}}">
                                            <TextBlock Grid.Column="0" Text="URL:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                            <TextBox Grid.Column="1" Text="{Binding Url, Mode=TwoWay}" FontSize="11" Height="24" Padding="4,2"/>
                                        </Grid>

                                        <!-- Key Field -->
                                        <Grid ColumnDefinitions="120, *" IsVisible="{Binding Type, Converter={x:Static views:RecorderView.IsKeyVisibleConverter}}">
                                            <TextBlock Grid.Column="0" Text="Key:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                            <TextBox Grid.Column="1" Text="{Binding Key, Mode=TwoWay}" FontSize="11" Height="24" Padding="4,2"/>
                                        </Grid>

                                        <!-- Width / Height Fields -->
                                        <Grid ColumnDefinitions="120, *" IsVisible="{Binding Type, Converter={x:Static views:RecorderView.IsViewportVisibleConverter}}">
                                            <TextBlock Grid.Column="0" Text="Width x Height:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                <TextBox Text="{Binding Width, Mode=TwoWay}" FontSize="11" Height="24" Width="80" Padding="4,2"/>
                                                <TextBlock Text="x" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                                <TextBox Text="{Binding Height, Mode=TwoWay}" FontSize="11" Height="24" Width="80" Padding="4,2"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- OffsetX / OffsetY Coordinates -->
                                        <Grid ColumnDefinitions="120, *" IsVisible="{Binding Type, Converter={x:Static views:RecorderView.IsCoordinatesVisibleConverter}}">
                                            <TextBlock Grid.Column="0" Text="{Binding Type, Converter={x:Static views:RecorderView.CoordinatesLabelConverter}}" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="X:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                                <TextBox Text="{Binding OffsetX, Mode=TwoWay}" FontSize="11" Height="24" Width="80" Padding="4,2"/>
                                                <TextBlock Text="Y:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                                <TextBox Text="{Binding OffsetY, Mode=TwoWay}" FontSize="11" Height="24" Width="80" Padding="4,2"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Click Details (Button / ClickCount) -->
                                        <Grid ColumnDefinitions="120, *" IsVisible="{Binding Type, Converter={x:Static views:RecorderView.IsClickDetailsVisibleConverter}}">
                                            <TextBlock Grid.Column="0" Text="Click Details:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="Button:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                                <TextBox Text="{Binding Button, Mode=TwoWay}" FontSize="11" Height="24" Width="80" Padding="4,2"/>
                                                <TextBlock Text="Clicks:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                                <TextBox Text="{Binding ClickCount, Mode=TwoWay}" FontSize="11" Height="24" Width="50" Padding="4,2"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Drag and Drop Details -->
                                        <StackPanel Spacing="8" IsVisible="{Binding Type, Converter={x:Static views:RecorderView.IsDragDetailsVisibleConverter}}">
                                            <Grid ColumnDefinitions="120, *">
                                                <TextBlock Grid.Column="0" Text="Target Selector:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                                <TextBox Grid.Column="1" Text="{Binding TargetSelector, Mode=TwoWay}" FontSize="11" Height="24" Padding="4,2"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="120, *">
                                                <TextBlock Grid.Column="0" Text="Source Offset:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="X:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                                    <TextBox Text="{Binding OffsetX, Mode=TwoWay}" FontSize="11" Height="24" Width="80" Padding="4,2"/>
                                                    <TextBlock Text="Y:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                                    <TextBox Text="{Binding OffsetY, Mode=TwoWay}" FontSize="11" Height="24" Width="80" Padding="4,2"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="120, *">
                                                <TextBlock Grid.Column="0" Text="Target Offset:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="X:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                                    <TextBox Text="{Binding TargetOffsetX, Mode=TwoWay}" FontSize="11" Height="24" Width="80" Padding="4,2"/>
                                                    <TextBlock Text="Y:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                                    <TextBox Text="{Binding TargetOffsetY, Mode=TwoWay}" FontSize="11" Height="24" Width="80" Padding="4,2"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Modifiers -->
                                        <Grid ColumnDefinitions="120, *" IsVisible="{Binding Type, Converter={x:Static views:RecorderView.IsModifiersVisibleConverter}}">
                                            <TextBlock Grid.Column="0" Text="Modifiers Mask:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                            <TextBox Grid.Column="1" Text="{Binding Modifiers, Mode=TwoWay}" FontSize="11" Height="24" Width="80" Padding="4,2" HorizontalAlignment="Left"/>
                                        </Grid>

                                        <!-- Action Buttons -->
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                            <Button Command="{Binding $parent[UserControl].DataContext.Recorder.MoveUpStepCommand}" CommandParameter="{Binding}" Padding="6,2">
                                                <PathIcon Data="{StaticResource ChevronUpIcon}" Width="10" Height="10" Foreground="#e8eaed"/>
                                            </Button>
                                            <Button Command="{Binding $parent[UserControl].DataContext.Recorder.MoveDownStepCommand}" CommandParameter="{Binding}" Padding="6,2">
                                                <PathIcon Data="{StaticResource ChevronDownIcon}" Width="10" Height="10" Foreground="#e8eaed"/>
                                            </Button>
                                            <Button Command="{Binding $parent[UserControl].DataContext.Recorder.DeleteStepCommand}" CommandParameter="{Binding}" Padding="6,2" Foreground="#ff6b6b" BorderBrush="#ff6b6b">
                                                <PathIcon Data="{StaticResource CloseIcon}" Width="10" Height="10" Foreground="#ff6b6b"/>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                    </DataGrid>
                </Grid>
            </Grid>
            
            <GridSplitter Grid.Column="1" Background="#3c4043"/>
            
            <!-- Right Side Tab Control -->
            <TabControl Grid.Column="2" Margin="10,0,0,0" Padding="0">
                <!-- Tab 1: Script -->
                <TabItem Header="{Binding Recorder.ScriptTabHeader}">
                    <Grid RowDefinitions="Auto, *" Margin="0,10,0,0">
                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,12">
                            <TextBlock Text="{Binding Recorder.ScriptTitleText}" VerticalAlignment="Center" Foreground="#e8eaed" FontSize="13" FontWeight="SemiBold"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Name="btnLoad" Click="BtnLoad_Click" Content="Load Recording" Classes="accent"/>
                                <Button Name="btnExportPuppeteer" Click="BtnExportPuppeteer_Click" Content="{Binding Recorder.ExportButtonText}" Classes="accent"/>
                                <Button Name="btnExportJson" Click="BtnExportJson_Click" Content="Export JSON" Classes="accent"/>
                            </StackPanel>
                        </Grid>
                        
                        <Border Grid.Row="1" Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4" Padding="10">
                            <map:MinimapTextEditor Name="txtGeneratedCode" 
                                           Background="Transparent" 
                                           BorderThickness="0" 
                                           Foreground="#e8eaed" 
                                           FontFamily="Courier New,Consolas,Monospace" 
                                           FontSize="12" 
                                           IsReadOnly="True" 
                                           ShowLineNumbers="True"
                                           HorizontalScrollBarVisibility="Auto" 
                                           VerticalScrollBarVisibility="Auto"/>
                        </Border>
                    </Grid>
                </TabItem>
                
                <!-- Tab 2: Recording Guide -->
                <TabItem Header="Recording Guide">
                    <ScrollViewer Margin="0,10,0,0">
                        <StackPanel Spacing="16" Margin="0,0,10,0">
                            <TextBlock Text="Chrome DevTools Protocol Recording Guide" FontSize="16" FontWeight="Bold" Foreground="#8ab4f8"/>
                            
                            <TextBlock Text="The CDP Recorder captures your interactions with the target application and generates a fully compliant Puppeteer script in real time. It supports the following features:" TextWrapping="Wrap" Foreground="#9aa0a6" FontSize="12"/>

                            <!-- Cards for supported features -->
                            <Border Background="#202124" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4" Padding="12">
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Background="#1a73e8" CornerRadius="2" Padding="4,2">
                                            <TextBlock Text="STATE" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="Viewport &amp; Navigation" FontWeight="Bold" Foreground="#e8eaed" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Text="• setViewport: Dynamically captures the window width/height at start." Foreground="#9aa0a6" FontSize="11" TextWrapping="Wrap"/>
                                    <TextBlock Text="• navigate: Captures the entry URL when starting. Generates page.goto(url)." Foreground="#9aa0a6" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#202124" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4" Padding="12">
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Background="#0f9d58" CornerRadius="2" Padding="4,2">
                                            <TextBlock Text="MOUSE" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="Click Actions" FontWeight="Bold" Foreground="#e8eaed" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Text="• click: Records left clicks on UI elements using precise hierarchical CSS selectors." Foreground="#9aa0a6" FontSize="11" TextWrapping="Wrap"/>
                                    <TextBlock Text="• Replayer locates elements at runtime via DOM querySelector and dispatches coordinate-based clicks to their center coordinates." Foreground="#9aa0a6" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#202124" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4" Padding="12">
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Background="#f4b400" CornerRadius="2" Padding="4,2">
                                            <TextBlock Text="KEYBOARD" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="Text Inputs &amp; Special Keys" FontWeight="Bold" Foreground="#e8eaed" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Text="• change: Consolidates text entry into a single step on focus loss (generating page.type(selector, text))." Foreground="#9aa0a6" FontSize="11" TextWrapping="Wrap"/>
                                    <TextBlock Text="• keydown: Captures non-character control/navigation keys (Enter, Escape, Tab, Backspace, Delete, Arrows) and replays them via Input.dispatchKeyEvent (generating page.keyboard.press(key))." Foreground="#9aa0a6" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#202124" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4" Padding="12">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="How to Use" FontWeight="Bold" Foreground="#e8eaed" FontSize="13"/>
                                    <TextBlock Text="1. Launch the target application (CdpSampleApp) and make sure it has CDP enabled." Foreground="#9aa0a6" FontSize="11" TextWrapping="Wrap"/>
                                    <TextBlock Text="2. Click 'Start Recording' and interact with the target application." Foreground="#9aa0a6" FontSize="11" TextWrapping="Wrap"/>
                                    <TextBlock Text="3. Click 'Stop Recording' to view the generated script." Foreground="#9aa0a6" FontSize="11" TextWrapping="Wrap"/>
                                    <TextBlock Text="4. Click 'Replay' to simulate the recorded actions, or click 'Export Script'/'Export JSON' to save the recording." Foreground="#9aa0a6" FontSize="11" TextWrapping="Wrap"/>
                                    <TextBlock Text="5. Use 'Load Recording' to import previously recorded JS/JSON scenarios." Foreground="#9aa0a6" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Test Studio Mode Content -->
        <views:TestStudioView Grid.Row="1" IsVisible="{Binding Recorder.IsTestStudioActive}"/>
    </Grid>
</UserControl>
