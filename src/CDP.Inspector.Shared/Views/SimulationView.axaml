<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CdpInspectorApp.Controls;assembly=CDP.Inspector.Controls"
             xmlns:vm="clr-namespace:CdpInspectorApp.ViewModels"
             x:Class="CdpInspectorApp.Views.SimulationView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="True">
    <Grid RowDefinitions="Auto, Auto, *" Background="#202124">
        
        <!-- Row 0: Navigation & Address Bar -->
        <Border Grid.Row="0" Background="#28292c" BorderBrush="#3c4043" BorderThickness="0,0,0,1" Padding="6,4">
            <Grid ColumnDefinitions="Auto, Auto, Auto, *, Auto, Auto">
                <Button Command="{Binding Simulation.BackCommand}" ToolTip.Tip="Go back" Width="26" Height="26" MinWidth="0" MinHeight="0" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="0,0,4,0">
                    <PathIcon Data="{StaticResource ChevronLeftIcon}" Width="11" Height="11" Foreground="#e8eaed"/>
                </Button>
                <Button Grid.Column="1" Command="{Binding Simulation.ForwardCommand}" ToolTip.Tip="Go forward" Width="26" Height="26" MinWidth="0" MinHeight="0" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="0,0,4,0">
                    <PathIcon Data="{StaticResource ChevronRightIcon}" Width="11" Height="11" Foreground="#e8eaed"/>
                </Button>
                <Button Grid.Column="2" Command="{Binding Simulation.ReloadCommand}" ToolTip.Tip="Reload target page" Width="26" Height="26" MinWidth="0" MinHeight="0" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="0,0,6,0">
                    <PathIcon Data="{StaticResource RefreshIcon}" Width="11" Height="11" Foreground="#e8eaed"/>
                </Button>

                <TextBox Grid.Column="3" Name="txtNavigateUrl" Text="{Binding Simulation.NavigateUrlText, Mode=TwoWay}" PlaceholderText="Enter URL (e.g. http://127.0.0.1:9222/)" Height="26" VerticalContentAlignment="Center" FontSize="11" Padding="6,2" Margin="0,0,6,0">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding Simulation.NavigateCommand}"/>
                    </TextBox.KeyBindings>
                </TextBox>
                
                <Button Grid.Column="4" Command="{Binding Simulation.NavigateCommand}" Content="Go" Classes="accent" Height="26" MinWidth="0" MinHeight="0" FontSize="11" Padding="10,0" VerticalAlignment="Center" Margin="0,0,6,0"/>

                <!-- Screenshot Button -->
                <Button Grid.Column="5" Name="btnCaptureScreenshot" Command="{Binding Simulation.CaptureScreenshotCommand}" ToolTip.Tip="Capture Page Screenshot" Width="26" Height="26" MinWidth="0" MinHeight="0" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                    <PathIcon Data="{StaticResource CameraIcon}" Width="12" Height="12" Foreground="#e8eaed"/>
                </Button>
            </Grid>
        </Border>

        <!-- Row 1: Device Emulation, Zoom & View Toolbar -->
        <Border Grid.Row="1" Background="#242528" BorderBrush="#3c4043" BorderThickness="0,0,0,1" Padding="6,3">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <!-- Device Presets Dropdown -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="Device:" Foreground="#9aa0a6" FontSize="11" VerticalAlignment="Center"/>
                        <ComboBox Name="cmbDevicePresets"
                                  Width="140" Height="24"
                                  ItemsSource="{Binding Simulation.DevicePresets}"
                                  SelectedItem="{Binding Simulation.SelectedDevicePreset, Mode=TwoWay}"
                                  Background="#202124" BorderBrush="#3c4043" Foreground="#e8eaed" FontSize="11" VerticalAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:DevicePreset">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="11"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Target View / Window Selector Dropdown -->
                    <ComboBox Name="cmbTargetViews"
                              Width="160" Height="24"
                              ItemsSource="{Binding Simulation.TargetViews}"
                              SelectedItem="{Binding Simulation.SelectedTargetView, Mode=TwoWay}"
                              ToolTip.Tip="Target View: Preview &amp; inspect all windows/popups composited together or select specific target"
                              Background="#202124" BorderBrush="#3c4043" Foreground="#e8eaed" FontSize="11" VerticalAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:TargetViewItemViewModel">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <PathIcon Data="{StaticResource WindowIcon}" Width="10" Height="10" Foreground="#8ab4f8"/>
                                    <TextBlock Text="{Binding Title}" FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Segmented Dimension Input Pill: Width x Height [Swap] -->
                    <Border Background="#202124" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4" Padding="2,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                            <TextBox Name="txtWidth" Text="{Binding Simulation.WidthText, Mode=TwoWay}" Width="44" Height="20" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="11" Padding="0"/>
                            <TextBlock Text="×" Foreground="#9aa0a6" FontSize="11" VerticalAlignment="Center"/>
                            <TextBox Name="txtHeight" Text="{Binding Simulation.HeightText, Mode=TwoWay}" Width="44" Height="20" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="11" Padding="0"/>
                            <Button Command="{Binding Simulation.RotateDeviceCommand}" ToolTip.Tip="Swap Orientation (Width × Height)" Width="20" Height="20" MinWidth="0" MinHeight="0" Padding="0" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                <PathIcon Data="{StaticResource SwapVertIcon}" Width="10" Height="10" Foreground="#e8eaed"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Device Settings Flyout Button -->
                    <Button Name="btnDeviceSettingsFlyout" ToolTip.Tip="Device Emulation Settings (DPR, Mobile UA, Apply)" Width="24" Height="24" MinWidth="0" MinHeight="0" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                        <PathIcon Data="{StaticResource SlidersIcon}" Width="12" Height="12" Foreground="#e8eaed"/>
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <Border Background="#28292c" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="6" Padding="12" Width="220">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Device Emulation Settings" FontWeight="Bold" FontSize="12" Foreground="#e8eaed"/>
                                        <Separator Background="#3c4043" Height="1" Margin="0,-4,0,0"/>

                                        <Grid ColumnDefinitions="*, Auto" VerticalAlignment="Center">
                                            <TextBlock Text="Scale Factor (DPR):" FontSize="11" Foreground="#9aa0a6" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Name="txtScaleFactor" Text="{Binding Simulation.ScaleFactorText, Mode=TwoWay}" Width="48" Height="24" FontSize="11" VerticalContentAlignment="Center"/>
                                        </Grid>

                                        <CheckBox Name="chkMobile" IsChecked="{Binding Simulation.IsMobileActive, Mode=TwoWay}" Content="Emulate Mobile Touch &amp; UA" FontSize="11"/>

                                        <Grid ColumnDefinitions="*, *" ColumnSpacing="6" Margin="0,4,0,0">
                                            <Button Name="btnResizeReset" Command="{Binding Simulation.ResizeResetCommand}" Content="Reset" Height="26" MinWidth="0" MinHeight="0" FontSize="11" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                            <Button Grid.Column="1" Name="btnResize" Command="{Binding Simulation.ResizeCommand}" Content="Apply" Classes="accent" Height="26" MinWidth="0" MinHeight="0" FontSize="11" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <!-- Divider -->
                    <Border Width="1" Height="16" Background="#3c4043" VerticalAlignment="Center"/>

                    <!-- Segmented Zoom & Pan Pill -->
                    <Border Background="#202124" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4" Padding="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="1">
                            <Button Name="btnZoomOut" Command="{Binding Simulation.ZoomOutCommand}" ToolTip.Tip="Zoom Out (Ctrl + Scroll Down)" Width="24" Height="22" MinWidth="0" MinHeight="0" Padding="0" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                <PathIcon Data="{StaticResource ZoomOutIcon}" Width="10" Height="10" Foreground="#e8eaed"/>
                            </Button>
                            <ComboBox Name="cmbZoomPresets"
                                      Width="72" Height="22"
                                      ItemsSource="{Binding Simulation.ZoomPresets}"
                                      SelectedItem="{Binding Simulation.SelectedZoomPreset, Mode=TwoWay}"
                                      Background="Transparent" BorderThickness="0" Foreground="#e8eaed" FontSize="11" VerticalAlignment="Center"/>
                            <Button Name="btnZoomIn" Command="{Binding Simulation.ZoomInCommand}" ToolTip.Tip="Zoom In (Ctrl + Scroll Up)" Width="24" Height="22" MinWidth="0" MinHeight="0" Padding="0" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                <PathIcon Data="{StaticResource ZoomInIcon}" Width="10" Height="10" Foreground="#e8eaed"/>
                            </Button>
                            <ToggleButton Name="chkPanMode" IsChecked="{Binding Simulation.IsPanModeActive, Mode=TwoWay}" ToolTip.Tip="Toggle Pan Mode (Middle Mouse Drag or Space+Drag)" Width="24" Height="22" MinWidth="0" MinHeight="0" Padding="0" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                                <PathIcon Data="{StaticResource HandIcon}" Width="11" Height="11" Foreground="#e8eaed"/>
                            </ToggleButton>
                        </StackPanel>
                    </Border>

                    <!-- View Options Flyout Button -->
                    <Button Name="btnViewOptionsFlyout" ToolTip.Tip="View Options (Window Frame, Reset Pan)" Width="24" Height="24" MinWidth="0" MinHeight="0" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                        <PathIcon Data="{StaticResource EyeIcon}" Width="12" Height="12" Foreground="#e8eaed"/>
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <Border Background="#28292c" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="6" Padding="12" Width="200">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="View Options" FontWeight="Bold" FontSize="12" Foreground="#e8eaed"/>
                                        <Separator Background="#3c4043" Height="1" Margin="0,-4,0,0"/>

                                        <CheckBox Name="chkWindowFrame" IsChecked="{Binding Simulation.IsWindowFrameVisible, Mode=TwoWay}" Content="Show Window Frame" FontSize="11"/>
                                        
                                        <Button Name="btnResetPan" Command="{Binding Simulation.ResetPanCommand}" Content="Reset Pan Position (0,0)" Height="26" MinWidth="0" MinHeight="0" FontSize="11" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                        <Button Name="btnToggleFitZoom" Command="{Binding Simulation.ToggleFitZoomCommand}" Content="Fit Zoom to Screen" Height="26" MinWidth="0" MinHeight="0" FontSize="11" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Row 2: Dockable Split Panel containing Live Viewport and Advanced Manual Interaction Tools -->
        <controls:DockSplitPanel Grid.Row="2"
                                Header="Advanced Manual Interaction Tools"
                                IsExpanded="{Binding Simulation.IsAdvancedToolsExpanded, Mode=TwoWay}"
                                IsPinned="{Binding Simulation.IsAdvancedToolsPinned, Mode=TwoWay}"
                                PanelHeight="{Binding Simulation.AdvancedToolsPanelHeight, Mode=TwoWay}">
            <!-- Main Content: Screencast Viewport Container -->
            <controls:DockSplitPanel.MainContent>
                <Border Background="#1a1b1e" Focusable="True" Name="borderScreenshot" ClipToBounds="True">
                    <Grid Name="gridViewportContainer" Background="#1a1b1e">
                        <!-- Canvas container for viewport and virtual window -->
                        <Grid Name="gridCanvasTransformGroup" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel Name="panelVirtualWindow" Orientation="Vertical" Width="{Binding Simulation.DeviceWidth}">
                                <!-- Virtual Window Title Bar -->
                                <Border Name="borderVirtualWindowFrame"
                                        Width="{Binding Simulation.DeviceWidth}"
                                        IsVisible="{Binding Simulation.IsWindowFrameVisible}"
                                        Background="#2d2e31"
                                        BorderBrush="#3c4043"
                                        BorderThickness="1,1,1,0"
                                        CornerRadius="6,6,0,0"
                                        Padding="8,5">
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <PathIcon Data="{StaticResource WindowIcon}" Width="12" Height="12" Foreground="#8ab4f8"/>
                                            <TextBlock Text="{Binding Simulation.WindowTitle}" FontWeight="SemiBold" FontSize="11" Foreground="#e8eaed" VerticalAlignment="Center"/>
                                            <Border Background="#3c4043" CornerRadius="3" Padding="4,1" VerticalAlignment="Center" Margin="5,0,0,0">
                                                <TextBlock Text="{Binding Simulation.WindowStateText}" FontSize="9" Foreground="#9aa0a6"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Drag Region Hint -->
                                        <TextBlock Grid.Column="1" Text=":: Drag Title Bar to Pan ::" FontSize="10" Foreground="#5f6368" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                                            <Button Name="btnVirtualMinimize" Command="{Binding Simulation.VirtualMinimizeCommand}" ToolTip.Tip="Minimize Target Window" Width="24" Height="20" MinWidth="0" MinHeight="0" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Background="Transparent" BorderThickness="0">
                                                <PathIcon Data="{StaticResource MinimizeIcon}" Width="10" Height="10" Foreground="#9aa0a6"/>
                                            </Button>
                                            <Button Name="btnVirtualMaximize" Command="{Binding Simulation.VirtualMaximizeCommand}" ToolTip.Tip="Maximize / Restore Target Window" Width="24" Height="20" MinWidth="0" MinHeight="0" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Background="Transparent" BorderThickness="0">
                                                <PathIcon Data="{StaticResource MaximizeIcon}" Width="10" Height="10" Foreground="#9aa0a6"/>
                                            </Button>
                                            <Button Name="btnVirtualClose" Command="{Binding Simulation.VirtualCloseCommand}" ToolTip.Tip="Close Target Window" Width="24" Height="20" MinWidth="0" MinHeight="0" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Background="Transparent" BorderThickness="0">
                                                <PathIcon Data="{StaticResource CloseIcon}" Width="10" Height="10" Foreground="#ff5252"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Main Screencast Image & Highlight Overlay Frame -->
                                <Border Name="borderImageFrame"
                                        Width="{Binding Simulation.DeviceWidth}"
                                        Height="{Binding Simulation.DeviceHeight}"
                                        Background="#292a2d"
                                        BorderBrush="#3c4043"
                                        BorderThickness="1"
                                        CornerRadius="0,0,6,6">
                                    <Grid Name="gridImageContainer">
                                        <Image Name="imgScreenshot"
                                               Source="{Binding Simulation.ScreenshotImage}"
                                               Width="{Binding Simulation.DeviceWidth}"
                                               Height="{Binding Simulation.DeviceHeight}"
                                               Stretch="Uniform"/>
                                        <controls:PreviewHighlightOverlay Name="overlayHighlight"
                                                                          DeviceWidth="{Binding Simulation.DeviceWidth}"
                                                                          DeviceHeight="{Binding Simulation.DeviceHeight}"
                                                                          IsHighlightOverlayVisible="{Binding Simulation.IsHighlightOverlayVisible}"
                                                                          HighlightBoxModel="{Binding Simulation.HighlightBoxModel}"
                                                                          HighlightElementType="{Binding Simulation.HighlightElementType}"
                                                                          HighlightAxRole="{Binding Simulation.HighlightAxRole}"
                                                                          HighlightAxName="{Binding Simulation.HighlightAxName}"
                                                                          ActiveReplayIndicator="{Binding Simulation.ActiveReplayIndicator}"
                                                                          Width="{Binding Simulation.DeviceWidth}"
                                                                          Height="{Binding Simulation.DeviceHeight}"
                                                                          IsHitTestVisible="False"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- Virtual Window 8-Direction Resizing Overlay Handles -->
                            <Grid Name="gridResizeHandlesOverlay" IsHitTestVisible="True">
                                <!-- Edges -->
                                <Border Name="handleResizeTop" Height="8" Cursor="SizeNorthSouth" Background="Transparent" VerticalAlignment="Top" Margin="10,-4,10,0"/>
                                <Border Name="handleResizeBottom" Height="8" Cursor="SizeNorthSouth" Background="Transparent" VerticalAlignment="Bottom" Margin="10,0,10,-4"/>
                                <Border Name="handleResizeLeft" Width="8" Cursor="SizeWestEast" Background="Transparent" HorizontalAlignment="Left" Margin="-4,10,0,10"/>
                                <Border Name="handleResizeRight" Width="8" Cursor="SizeWestEast" Background="Transparent" HorizontalAlignment="Right" Margin="0,10,-4,10"/>

                                <!-- Corners -->
                                <Border Name="handleResizeTopLeft" Width="14" Height="14" Cursor="TopLeftCorner" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-7,-7,0,0">
                                    <Border Width="8" Height="8" Background="#8ab4f8" CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8" ToolTip.Tip="Drag Top-Left Corner to Resize"/>
                                </Border>
                                <Border Name="handleResizeTopRight" Width="14" Height="14" Cursor="TopRightCorner" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-7,-7,0">
                                    <Border Width="8" Height="8" Background="#8ab4f8" CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8" ToolTip.Tip="Drag Top-Right Corner to Resize"/>
                                </Border>
                                <Border Name="handleResizeBottomLeft" Width="14" Height="14" Cursor="BottomLeftCorner" Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-7,0,0,-7">
                                    <Border Width="8" Height="8" Background="#8ab4f8" CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8" ToolTip.Tip="Drag Bottom-Left Corner to Resize"/>
                                </Border>
                                <Border Name="handleResizeBottomRight" Width="14" Height="14" Cursor="BottomRightCorner" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-7,-7">
                                    <Border Width="8" Height="8" Background="#8ab4f8" CornerRadius="2" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8" ToolTip.Tip="Drag Bottom-Right Corner to Resize"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </controls:DockSplitPanel.MainContent>

            <!-- Bottom Split Panel Content: Advanced Manual Interaction Tools -->
            <controls:DockSplitPanel.Content>
                <ScrollViewer MaxHeight="250">
                    <Grid ColumnDefinitions="*, *" Margin="5">
                        <!-- Left side: Manual actions -->
                        <StackPanel Spacing="10" Margin="0,0,10,0">
                            <!-- Mouse click element -->
                            <StackPanel Spacing="3">
                                <TextBlock Text="Selected Element Actions" FontWeight="SemiBold" Foreground="#8ab4f8" FontSize="11"/>
                                <Button Name="btnClick" Command="{Binding Simulation.ClickCommand}" Content="Click Selected Element Center" Classes="accent" FontSize="11" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            
                            <!-- Keyboard Simulation -->
                            <StackPanel Spacing="3">
                                <TextBlock Text="Keyboard Simulation" FontWeight="SemiBold" Foreground="#8ab4f8" FontSize="11"/>
                                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,3">
                                    <TextBox Name="txtInputSim" Text="{Binding Simulation.InputSimText, Mode=TwoWay}" PlaceholderText="Text to insert..." Height="28" FontSize="11" VerticalContentAlignment="Center"/>
                                    <Button Name="btnSendText" Command="{Binding Simulation.SendTextCommand}" Grid.Column="1" Content="Send Text" FontSize="11" Margin="4,0,0,0"/>
                                </Grid>
                                <Grid ColumnDefinitions="*, Auto">
                                    <ComboBox Name="cbKeys" ItemsSource="{Binding Simulation.KeysList}" SelectedItem="{Binding Simulation.SelectedKey, Mode=TwoWay}" PlaceholderText="Select Key..." Height="28" FontSize="11" HorizontalAlignment="Stretch"/>
                                    <Button Name="btnSendKey" Command="{Binding Simulation.SendKeyCommand}" Grid.Column="1" Content="Send Key" FontSize="11" Margin="4,0,0,0"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,3,0,0">
                                    <CheckBox Name="chkCtrl" IsChecked="{Binding Simulation.IsCtrlActive, Mode=TwoWay}" Content="Ctrl" FontSize="10"/>
                                    <CheckBox Name="chkShift" IsChecked="{Binding Simulation.IsShiftActive, Mode=TwoWay}" Content="Shift" FontSize="10"/>
                                    <CheckBox Name="chkAlt" IsChecked="{Binding Simulation.IsAltActive, Mode=TwoWay}" Content="Alt" FontSize="10"/>
                                    <CheckBox Name="chkMeta" IsChecked="{Binding Simulation.IsMetaActive, Mode=TwoWay}" Content="Meta" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right side: Manual Coordinate actions -->
                        <StackPanel Grid.Column="1" Spacing="10" Margin="10,0,0,0">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Manual Coordinates Simulation" FontWeight="SemiBold" Foreground="#8ab4f8" FontSize="11"/>
                                <Grid ColumnDefinitions="*, *, *, *">
                                    <StackPanel Margin="0,0,3,3">
                                        <TextBlock Text="X" FontSize="9" Foreground="#9aa0a6"/>
                                        <TextBox Name="txtMousePointX" Text="{Binding Simulation.MousePointXText, Mode=TwoWay}" Height="28" FontSize="11" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,3,3">
                                        <TextBlock Text="Y" FontSize="9" Foreground="#9aa0a6"/>
                                        <TextBox Name="txtMousePointY" Text="{Binding Simulation.MousePointYText, Mode=TwoWay}" Height="28" FontSize="11" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="0,0,3,3">
                                        <TextBlock Text="Drag End X" FontSize="9" Foreground="#9aa0a6"/>
                                        <TextBox Name="txtMouseDragEndX" Text="{Binding Simulation.MouseDragEndXText, Mode=TwoWay}" Height="28" FontSize="11" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Margin="0,0,0,3">
                                        <TextBlock Text="Drag End Y" FontSize="9" Foreground="#9aa0a6"/>
                                        <TextBox Name="txtMouseDragEndY" Text="{Binding Simulation.MouseDragEndYText, Mode=TwoWay}" Height="28" FontSize="11" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                                
                                <Grid ColumnDefinitions="*, *, Auto">
                                    <StackPanel Margin="0,0,3,0">
                                        <TextBlock Text="Button" FontSize="9" Foreground="#9aa0a6"/>
                                        <ComboBox Name="cbMouseButton" ItemsSource="{Binding Simulation.MouseButtonsList}" SelectedItem="{Binding Simulation.MouseButtonText, Mode=TwoWay}" Height="28" FontSize="11" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="3,0,3,0">
                                        <TextBlock Text="Clicks" FontSize="9" Foreground="#9aa0a6"/>
                                        <TextBox Name="txtMouseClickCount" Text="{Binding Simulation.MouseClickCountText, Mode=TwoWay}" Height="28" FontSize="11" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,5,0,0">
                                    <Button Name="btnMouseMove" Command="{Binding Simulation.MouseMoveCommand}" Content="Move" FontSize="11"/>
                                    <Button Name="btnMouseClickAtPoint" Command="{Binding Simulation.MouseClickAtPointCommand}" Content="Click Point" FontSize="11"/>
                                    <Button Name="btnMouseDrag" Command="{Binding Simulation.MouseDragCommand}" Content="Drag" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Scroll simulation -->
                            <StackPanel Spacing="3">
                                <TextBlock Text="Manual Wheel Scroll" FontWeight="SemiBold" Foreground="#8ab4f8" FontSize="11"/>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBox Name="txtScrollDeltaY" Text="{Binding Simulation.ScrollDeltaYText, Mode=TwoWay}" Width="60" Height="28" FontSize="11" VerticalContentAlignment="Center"/>
                                    <Button Name="btnScroll" Command="{Binding Simulation.ScrollCommand}" Content="Scroll" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </controls:DockSplitPanel.Content>
        </controls:DockSplitPanel>
    </Grid>
</UserControl>
