<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             x:Class="CdpInspectorApp.Views.SourcesView"
             x:CompileBindings="False">
    <Grid ColumnDefinitions="260, 4, *" Margin="10">
        <!-- Left Workspace navigator -->
        <Grid RowDefinitions="Auto, *">
            <TextBlock Text="Workspace Navigator" Classes="panel-header"/>
            <TreeView Name="treeWorkspaceFiles" ItemsSource="{Binding Sources.WorkspaceFiles}" SelectedItem="{Binding Sources.SelectedFile, Mode=TwoWay}" Grid.Row="1">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Background="#3c4043"/>

        <!-- Code Viewer -->
        <Grid Grid.Column="2" RowDefinitions="Auto, *" Margin="10,0,0,0">
            <TextBlock Name="lblSourceFileName" Text="{Binding Sources.SelectedFileName}" Classes="panel-header"/>
            <ae:TextEditor Name="txtSourceContent" Grid.Row="1" FontFamily="Consolas,Monaco,Courier New,monospace" FontSize="11" Foreground="#e8eaed" Background="Transparent" BorderThickness="0" ShowLineNumbers="True" IsReadOnly="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
        </Grid>
    </Grid>
</UserControl>
