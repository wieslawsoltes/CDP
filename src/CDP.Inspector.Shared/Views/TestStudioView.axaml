<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:CdpInspectorApp.Models"
             xmlns:services="clr-namespace:CdpInspectorApp.Services"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:controls="clr-namespace:CdpInspectorApp.Controls"
             xmlns:dgdd="clr-namespace:Avalonia.Controls.DataGridDragDrop;assembly=Avalonia.Controls.DataGrid"
             xmlns:map="using:XamlPlayground.Editor.Minimap"
             x:Class="CdpInspectorApp.Views.TestStudioView"
             x:CompileBindings="False">
    <Grid ColumnDefinitions="Auto, 4, *, 4, *">
        <!-- Column 0: Collapsible Workspace Sidebar Panel -->
        <Grid Grid.Column="0" RowDefinitions="Auto, *, Auto" Width="250" Margin="0,0,10,0" IsVisible="{Binding !Recorder.TestStudio.IsSidebarCollapsed}">
            <!-- Path picker TextBox/Browse button -->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                <TextBox Name="txtWorkspacePath" Grid.Column="0" Text="{Binding Recorder.TestStudio.WorkspaceRootPath, Mode=TwoWay}" PlaceholderText="Workspace root path..." FontSize="11" Height="24" Padding="4,2" VerticalAlignment="Center"/>
                <Button Name="btnBrowseWorkspace" Grid.Column="1" Content="..." Command="{Binding Recorder.TestStudio.BrowseWorkspaceRootCommand}" FontSize="10" Padding="6,3" Margin="4,0,0,0" VerticalAlignment="Center"/>
            </Grid>

            <!-- Workspace files listing (Hierarchical DataGrid) -->
            <DataGrid Name="treeWorkspace" Grid.Row="1"
                      HierarchicalModel="{Binding Recorder.TestStudio.HierarchicalWorkspace}"
                      SelectedItem="{Binding Recorder.TestStudio.SelectedWorkspaceNode, Mode=TwoWay}"
                      CanUserReorderRows="False"
                      CanUserResizeColumns="True"
                      HierarchicalRowsEnabled="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="None"
                      Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Create File" Command="{Binding Recorder.TestStudio.CreateFileCommand}"/>
                        <MenuItem Header="Create Folder" Command="{Binding Recorder.TestStudio.CreateFolderCommand}"/>
                        <MenuItem Header="Rename" Command="{Binding Recorder.TestStudio.RenameCommand}"/>
                        <MenuItem Header="Delete" Command="{Binding Recorder.TestStudio.DeleteCommand}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridHierarchicalColumn Width="*">
                        <DataGridHierarchicalColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,0">
                                    <TextBlock Text="📁" IsVisible="{Binding Item.IsFolder}" Foreground="#ffca28" VerticalAlignment="Center"/>
                                    <TextBlock Text="📄" IsVisible="{Binding !Item.IsFolder}" Foreground="#8ab4f8" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Item.Name}" FontSize="12" Foreground="#e8eaed" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridHierarchicalColumn.CellTemplate>
                    </DataGridHierarchicalColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Create file/folder/rename/delete buttons and "Run Folder Suite" button -->
            <StackPanel Grid.Row="2" Margin="0,10,0,0" Spacing="6">
                <WrapPanel HorizontalAlignment="Center">
                    <Button Name="btnCreateFile" Content="New File" Command="{Binding Recorder.TestStudio.CreateFileCommand}" FontSize="10" Margin="0,0,4,4"/>
                    <Button Name="btnCreateFolder" Content="New Folder" Command="{Binding Recorder.TestStudio.CreateFolderCommand}" FontSize="10" Margin="0,0,4,4"/>
                    <Button Name="btnRename" Content="Rename" Command="{Binding Recorder.TestStudio.RenameCommand}" FontSize="10" Margin="0,0,4,4"/>
                    <Button Name="btnDelete" Content="Delete" Command="{Binding Recorder.TestStudio.DeleteCommand}" FontSize="10" Margin="0,0,4,4"/>
                </WrapPanel>
                <Button Name="btnRunSuite" Content="Run Folder Suite" Command="{Binding Recorder.TestStudio.RunSuiteCommand}" CommandParameter="{Binding Recorder.TestStudio.SelectedWorkspaceItem.Path}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Classes="accent"/>
            </StackPanel>
        </Grid>

        <!-- Column 1: GridSplitter between Sidebar and Steps -->
        <GridSplitter Grid.Column="1" Background="#3c4043" IsVisible="{Binding !Recorder.TestStudio.IsSidebarCollapsed}"/>

        <!-- LEFT COLUMN: Steps List + Debugger Toolbar + Quick-Add panel -->
        <Grid Grid.Column="2" RowDefinitions="Auto, Auto, *, Auto" Margin="0,0,10,0">
            <!-- Debugger Toolbar -->
            <Border Grid.Row="0" Classes="panel-card" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="📁 Project" Command="{Binding Recorder.TestStudio.ToggleSidebarCommand}"/>
                    <TextBlock Text="Env:" VerticalAlignment="Center" FontSize="11" Foreground="#9aa0a6" Margin="4,0,0,0"/>
                    <ComboBox ItemsSource="{Binding Recorder.TestStudio.Environments}"
                              SelectedItem="{Binding Recorder.TestStudio.SelectedEnvironment, Mode=TwoWay}"
                              MinWidth="100" Height="24" FontSize="11" Padding="6,2" VerticalAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="⚙" Command="{Binding Recorder.TestStudio.ManageEnvironmentsCommand}" ToolTip.Tip="Manage Environments" FontSize="11" Padding="6,3" VerticalAlignment="Center"/>
                    <Button Name="btnTestStudioPlay" Content="▶ Play" Command="{Binding Recorder.TestStudio.PlayCommand}" Classes="accent"/>
                    <Button Name="btnTestStudioPause" Content="⏸ Pause" Command="{Binding Recorder.TestStudio.PauseCommand}"/>
                    <Button Name="btnTestStudioStop" Content="■ Stop" Command="{Binding Recorder.TestStudio.StopCommand}"/>
                    <Button Name="btnTestStudioStep" Content="↷ Step" Command="{Binding Recorder.TestStudio.StepOverCommand}"/>
                    <Button Name="btnTestStudioClear" Content="Clear" Command="{Binding Recorder.TestStudio.ClearCommand}"/>
                    <Button Name="btnTestStudioToggleRecord" Command="{Binding Recorder.ToggleRecordCommand}"
                            Content="{Binding Recorder.ToggleRecordButtonText}"
                            Background="{Binding Recorder.ToggleRecordButtonBackground}"
                            BorderBrush="{Binding Recorder.ToggleRecordButtonBorderBrush}"
                            Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Reporting Section -->
            <Border Grid.Row="1" Classes="panel-card" Margin="0,0,0,10">
                <Grid RowDefinitions="Auto, Auto" Margin="0">
                    <!-- Checkboxes -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="20" Margin="0,0,0,8">
                        <CheckBox Name="chkTestStudioRecordVideo" Content="Record Video" IsChecked="{Binding Recorder.TestStudio.IsRecordVideoEnabled}" FontSize="11" Margin="0"/>
                        <CheckBox Name="chkTestStudioGenerateReports" Content="Generate Reports" IsChecked="{Binding Recorder.TestStudio.IsGenerateReportEnabled}" FontSize="11" Margin="0"/>
                    </StackPanel>
                    
                    <!-- Path and Browse button, View buttons -->
                    <Grid Grid.Row="1" ColumnDefinitions="*, Auto, Auto, Auto, Auto">
                        <TextBox Name="txtTestStudioOutputDirectory" Grid.Column="0" Text="{Binding Recorder.TestStudio.OutputDirectory, Mode=TwoWay}" PlaceholderText="Output directory..." FontSize="11" Height="24" Padding="4,2" VerticalAlignment="Center"/>
                        <Button Name="btnBrowseReportDir" Grid.Column="1" Content="Browse..." FontSize="10" Padding="6,3" Margin="4,0,0,0" VerticalAlignment="Center"/>
                        <Button Name="btnViewHtmlReport" Grid.Column="2" Content="HTML Report" Command="{Binding Recorder.TestStudio.OpenLastReportCommand}" FontSize="10" Padding="6,3" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <Button Name="btnViewPdfReport" Grid.Column="3" Content="PDF Report" Command="{Binding Recorder.TestStudio.OpenLastPdfReportCommand}" FontSize="10" Padding="6,3" Margin="4,0,0,0" VerticalAlignment="Center"/>
                        <Button Name="btnReplayLastVideo" Grid.Column="4" Content="Replay Video" Command="{Binding Recorder.TestStudio.ReplayLastVideoCommand}" CommandParameter="{Binding $parent[Window]}" FontSize="10" Padding="6,3" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Steps List -->
            <Grid Grid.Row="2" RowDefinitions="Auto, *">
                <TextBlock Grid.Row="0" Text="Test Steps" Classes="panel-header" Foreground="#e8eaed" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                <DataGrid Name="lstSteps" Grid.Row="1"
                             HierarchicalModel="{Binding Recorder.TestStudio.HierarchicalSteps}"
                             SelectedItem="{Binding Recorder.TestStudio.SelectedStepNode, Mode=TwoWay}"
                             CanUserReorderRows="True"
                             CanUserResizeColumns="True"
                             HierarchicalRowsEnabled="True"
                             RowDragHandle="RowHeaderAndRow"
                             GridLinesVisibility="Horizontal"
                             HeadersVisibility="Column"
                             RowDetailsVisibilityMode="VisibleWhenSelected"
                             Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                    <DataGrid.RowDropHandler>
                        <dgdd:DataGridHierarchicalRowReorderHandler />
                    </DataGrid.RowDropHandler>
                    <DataGrid.Styles>
                        <!-- Style for the hierarchical column's TextBlock -->
                        <Style Selector="DataGridCell TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Foreground" Value="#e8eaed"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Styles>
                    <DataGrid.Columns>
                        <!-- Status Column -->
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8" Fill="#9aa0a6" IsVisible="{Binding Item.IsPending}"/>
                                        <Ellipse Width="8" Height="8" Fill="#1a73e8" IsVisible="{Binding Item.IsRunning}"/>
                                        <TextBlock Text="✔" Foreground="#0f9d58" FontWeight="Bold" FontSize="12" IsVisible="{Binding Item.IsPassed}"/>
                                        <TextBlock Text="✘" Foreground="#c5221f" FontWeight="Bold" FontSize="12" IsVisible="{Binding Item.IsFailed}"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!-- Action Column (Hierarchical Column) -->
                        <DataGridHierarchicalColumn Header="Action" Width="1.5*" Binding="{Binding Item.ActionDisplay}" />
 
                        <!-- Selector Column -->
                        <DataGridTemplateColumn Header="Selector" Width="1.5*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Item.Selector}" Foreground="#8ab4f8" FontSize="12" FontWeight="Normal" VerticalAlignment="Center" Margin="12,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
 
                        <!-- Value Column -->
                        <DataGridTemplateColumn Header="Value" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Item.Value}" Foreground="#e8eaed" FontSize="12" FontWeight="Normal" VerticalAlignment="Center" Margin="12,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
 
                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate>
                            <Border Background="#202124" BorderBrush="#3c4043" BorderThickness="0,1,0,0" Padding="12">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                                        <Border Background="#1a73e8" CornerRadius="2" Padding="4,2">
                                            <TextBlock Text="EDIT" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                        <TextBlock Text="{Binding Item.ActionDisplay}" FontWeight="Bold" Foreground="#e8eaed" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid ColumnDefinitions="100, *">
                                        <TextBlock Grid.Column="0" Text="Action:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                        <AutoCompleteBox Grid.Column="1"
                                                         Text="{Binding Item.Action, Mode=TwoWay}"
                                                         ItemsSource="{Binding $parent[UserControl].DataContext.Recorder.TestStudio.CommandSuggestions}"
                                                         FilterMode="Contains"
                                                         FontSize="11"
                                                         Height="24"
                                                         Padding="4,2"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="100, *">
                                        <TextBlock Grid.Column="0" Text="Selector:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                        <AutoCompleteBox Grid.Column="1"
                                                         Text="{Binding Item.Selector, Mode=TwoWay}"
                                                         ItemsSource="{Binding Source={x:Static services:SelectorService.Instance}, Path=AvailableSelectors}"
                                                         FilterMode="Contains"
                                                         FontSize="11"
                                                         Height="24"
                                                         Padding="4,2"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="100, *">
                                        <TextBlock Grid.Column="0" Text="Value:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                        <AutoCompleteBox Grid.Column="1"
                                                         Text="{Binding Item.Value, Mode=TwoWay}"
                                                         ItemsSource="{Binding $parent[UserControl].DataContext.Recorder.TestStudio.ValueSuggestions}"
                                                         FilterMode="Contains"
                                                         FontSize="11"
                                                         Height="24"
                                                         Padding="4,2"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Item.ErrorMessage}" FontSize="11" Foreground="#ff6b6b" IsVisible="{Binding Item.ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                        <Button Content="▲" Command="{Binding $parent[UserControl].DataContext.Recorder.TestStudio.MoveUpStepCommand}" CommandParameter="{Binding Item}" Padding="6,2" FontSize="10"/>
                                        <Button Content="▼" Command="{Binding $parent[UserControl].DataContext.Recorder.TestStudio.MoveDownStepCommand}" CommandParameter="{Binding Item}" Padding="6,2" FontSize="10"/>
                                        <Button Content="✕" Command="{Binding $parent[UserControl].DataContext.Recorder.TestStudio.DeleteStepCommand}" CommandParameter="{Binding Item}" Padding="6,2" FontSize="10" Foreground="#ff6b6b" BorderBrush="#ff6b6b"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>
                </DataGrid>
            </Grid>

            <!-- Flow Command Toolbox -->
            <Border Grid.Row="3" Classes="panel-card" Margin="0,10,0,0">
                <StackPanel Spacing="8">
                    <TextBlock Text="Flow Command Toolbox" Classes="panel-header" Margin="0,0,0,4"/>

                    <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" Text="Command: " VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                        <AutoCompleteBox Name="acbTestStudioCommand" Grid.Column="1"
                                         Text="{Binding Recorder.TestStudio.SelectedCommandName, Mode=TwoWay}"
                                         ItemsSource="{Binding Recorder.TestStudio.CommandSuggestions}"
                                         FilterMode="Contains"
                                         FontSize="11"
                                         Margin="4,0,0,0"
                                         PlaceholderText="Type a flow command..."/>
                        <Button Name="btnTestStudioAddSelectedCommand" Grid.Column="2"
                                Content="Add"
                                Command="{Binding Recorder.TestStudio.AddSelectedCommandCommand}"
                                Margin="6,0,0,0"/>
                    </Grid>
                    
                    <!-- Target Selector using AutoCompleteBox -->
                    <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" Text="Target Selector: " VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                        <AutoCompleteBox Name="acbTestStudioTargetSelector" Grid.Column="1" 
                                         Text="{Binding Recorder.TestStudio.SelectedElementSelector, Mode=TwoWay}"
                                         ItemsSource="{Binding Source={x:Static services:SelectorService.Instance}, Path=AvailableSelectors}"
                                         FilterMode="Contains"
                                         FontSize="11" 
                                         Margin="4,0,0,0"
                                         PlaceholderText="Type or select a selector..."/>
                    </Grid>
 
                    <!-- Parameters Input -->
                    <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" Text="Value / Text: " VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                        <AutoCompleteBox Name="txtTestStudioInputValue" Grid.Column="1"
                                         Text="{Binding Recorder.TestStudio.InputSimText, Mode=TwoWay}"
                                         ItemsSource="{Binding Recorder.TestStudio.ValueSuggestions}"
                                         FilterMode="Contains"
                                         PlaceholderText="Value, text, expression, or delay..."
                                         FontSize="11"
                                         Margin="4,0,0,0"/>
                    </Grid>

                    <!-- Categories TabControl -->
                    <TabControl Background="Transparent" BorderThickness="0" Margin="0,4,0,0" MinHeight="100">
                        <!-- Interactions Tab -->
                        <TabItem Header="Interactions" FontSize="11">
                            <WrapPanel Margin="0,8,0,0">
                                <Button Name="btnTestStudioAddTap" Content="Tap" Command="{Binding Recorder.TestStudio.AddTapCommand}" Margin="0,0,6,6"/>
                                <Button Name="btnTestStudioAddDoubleTap" Content="Double Tap" Command="{Binding Recorder.TestStudio.AddDoubleTapCommand}" Margin="0,0,6,6"/>
                                <Button Name="btnTestStudioAddLongPress" Content="Long Press" Command="{Binding Recorder.TestStudio.AddLongPressCommand}" Margin="0,0,6,6"/>
                                <Button Name="btnTestStudioAddInputText" Content="Input Text" Command="{Binding Recorder.TestStudio.AddInputCommand}" Margin="0,0,6,6"/>
                                <Button Name="btnTestStudioAddClearText" Content="Clear Text" Command="{Binding Recorder.TestStudio.AddClearTextCommand}" Margin="0,0,6,6"/>
                                <Button Name="btnTestStudioAddPasteText" Content="Paste Text" Command="{Binding Recorder.TestStudio.AddPasteTextCommand}" Margin="0,0,6,6"/>
                                <Button Name="btnTestStudioAddEraseText" Content="Erase Text" Command="{Binding Recorder.TestStudio.AddEraseTextCommand}" Margin="0,0,6,6"/>
                                <Button Name="btnTestStudioAddSwipe" Content="Swipe" Command="{Binding Recorder.TestStudio.AddSwipeCommand}" Margin="0,0,6,6"/>
                                <Button Name="btnTestStudioAddScroll" Content="Scroll" Command="{Binding Recorder.TestStudio.AddScrollCommand}" Margin="0,0,6,6"/>
                                <Button Name="btnTestStudioAddCopyText" Content="Copy Text" Command="{Binding Recorder.TestStudio.AddCopyTextFromCommand}" Margin="0,0,6,6"/>
                            </WrapPanel>
                        </TabItem>
                        
                        <!-- Assertions Tab -->
                        <TabItem Header="Assertions" FontSize="11">
                            <WrapPanel Margin="0,8,0,0">
                                <Button Name="btnTestStudioAddAssertVisible" Content="Assert Visible" Command="{Binding Recorder.TestStudio.AddAssertVisibleCommand}" Margin="0,0,6,6"/>
                                <Button Name="btnTestStudioAddAssertNotVisible" Content="Assert Not Visible" Command="{Binding Recorder.TestStudio.AddAssertNotVisibleCommand}" Margin="0,0,6,6"/>
                                <Button Name="btnTestStudioAddAssertTrue" Content="Assert True" Command="{Binding Recorder.TestStudio.AddAssertTrueCommand}" Margin="0,0,6,6"/>
                                <Button Name="btnTestStudioAddAssertFalse" Content="Assert False" Command="{Binding Recorder.TestStudio.AddAssertFalseCommand}" Margin="0,0,6,6"/>
                            </WrapPanel>
                        </TabItem>
                        
                        <!-- App & Device Tab -->
                        <TabItem Header="App &amp; Device" FontSize="11">
                            <WrapPanel Margin="0,8,0,0">
                                <Button Content="Launch App" Command="{Binding Recorder.TestStudio.AddLaunchAppCommand}" Margin="0,0,6,6"/>
                                <Button Content="Stop App" Command="{Binding Recorder.TestStudio.AddStopAppCommand}" Margin="0,0,6,6"/>
                                <Button Content="Kill App" Command="{Binding Recorder.TestStudio.AddKillAppCommand}" Margin="0,0,6,6"/>
                                <Button Content="Clear State" Command="{Binding Recorder.TestStudio.AddClearStateCommand}" Margin="0,0,6,6"/>
                                <Button Content="Set Orientation" Command="{Binding Recorder.TestStudio.AddSetOrientationCommand}" Margin="0,0,6,6"/>
                                <Button Content="Set Location" Command="{Binding Recorder.TestStudio.AddSetLocationCommand}" Margin="0,0,6,6"/>
                                <Button Content="Set Airplane Mode" Command="{Binding Recorder.TestStudio.AddSetAirplaneModeCommand}" Margin="0,0,6,6"/>
                                <Button Content="Take Screenshot" Command="{Binding Recorder.TestStudio.AddTakeScreenshotCommand}" Margin="0,0,6,6"/>
                                <Button Content="Go Back" Command="{Binding Recorder.TestStudio.AddBackCommand}" Margin="0,0,6,6"/>
                                <Button Content="Delay (ms)" Command="{Binding Recorder.TestStudio.AddDelayCommand}" Margin="0,0,6,6"/>
                                <Button Content="Open Link" Command="{Binding Recorder.TestStudio.AddOpenLinkCommand}" Margin="0,0,6,6"/>
                            </WrapPanel>
                        </TabItem>

                        <!-- Logic Tab -->
                        <TabItem Header="Logic" FontSize="11">
                            <WrapPanel Margin="0,8,0,0">
                                <Button Content="Repeat" Command="{Binding Recorder.TestStudio.AddRepeatCommand}" Margin="0,0,6,6"/>
                                <Button Content="Retry" Command="{Binding Recorder.TestStudio.AddRetryCommand}" Margin="0,0,6,6"/>
                                <Button Content="Run Flow" Command="{Binding Recorder.TestStudio.AddRunFlowCommand}" Margin="0,0,6,6"/>
                                <Button Content="Eval Script" Command="{Binding Recorder.TestStudio.AddEvalScriptCommand}" Margin="0,0,6,6"/>
                            </WrapPanel>
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </Border>
        </Grid>

        <!-- GRID SPLITTER -->
        <GridSplitter Grid.Column="3" Background="#3c4043"/>

        <!-- RIGHT COLUMN: YAML Editor + Apply YAML button + execution logs -->
        <Grid Grid.Column="4" RowDefinitions="*, 4, *" Margin="10,0,0,0">
            <!-- YAML Editor -->
            <Grid Grid.Row="0" RowDefinitions="Auto, *" Margin="0,0,0,6">
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto" Margin="0,0,0,8">
                    <TextBlock Grid.Column="0" Text="YAML Configuration" Classes="panel-header" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Name="btnTestStudioApplyYaml" Grid.Column="1" Content="Apply YAML" Command="{Binding Recorder.TestStudio.ApplyYamlCommand}" Classes="accent" Margin="0,0,8,0"/>
                    <Button Name="btnTestStudioSaveYaml" Grid.Column="2" Content="Save" Command="{Binding Recorder.TestStudio.SaveYamlCommand}"/>
                </Grid>
                <Border Grid.Row="1" Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                    <map:MinimapTextEditor Name="txtYamlCode" Background="Transparent" BorderThickness="0" FontFamily="Courier New,Consolas,Monospace" FontSize="12" Foreground="#e8eaed" ShowLineNumbers="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
                </Border>
            </Grid>

            <!-- SPLITTER -->
            <GridSplitter Grid.Row="1" Background="#3c4043"/>

            <!-- Execution Logs -->
            <Grid Grid.Row="2" RowDefinitions="Auto, *" Margin="0,6,0,0">
                <TextBlock Grid.Row="0" Text="Execution Log" Classes="panel-header" FontSize="14" FontWeight="Bold"/>
                <ListBox Grid.Row="1" ItemsSource="{Binding Recorder.TestStudio.Logs}" Background="#202124" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Courier New,Consolas,Monospace" FontSize="11" Foreground="#e8eaed"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>


        <!-- Inline Name Prompt Overlay -->
        <Border Grid.ColumnSpan="5" Background="#80000000" IsVisible="{Binding Recorder.TestStudio.IsNamePromptVisible}" ZIndex="100">
            <Border Background="#2d2d2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="8" Width="300" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding Recorder.TestStudio.NamePromptTitle}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBox Text="{Binding Recorder.TestStudio.NamePromptValue, Mode=TwoWay}" PlaceholderText="Enter name..."/>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding Recorder.TestStudio.CancelNamePromptCommand}"/>
                        <Button Content="OK" Command="{Binding Recorder.TestStudio.SubmitNamePromptCommand}" Classes="accent"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Manage Environments Overlay -->
        <Border Grid.ColumnSpan="5" Background="#80000000" IsVisible="{Binding Recorder.TestStudio.IsManageEnvironmentsVisible}" ZIndex="99">
            <Border Background="#2d2d2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="8" Width="600" Height="400" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="16">
                <Grid RowDefinitions="Auto, *, Auto">
                    <TextBlock Grid.Row="0" Text="Manage Environments" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                    
                    <Grid Grid.Row="1" ColumnDefinitions="150, 8, *">
                        <!-- Left Panel: List of Environments -->
                        <Grid Grid.Column="0" RowDefinitions="*, Auto">
                            <ListBox Grid.Row="0" ItemsSource="{Binding Recorder.TestStudio.Environments}" SelectedItem="{Binding Recorder.TestStudio.SelectedEnvironment, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" Margin="0,8,0,0">
                                <Button Content="Create" Command="{Binding Recorder.TestStudio.CreateEnvironmentCommand}" FontSize="10"/>
                                <Button Content="Delete" Command="{Binding Recorder.TestStudio.DeleteEnvironmentCommand}" FontSize="10" Foreground="#ff6b6b"/>
                            </StackPanel>
                        </Grid>

                        <GridSplitter Grid.Column="1" Background="#3c4043"/>

                        <!-- Right Panel: Active Environment Details -->
                        <Grid Grid.Column="2" RowDefinitions="Auto, Auto, *, Auto" Margin="8,0,0,0" IsVisible="{Binding Recorder.TestStudio.SelectedEnvironment, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <Grid Grid.Row="0" ColumnDefinitions="100, *" Margin="0,0,0,8">
                                <TextBlock Grid.Column="0" Text="Name:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                <TextBox Grid.Column="1" Text="{Binding Recorder.TestStudio.SelectedEnvironment.Name, Mode=TwoWay}" FontSize="11" Height="24" Padding="4,2"/>
                            </Grid>
                            <Grid Grid.Row="1" ColumnDefinitions="*, *" Margin="0,0,0,8">
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Text="Included Tags (comma-separated):" Foreground="#9aa0a6" FontSize="10" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding Recorder.TestStudio.SelectedEnvironment.IncludedTags, Mode=TwoWay}" FontSize="11" Height="24" Padding="4,2"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <TextBlock Text="Excluded Tags (comma-separated):" Foreground="#9aa0a6" FontSize="10" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding Recorder.TestStudio.SelectedEnvironment.ExcludedTags, Mode=TwoWay}" FontSize="11" Height="24" Padding="4,2"/>
                                </StackPanel>
                            </Grid>
                            
                            <Grid Grid.Row="2" RowDefinitions="Auto, *">
                                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                    <TextBlock Grid.Column="0" Text="Variables:" Foreground="#9aa0a6" FontSize="11" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="Add" Command="{Binding Recorder.TestStudio.AddVariableCommand}" FontSize="9" Padding="4,2"/>
                                </Grid>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding Recorder.TestStudio.SelectedEnvironment.Variables}" CanUserReorderRows="False" CanUserResizeColumns="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" Background="#202124" BorderBrush="#3c4043" BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Key" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Key, Mode=TwoWay}" FontSize="11" BorderThickness="0" Background="Transparent" Padding="4,2" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Value" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Value, Mode=TwoWay}" FontSize="11" BorderThickness="0" Background="Transparent" Padding="4,2" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Width="40">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="✕" Command="{Binding $parent[UserControl].DataContext.Recorder.TestStudio.DeleteVariableCommand}" CommandParameter="{Binding}" Foreground="#ff6b6b" FontSize="9" Padding="4,2" HorizontalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Cancel" Command="{Binding Recorder.TestStudio.CancelEnvironmentsCommand}"/>
                        <Button Content="Save" Command="{Binding Recorder.TestStudio.SaveEnvironmentsCommand}" Classes="accent"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
