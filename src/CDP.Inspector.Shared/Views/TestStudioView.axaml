<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:CdpInspectorApp.Models"
             xmlns:services="clr-namespace:CdpInspectorApp.Services"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             xmlns:controls="clr-namespace:CdpInspectorApp.Controls"
             xmlns:dgdd="clr-namespace:Avalonia.Controls.DataGridDragDrop;assembly=Avalonia.Controls.DataGrid"
             xmlns:map="using:XamlPlayground.Editor.Minimap"
             xmlns:vm="clr-namespace:CdpInspectorApp.ViewModels"
             xmlns:tree="clr-namespace:Avalonia.Controls.DataGridHierarchical;assembly=Avalonia.Controls.DataGrid"
             xmlns:views="clr-namespace:CdpInspectorApp.Views"
             xmlns:rules="clr-namespace:CdpInspectorApp.Services.AssertionRules"
             x:Class="CdpInspectorApp.Views.TestStudioView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="True">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding Recorder.TestStudio.SidebarColumnWidth, Mode=TwoWay}"/>
            <ColumnDefinition Width="{Binding Recorder.TestStudio.SidebarSplitterWidth, Mode=TwoWay}"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- Column 0: Collapsible Workspace Sidebar Panel -->
        <Grid Grid.Column="0" RowDefinitions="*, 4, *" Margin="0,0,10,0" IsVisible="{Binding !Recorder.TestStudio.IsSidebarCollapsed}">
            <!-- Project Explorer -->
            <Grid Grid.Row="0" RowDefinitions="Auto, *, Auto">
                <!-- Path picker TextBox/Browse button -->
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                    <TextBox Name="txtWorkspacePath" Grid.Column="0" Text="{Binding Recorder.TestStudio.WorkspaceRootPath, Mode=TwoWay}" PlaceholderText="Workspace root path..." FontSize="11" Height="24" Padding="4,2" VerticalAlignment="Center"/>
                    <Button Name="btnBrowseWorkspace" Grid.Column="1" Content="..." Command="{Binding Recorder.TestStudio.BrowseWorkspaceRootCommand}" FontSize="10" Padding="6,3" Margin="4,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <!-- Workspace files listing (Hierarchical DataGrid) -->
                <DataGrid Name="treeWorkspace" Grid.Row="1"
                          HierarchicalModel="{Binding Recorder.TestStudio.HierarchicalWorkspace}"
                          SelectedItem="{Binding Recorder.TestStudio.SelectedWorkspaceNode, Mode=TwoWay}"
                          CanUserReorderRows="False"
                          CanUserResizeColumns="True"
                          HierarchicalRowsEnabled="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="None"
                          Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                    <DataGrid.ContextMenu>
                        <ContextMenu x:DataType="vm:MainWindowViewModel">
                            <MenuItem Header="Create File" Command="{Binding Recorder.TestStudio.CreateFileCommand}"/>
                            <MenuItem Header="Create Folder" Command="{Binding Recorder.TestStudio.CreateFolderCommand}"/>
                            <MenuItem Header="Rename" Command="{Binding Recorder.TestStudio.RenameCommand}"/>
                            <MenuItem Header="Delete" Command="{Binding Recorder.TestStudio.DeleteCommand}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridHierarchicalColumn Width="*">
                            <DataGridHierarchicalColumn.CellTemplate>
                                <DataTemplate x:DataType="tree:HierarchicalNode">
                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,0">
                                        <PathIcon Data="{StaticResource FolderIcon}" Width="14" Height="14" Foreground="#ffca28" IsVisible="{Binding ((models:WorkspaceItemModel)Item).IsFolder}" VerticalAlignment="Center"/>
                                        <PathIcon Data="{StaticResource FileIcon}" Width="14" Height="14" Foreground="#8ab4f8" IsVisible="{Binding !((models:WorkspaceItemModel)Item).IsFolder}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ((models:WorkspaceItemModel)Item).Name}" FontSize="12" Foreground="#e8eaed" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridHierarchicalColumn.CellTemplate>
                        </DataGridHierarchicalColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Create file/folder/rename/delete buttons and "Run Folder Suite" button -->
                <StackPanel Grid.Row="2" Margin="0,10,0,0" Spacing="6">
                    <WrapPanel HorizontalAlignment="Center">
                        <Button Name="btnCreateFile" Content="New File" Command="{Binding Recorder.TestStudio.CreateFileCommand}" FontSize="10" Margin="0,0,4,4"/>
                        <Button Name="btnCreateFolder" Content="New Folder" Command="{Binding Recorder.TestStudio.CreateFolderCommand}" FontSize="10" Margin="0,0,4,4"/>
                        <Button Name="btnRename" Content="Rename" Command="{Binding Recorder.TestStudio.RenameCommand}" FontSize="10" Margin="0,0,4,4"/>
                        <Button Name="btnDelete" Content="Delete" Command="{Binding Recorder.TestStudio.DeleteCommand}" FontSize="10" Margin="0,0,4,4"/>
                    </WrapPanel>
                    <Button Name="btnRunSuite" Content="Run Folder Suite" Command="{Binding Recorder.TestStudio.RunSuiteCommand}" CommandParameter="{Binding Recorder.TestStudio.SelectedWorkspaceItem.Path}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Classes="accent"/>
                </StackPanel>
            </Grid>

            <!-- GridSplitter between Project Explorer and Flow Command Toolbox -->
            <GridSplitter Grid.Row="1" Background="#3c4043" ResizeDirection="Rows" HorizontalAlignment="Stretch"/>

            <!-- Flow Command Toolbox -->
            <Border Grid.Row="2" BorderBrush="#3c4043" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                <ScrollViewer>
                    <StackPanel Spacing="8" Margin="0,0,10,0">
                        <!-- Command autocomplete box -->
                        <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,4">
                            <TextBlock Grid.Column="0" Text="Cmd: " VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                            <AutoCompleteBox Name="acbTestStudioCommand" Grid.Column="1"
                                             Text="{Binding Recorder.TestStudio.SelectedCommandName, Mode=TwoWay}"
                                             ItemsSource="{Binding Recorder.TestStudio.CommandSuggestions}"
                                             FilterMode="Contains"
                                             FontSize="11"
                                             Margin="4,0,0,0"
                                             PlaceholderText="Command..."/>
                            <Button Name="btnTestStudioAddSelectedCommand" Grid.Column="2"
                                    Content="Add"
                                    Command="{Binding Recorder.TestStudio.AddSelectedCommandCommand}"
                                    Margin="6,0,0,0"/>
                        </Grid>
                        
                        <!-- Target Selector -->
                        <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,4">
                            <TextBlock Grid.Column="0" Text="Target: " VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                            <AutoCompleteBox Name="acbTestStudioTargetSelector" Grid.Column="1" 
                                             Text="{Binding Recorder.TestStudio.SelectedElementSelector, Mode=TwoWay}"
                                             ItemsSource="{Binding Source={x:Static services:SelectorService.Instance}, Path=AvailableSelectors}"
                                             FilterMode="Contains"
                                             FontSize="11" 
                                             Margin="4,0,0,0"
                                             PlaceholderText="Selector..."/>
                        </Grid>
     
                        <!-- Parameters Input -->
                        <Grid ColumnDefinitions="Auto, *" Margin="0,0,0,4">
                            <TextBlock Grid.Column="0" Text="Value: " VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                            <AutoCompleteBox Name="txtTestStudioInputValue" Grid.Column="1"
                                             Text="{Binding Recorder.TestStudio.InputSimText, Mode=TwoWay}"
                                             ItemsSource="{Binding Recorder.TestStudio.ValueSuggestions}"
                                             FilterMode="Contains"
                                             PlaceholderText="Value/text/delay..."
                                             FontSize="11"
                                             Margin="4,0,0,0"/>
                        </Grid>

                        <!-- Categories Accordion -->
                        <controls:Accordion Name="toolboxAccordion" Margin="0,4,0,0">
                            <!-- Interactions Category -->
                            <controls:AccordionItem Header="Interactions" IsExpanded="True">
                                <WrapPanel Margin="0,4,0,0">
                                    <Button Name="btnTestStudioAddTap" Content="Tap" Command="{Binding Recorder.TestStudio.AddTapCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Name="btnTestStudioAddDoubleTap" Content="Double Tap" Command="{Binding Recorder.TestStudio.AddDoubleTapCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Name="btnTestStudioAddLongPress" Content="Long Press" Command="{Binding Recorder.TestStudio.AddLongPressCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Name="btnTestStudioAddInputText" Content="Input Text" Command="{Binding Recorder.TestStudio.AddInputCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Name="btnTestStudioAddClearText" Content="Clear" Command="{Binding Recorder.TestStudio.AddClearTextCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Name="btnTestStudioAddPasteText" Content="Paste" Command="{Binding Recorder.TestStudio.AddPasteTextCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Name="btnTestStudioAddEraseText" Content="Erase" Command="{Binding Recorder.TestStudio.AddEraseTextCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Name="btnTestStudioAddSwipe" Content="Swipe" Command="{Binding Recorder.TestStudio.AddSwipeCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Name="btnTestStudioAddScroll" Content="Scroll" Command="{Binding Recorder.TestStudio.AddScrollCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Name="btnTestStudioAddCopyText" Content="Copy" Command="{Binding Recorder.TestStudio.AddCopyTextFromCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                </WrapPanel>
                            </controls:AccordionItem>
                            
                            <!-- Assertions Category -->
                            <controls:AccordionItem Header="Assertions">
                                <WrapPanel Margin="0,4,0,0">
                                    <Button Name="btnTestStudioAddAssertVisible" Content="Assert Visible" Command="{Binding Recorder.TestStudio.AddAssertVisibleCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Name="btnTestStudioAddAssertNotVisible" Content="Assert Not Visible" Command="{Binding Recorder.TestStudio.AddAssertNotVisibleCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Name="btnTestStudioAddAssertTrue" Content="Assert True" Command="{Binding Recorder.TestStudio.AddAssertTrueCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Name="btnTestStudioAddAssertFalse" Content="Assert False" Command="{Binding Recorder.TestStudio.AddAssertFalseCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Name="btnTestStudioAddAssertProperty" Content="Assert Property..." Command="{Binding Recorder.TestStudio.ShowAssertPropertyPickerCommand}" CommandParameter="{Binding Recorder.TestStudio.SelectedElementSelector}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                </WrapPanel>
                            </controls:AccordionItem>
                            
                            <!-- App & Device Category -->
                            <controls:AccordionItem Header="App &amp; Device">
                                <WrapPanel Margin="0,4,0,0">
                                    <Button Content="Launch" Command="{Binding Recorder.TestStudio.AddLaunchAppCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Content="Stop" Command="{Binding Recorder.TestStudio.AddStopAppCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Content="Kill" Command="{Binding Recorder.TestStudio.AddKillAppCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Content="Clear State" Command="{Binding Recorder.TestStudio.AddClearStateCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Content="Orient" Command="{Binding Recorder.TestStudio.AddSetOrientationCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Content="Location" Command="{Binding Recorder.TestStudio.AddSetLocationCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Content="Airplane" Command="{Binding Recorder.TestStudio.AddSetAirplaneModeCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Content="Screenshot" Command="{Binding Recorder.TestStudio.AddTakeScreenshotCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Content="Back" Command="{Binding Recorder.TestStudio.AddBackCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Content="Delay" Command="{Binding Recorder.TestStudio.AddDelayCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Content="Link" Command="{Binding Recorder.TestStudio.AddOpenLinkCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                </WrapPanel>
                            </controls:AccordionItem>
 
                            <!-- Logic Category -->
                            <controls:AccordionItem Header="Logic">
                                <WrapPanel Margin="0,4,0,0">
                                    <Button Content="Repeat" Command="{Binding Recorder.TestStudio.AddRepeatCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Content="Retry" Command="{Binding Recorder.TestStudio.AddRetryCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Content="Run Flow" Command="{Binding Recorder.TestStudio.AddRunFlowCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                    <Button Content="Eval Script" Command="{Binding Recorder.TestStudio.AddEvalScriptCommand}" Margin="0,0,4,4" Padding="6,3" FontSize="10"/>
                                </WrapPanel>
                            </controls:AccordionItem>
                        </controls:Accordion>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Column 1: GridSplitter between Sidebar and Steps -->
        <GridSplitter Grid.Column="1" Background="#3c4043" IsVisible="{Binding !Recorder.TestStudio.IsSidebarCollapsed}"/>

        <!-- LEFT COLUMN: Steps List + Debugger Toolbar -->
        <Grid Grid.Column="2" RowDefinitions="Auto, Auto, *" Margin="0,0,10,0">
            <!-- Debugger Toolbar -->
            <Border Grid.Row="0" Classes="panel-card" Margin="0,0,0,10">
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Group 1: Sidebar Toggle -->
                    <Button Command="{Binding Recorder.TestStudio.ToggleSidebarCommand}" Margin="0,2,8,2" Padding="8,4" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource FolderIcon}" Width="12" Height="12" Foreground="#ffca28"/>
                            <TextBlock Text="Project" VerticalAlignment="Center" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Group 2: Environment Selector -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,2,8,2">
                        <TextBlock Text="Env:" VerticalAlignment="Center" FontSize="11" Foreground="#9aa0a6"/>
                        <ComboBox ItemsSource="{Binding Recorder.TestStudio.Environments}"
                                  SelectedItem="{Binding Recorder.TestStudio.SelectedEnvironment, Mode=TwoWay}"
                                  MinWidth="100" Height="24" FontSize="11" Padding="6,2" VerticalAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:TestEnvironmentModel">
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Command="{Binding Recorder.TestStudio.ManageEnvironmentsCommand}" ToolTip.Tip="Manage Environments" Padding="6,3" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource SettingsIcon}" Width="12" Height="12" Foreground="#e8eaed"/>
                        </Button>
                    </StackPanel>

                    <!-- Group 3: Playback Controls (Icon-only) -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,2,8,2">
                        <Button Name="btnTestStudioPlay" Command="{Binding Recorder.TestStudio.PlayCommand}" Classes="accent" ToolTip.Tip="Play (Run Test Suite)" Padding="8,4" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource PlayIcon}" Width="12" Height="12" Foreground="White"/>
                        </Button>
                        <Button Name="btnTestStudioPause" Command="{Binding Recorder.TestStudio.PauseCommand}" ToolTip.Tip="Pause Playback" Padding="8,4" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource PauseIcon}" Width="12" Height="12" Foreground="#e8eaed"/>
                        </Button>
                        <Button Name="btnTestStudioStop" Command="{Binding Recorder.TestStudio.StopCommand}" ToolTip.Tip="Stop Playback" Padding="8,4" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource StopIcon}" Width="12" Height="12" Foreground="#e8eaed"/>
                        </Button>
                        <Button Name="btnTestStudioStep" Command="{Binding Recorder.TestStudio.StepOverCommand}" ToolTip.Tip="Step Over" Padding="8,4" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource StepIcon}" Width="12" Height="12" Foreground="#e8eaed"/>
                        </Button>
                    </StackPanel>

                    <!-- Group 4: Step Management & Recording -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,2,0,2">
                        <Button Name="btnTestStudioClear" Content="Clear" Command="{Binding Recorder.TestStudio.ClearCommand}" Padding="8,4" VerticalAlignment="Center"/>
                        <Button Name="btnTestStudioToggleRecord" Command="{Binding Recorder.ToggleRecordCommand}"
                                Content="{Binding Recorder.ToggleRecordButtonText}"
                                Background="{Binding Recorder.ToggleRecordButtonBackground}"
                                BorderBrush="{Binding Recorder.ToggleRecordButtonBorderBrush}"
                                Foreground="White"
                                Padding="8,4"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                </WrapPanel>
            </Border>

            <!-- Reporting Section -->
            <Border Grid.Row="1" Classes="panel-card" Margin="0,0,0,10">
                <Grid RowDefinitions="Auto, Auto, Auto, Auto" Margin="0">
                    <!-- Checkboxes -->
                    <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox Name="chkTestStudioRecordVideo" Content="Record Video" IsChecked="{Binding Recorder.TestStudio.IsRecordVideoEnabled}" FontSize="11" Margin="0,0,20,0"/>
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,20,0">
                            <CheckBox Name="chkTestStudioGenerateReports" Content="Generate Reports" IsChecked="{Binding Recorder.TestStudio.IsGenerateReportEnabled}" FontSize="11" Margin="0"/>
                            <Button Name="btnConfigureReports" Padding="4" VerticalAlignment="Center" ToolTip.Tip="Configure Report Options" Background="Transparent" BorderThickness="0">
                                <PathIcon Data="{StaticResource SettingsIcon}" Width="12" Height="12" Foreground="#e8eaed"/>
                                <Button.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedLeft">
                                        <Border Width="280" Padding="12" Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                                            <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto">
                                                <TextBlock Grid.Row="0" Text="Report Options" FontWeight="Bold" FontSize="12" Foreground="White" Margin="0,0,0,10"/>
                                                <CheckBox Grid.Row="1" Content="Include Screenshots" IsChecked="{Binding Recorder.TestStudio.ReportIncludeScreenshots, Mode=TwoWay}" FontSize="11" Margin="0,0,0,6"/>
                                                <CheckBox Grid.Row="2" Content="Include Performance Charts" IsChecked="{Binding Recorder.TestStudio.ReportIncludeCharts, Mode=TwoWay}" FontSize="11" Margin="0,0,0,6"/>
                                                <CheckBox Grid.Row="3" Content="Include Metrics Table" IsChecked="{Binding Recorder.TestStudio.ReportIncludeMetricsTable, Mode=TwoWay}" FontSize="11" Margin="0,0,0,6"/>
                                                <CheckBox Grid.Row="4" Content="Include Network Details" IsChecked="{Binding Recorder.TestStudio.ReportIncludeNetworkDetails, Mode=TwoWay}" FontSize="11" Margin="0"/>
                                            </Grid>
                                        </Border>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,20,0">
                            <CheckBox Name="chkTestStudioAutoAssertion" Content="Auto Assertions" IsChecked="{Binding Recorder.TestStudio.IsAutoAssertionEnabled}" FontSize="11" Margin="0"/>
                            <Button Name="btnConfigureAutoAssertions" Padding="4" VerticalAlignment="Center" ToolTip.Tip="Configure Auto Assertions" Background="Transparent" BorderThickness="0">
                                <PathIcon Data="{StaticResource SettingsIcon}" Width="12" Height="12" Foreground="#e8eaed"/>
                                <Button.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedLeft">
                                        <Border Width="320" Padding="12" Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                                            <Grid RowDefinitions="Auto, Auto, *">
                                                <TextBlock Grid.Row="0" Text="Auto Assertion Rules" FontWeight="Bold" FontSize="12" Foreground="White" Margin="0,0,0,10"/>
                                                <Grid Grid.Row="1" ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" Margin="0,0,0,12">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Stable Delay (ms)" FontSize="10" Foreground="#9aa0a6" Margin="0,0,0,4"/>
                                                    <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding Recorder.TestStudio.AssertionEngine.StableDelay, Mode=TwoWay}" FontSize="10" Height="22" Padding="4,2" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Poll Interval (ms)" FontSize="10" Foreground="#9aa0a6" Margin="0,0,0,4"/>
                                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Recorder.TestStudio.AssertionEngine.PollInterval, Mode=TwoWay}" FontSize="10" Height="22" Padding="4,2" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                </Grid>
                                                <ScrollViewer Grid.Row="2" MaxHeight="350">
                                                    <ItemsControl ItemsSource="{Binding Recorder.TestStudio.AssertionEngine.Rules}">
                                                        <ItemsControl.DataTemplates>
                                                            <DataTemplate DataType="rules:TextBoxAssertionRule">
                                                                <StackPanel Spacing="4" Margin="0,0,0,12">
                                                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsEnabled, Mode=TwoWay}" FontSize="11" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding Description}" FontSize="10" Foreground="#9aa0a6" TextWrapping="Wrap" Margin="18,0,0,0" IsVisible="{Binding IsEnabled}"/>
                                                                    <CheckBox Content="Assert Empty Text" IsChecked="{Binding AssertEmptyText, Mode=TwoWay}" FontSize="10" Margin="18,2,0,0" IsVisible="{Binding IsEnabled}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                            <DataTemplate DataType="rules:DateTimeAssertionRule">
                                                                <StackPanel Spacing="4" Margin="0,0,0,12">
                                                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsEnabled, Mode=TwoWay}" FontSize="11" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding Description}" FontSize="10" Foreground="#9aa0a6" TextWrapping="Wrap" Margin="18,0,0,0" IsVisible="{Binding IsEnabled}"/>
                                                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="18,2,0,0" IsVisible="{Binding IsEnabled}">
                                                                        <CheckBox Content="Assert Date" IsChecked="{Binding AssertDate, Mode=TwoWay}" FontSize="10"/>
                                                                        <CheckBox Content="Assert Time" IsChecked="{Binding AssertTime, Mode=TwoWay}" FontSize="10"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                            <DataTemplate DataType="rules:IAssertionInferenceRule">
                                                                <StackPanel Spacing="4" Margin="0,0,0,12">
                                                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsEnabled, Mode=TwoWay}" FontSize="11" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding Description}" FontSize="10" Foreground="#9aa0a6" TextWrapping="Wrap" Margin="18,0,0,0" IsVisible="{Binding IsEnabled}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.DataTemplates>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>
                        <CheckBox Name="chkTestStudioAutoLaunch" Content="Auto Launch App" IsChecked="{Binding Recorder.TestStudio.IsAutoLaunchEnabled}" FontSize="11" Margin="0,0,20,0"/>
                        <CheckBox Name="chkTestStudioMovePhysicalCursor" Content="Move OS Pointer" IsChecked="{Binding Recorder.TestStudio.MovePhysicalCursor}" FontSize="11" Margin="0,0,20,0" IsVisible="{Binding Connection.IsOsAutomation}"/>
                        <CheckBox Name="chkTestStudioUsePeerAutomation" Content="Use Peer Automation" IsChecked="{Binding Recorder.TestStudio.UsePeerAutomation}" FontSize="11" Margin="0" IsVisible="{Binding Connection.IsOsAutomation}"/>
                    </WrapPanel>
                    
                    <!-- Path and Browse button -->
                    <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="0,0,0,8">
                        <TextBox Name="txtTestStudioOutputDirectory" Grid.Column="0" Text="{Binding Recorder.TestStudio.OutputDirectory, Mode=TwoWay}" PlaceholderText="Output directory..." FontSize="11" Height="24" Padding="4,2" VerticalAlignment="Center"/>
                        <Button Name="btnBrowseReportDir" Grid.Column="1" Content="Browse..." FontSize="10" Padding="6,3" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Auto Launch Fields -->
                    <Grid Grid.Row="2" ColumnDefinitions="Auto, *, Auto, Auto, *" Margin="0,0,0,8" IsVisible="{Binding Recorder.TestStudio.IsAutoLaunchEnabled}">
                        <TextBlock Grid.Column="0" Text="App Path: " VerticalAlignment="Center" FontSize="11" Foreground="#9aa0a6" Margin="0,0,4,0"/>
                        <TextBox Name="txtAutoLaunchPath" Grid.Column="1" Text="{Binding Recorder.TestStudio.AutoLaunchPath, Mode=TwoWay}" PlaceholderText="Executable path..." FontSize="11" Height="24" Padding="4,2" VerticalAlignment="Center"/>
                        <Button Name="btnBrowseAutoLaunchPath" Grid.Column="2" Content="..." Command="{Binding Recorder.TestStudio.BrowseAutoLaunchPathCommand}" FontSize="10" Padding="6,3" Margin="4,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="Args: " VerticalAlignment="Center" FontSize="11" Foreground="#9aa0a6" Margin="0,0,4,0"/>
                        <TextBox Name="txtAutoLaunchArguments" Grid.Column="4" Text="{Binding Recorder.TestStudio.AutoLaunchArguments, Mode=TwoWay}" PlaceholderText="Launch arguments..." FontSize="11" Height="24" Padding="4,2" VerticalAlignment="Center"/>
                    </Grid>
 
                    <!-- View buttons (WrapPanel for responsiveness) -->
                    <WrapPanel Grid.Row="3" Orientation="Horizontal">
                        <Button Name="btnViewHtmlReport" Content="HTML Report" Command="{Binding Recorder.TestStudio.OpenLastReportCommand}" FontSize="10" Padding="6,3" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <Button Name="btnViewPdfReport" Content="PDF Report" Command="{Binding Recorder.TestStudio.OpenLastPdfReportCommand}" FontSize="10" Padding="6,3" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <Button Name="btnReplayLastVideo" Content="Replay Video" Command="{Binding Recorder.TestStudio.ReplayLastVideoCommand}" CommandParameter="{Binding $parent[Window]}" FontSize="10" Padding="6,3" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- Steps List -->
            <Grid Grid.Row="2">
                <TabControl>
                    <TabItem Header="Steps List">
                        <DataGrid Name="lstSteps"
                                  HierarchicalModel="{Binding Recorder.TestStudio.HierarchicalSteps}"
                                  SelectedItem="{Binding Recorder.TestStudio.SelectedStepNode, Mode=TwoWay}"
                                  CanUserReorderRows="True"
                                  CanUserResizeColumns="True"
                                  HierarchicalRowsEnabled="True"
                                  RowDragHandle="RowHeaderAndRow"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  RowDetailsVisibilityMode="VisibleWhenSelected"
                                  Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                            <DataGrid.RowDropHandler>
                                <dgdd:DataGridHierarchicalRowReorderHandler />
                            </DataGrid.RowDropHandler>
                            <DataGrid.Styles>
                                <!-- Style for the hierarchical column's TextBlock -->
                                <Style Selector="DataGridCell TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="#e8eaed"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGrid.Styles>
                            <DataGrid.Columns>
                                <!-- Status Column -->
                                <DataGridTemplateColumn Header="" Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="tree:HierarchicalNode">
                                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Ellipse Width="8" Height="8" Fill="#9aa0a6" IsVisible="{Binding ((models:TestStudioStepModel)Item).IsPending}"/>
                                                <Ellipse Width="8" Height="8" Fill="#1a73e8" IsVisible="{Binding ((models:TestStudioStepModel)Item).IsRunning}"/>
                                                <PathIcon Data="{StaticResource CheckIcon}" Width="12" Height="12" Foreground="#0f9d58" IsVisible="{Binding ((models:TestStudioStepModel)Item).IsPassed}"/>
                                                <PathIcon Data="{StaticResource CloseIcon}" Width="12" Height="12" Foreground="#c5221f" IsVisible="{Binding ((models:TestStudioStepModel)Item).IsFailed}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <!-- Action Column (Hierarchical Column) -->
                                <DataGridHierarchicalColumn Header="Action" Width="1.5*">
                                    <DataGridHierarchicalColumn.CellTemplate>
                                        <DataTemplate x:DataType="tree:HierarchicalNode">
                                            <TextBlock Text="{Binding ((models:TestStudioStepModel)Item).ActionDisplay}" />
                                        </DataTemplate>
                                    </DataGridHierarchicalColumn.CellTemplate>
                                </DataGridHierarchicalColumn>
         
                                <!-- Selector Column -->
                                <DataGridTemplateColumn Header="Selector" Width="1.5*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="tree:HierarchicalNode">
                                            <TextBlock Text="{Binding ((models:TestStudioStepModel)Item).Selector}" Foreground="#8ab4f8" FontSize="12" FontWeight="Normal" VerticalAlignment="Center" Margin="12,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
         
                                <!-- Value Column -->
                                <DataGridTemplateColumn Header="Value" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="tree:HierarchicalNode">
                                            <TextBlock Text="{Binding ((models:TestStudioStepModel)Item).Value}" Foreground="#e8eaed" FontSize="12" FontWeight="Normal" VerticalAlignment="Center" Margin="12,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
         
                            <DataGrid.RowDetailsTemplate>
                                <DataTemplate x:DataType="tree:HierarchicalNode">
                                    <Border Background="#202124" BorderBrush="#3c4043" BorderThickness="0,1,0,0" Padding="12">
                                        <StackPanel Spacing="8">
                                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4">
                                                <Border Background="#1a73e8" CornerRadius="2" Padding="4,2">
                                                    <TextBlock Text="EDIT" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                                <TextBlock Text="{Binding ((models:TestStudioStepModel)Item).ActionDisplay}" FontWeight="Bold" Foreground="#e8eaed" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <Grid ColumnDefinitions="100, *">
                                                <TextBlock Grid.Column="0" Text="Action:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                                <AutoCompleteBox Grid.Column="1"
                                                                 Text="{Binding ((models:TestStudioStepModel)Item).Action, Mode=TwoWay}"
                                                                 ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Recorder.TestStudio.CommandSuggestions}"
                                                                 FilterMode="Contains"
                                                                 FontSize="11"
                                                                 Height="24"
                                                                 Padding="4,2"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="100, *">
                                                <TextBlock Grid.Column="0" Text="Selector:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                                <AutoCompleteBox Grid.Column="1"
                                                                 Text="{Binding ((models:TestStudioStepModel)Item).Selector, Mode=TwoWay}"
                                                                 ItemsSource="{Binding Source={x:Static services:SelectorService.Instance}, Path=AvailableSelectors}"
                                                                 FilterMode="Contains"
                                                                 FontSize="11"
                                                                 Height="24"
                                                                 Padding="4,2"/>
                                            </Grid>
                                            <Grid ColumnDefinitions="100, *, Auto">
                                                <TextBlock Grid.Column="0" Text="Value:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                                <AutoCompleteBox Grid.Column="1"
                                                                 Text="{Binding ((models:TestStudioStepModel)Item).Value, Mode=TwoWay}"
                                                                 ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Recorder.TestStudio.ValueSuggestions}"
                                                                 FilterMode="Contains"
                                                                 FontSize="11"
                                                                 Height="24"
                                                                 Padding="4,2"/>
                                                <Button Grid.Column="2"
                                                        Content="..."
                                                        Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Recorder.TestStudio.BrowseExecutableCommand}"
                                                        CommandParameter="{Binding ((models:TestStudioStepModel)Item)}"
                                                        IsVisible="{Binding ((models:TestStudioStepModel)Item).IsLaunchApp}"
                                                        FontSize="10" Padding="6,3" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </Grid>
                                            <TextBlock Text="{Binding ((models:TestStudioStepModel)Item).ErrorMessage}" FontSize="11" Foreground="#ff6b6b" IsVisible="{Binding ((models:TestStudioStepModel)Item).ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                                <Button Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Recorder.TestStudio.MoveUpStepCommand}" CommandParameter="{Binding ((models:TestStudioStepModel)Item)}" Padding="6,2">
                                                    <PathIcon Data="{StaticResource ChevronUpIcon}" Width="10" Height="10" Foreground="#e8eaed"/>
                                                </Button>
                                                <Button Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Recorder.TestStudio.MoveDownStepCommand}" CommandParameter="{Binding ((models:TestStudioStepModel)Item)}" Padding="6,2">
                                                    <PathIcon Data="{StaticResource ChevronDownIcon}" Width="10" Height="10" Foreground="#e8eaed"/>
                                                </Button>
                                                <Button Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Recorder.TestStudio.DeleteStepCommand}" CommandParameter="{Binding ((models:TestStudioStepModel)Item)}" Padding="6,2" Foreground="#ff6b6b" BorderBrush="#ff6b6b">
                                                    <PathIcon Data="{StaticResource CloseIcon}" Width="10" Height="10" Foreground="#ff6b6b"/>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGrid.RowDetailsTemplate>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="Node Editor">
                        <views:TestStudioNodeEditorView Name="nodeEditorTab" DataContext="{Binding Recorder.TestStudio.NodeEditor}" />
                    </TabItem>
                </TabControl>
            </Grid>


        </Grid>

        <!-- GRID SPLITTER -->
        <GridSplitter Grid.Column="3" Background="#3c4043"/>

        <!-- RIGHT COLUMN: YAML Editor + Apply YAML button + execution logs -->
        <Grid Grid.Column="4" RowDefinitions="*, 4, *" Margin="10,0,0,0">
            <!-- YAML Editor -->
            <Grid Grid.Row="0" RowDefinitions="Auto, *" Margin="0,0,0,6">
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto" Margin="0,0,0,8">
                    <TextBlock Grid.Column="0" Text="YAML Configuration" Classes="panel-header" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Name="btnTestStudioApplyYaml" Grid.Column="1" Content="Apply YAML" Command="{Binding Recorder.TestStudio.ApplyYamlCommand}" Classes="accent" Margin="0,0,8,0"/>
                    <Button Name="btnTestStudioSaveYaml" Grid.Column="2" Content="Save" Command="{Binding Recorder.TestStudio.SaveYamlCommand}"/>
                </Grid>
                <Border Grid.Row="1" Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                    <map:MinimapTextEditor Name="txtYamlCode" Background="Transparent" BorderThickness="0" FontFamily="Courier New,Consolas,Monospace" FontSize="12" Foreground="#e8eaed" ShowLineNumbers="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"/>
                </Border>
            </Grid>

            <!-- SPLITTER -->
            <GridSplitter Grid.Row="1" Background="#3c4043"/>

            <!-- Execution Logs -->
            <Grid Grid.Row="2" RowDefinitions="Auto, *" Margin="0,6,0,0">
                <TextBlock Grid.Row="0" Text="Execution Log" Classes="panel-header" FontSize="14" FontWeight="Bold"/>
                <ListBox Grid.Row="1" ItemsSource="{Binding Recorder.TestStudio.Logs}" Background="#202124" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{Binding}" FontFamily="Courier New,Consolas,Monospace" FontSize="11" Foreground="#e8eaed"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>


        <!-- Inline Name Prompt Overlay -->
        <Border Grid.ColumnSpan="5" Background="#80000000" IsVisible="{Binding Recorder.TestStudio.IsNamePromptVisible}" ZIndex="100">
            <Border Background="#2d2d2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="8" Width="300" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding Recorder.TestStudio.NamePromptTitle}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    <TextBox Text="{Binding Recorder.TestStudio.NamePromptValue, Mode=TwoWay}" PlaceholderText="Enter name..."/>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding Recorder.TestStudio.CancelNamePromptCommand}"/>
                        <Button Content="OK" Command="{Binding Recorder.TestStudio.SubmitNamePromptCommand}" Classes="accent"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Inline Property Assertion Picker Overlay -->
        <Border Grid.ColumnSpan="5" Background="#80000000" IsVisible="{Binding Recorder.TestStudio.IsAssertPickerVisible}" ZIndex="101">
            <Border Background="#2d2d2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="8" Width="380" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding Recorder.TestStudio.AssertPickerTitle}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    
                    <!-- Property selector -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Property:" FontSize="11" Foreground="#9aa0a6"/>
                        <controls:EditableComboBox ItemsSource="{Binding Recorder.TestStudio.AssertPickerProperties}"
                                                  SelectedItem="{Binding Recorder.TestStudio.AssertPickerSelectedProperty, Mode=TwoWay}"
                                                  Text="{Binding Recorder.TestStudio.AssertPickerSelectedPropertyName, Mode=TwoWay}"
                                                  HorizontalAlignment="Stretch">
                            <controls:EditableComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ElementPropertyInfo">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock Text="{Binding Type, StringFormat='({0})'}" Foreground="#9aa0a6" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Value, StringFormat='= {0}'}" Foreground="#8ab4f8" FontSize="10" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </controls:EditableComboBox.ItemTemplate>
                        </controls:EditableComboBox>
                    </StackPanel>

                    <!-- Comparison Selector -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Assertion Type:" FontSize="11" Foreground="#9aa0a6"/>
                        <ComboBox SelectedIndex="{Binding Recorder.TestStudio.AssertPickerComparisonIndex, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Assert True (Property evaluates to true)"/>
                            <ComboBoxItem Content="Assert False (Property evaluates to false)"/>
                            <ComboBoxItem Content="Equals (Property == Value)"/>
                            <ComboBoxItem Content="Not Equals (Property != Value)"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Expected Value -->
                    <StackPanel Spacing="4" IsVisible="{Binding Recorder.TestStudio.IsAssertPickerValueInputVisible}">
                        <TextBlock Text="Expected Value:" FontSize="11" Foreground="#9aa0a6"/>
                        <TextBox Text="{Binding Recorder.TestStudio.AssertPickerValue, Mode=TwoWay}" PlaceholderText="Enter expected value..."/>
                    </StackPanel>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="Cancel" Command="{Binding Recorder.TestStudio.CancelAssertPickerCommand}"/>
                        <Button Content="OK" Command="{Binding Recorder.TestStudio.SubmitAssertPickerCommand}" Classes="accent"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Manage Environments Overlay -->
        <Border Grid.ColumnSpan="5" Background="#80000000" IsVisible="{Binding Recorder.TestStudio.IsManageEnvironmentsVisible}" ZIndex="99">
            <Border Background="#2d2d2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="8" Width="600" Height="400" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="16">
                <Grid RowDefinitions="Auto, *, Auto">
                    <TextBlock Grid.Row="0" Text="Manage Environments" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                    
                    <Grid Grid.Row="1" ColumnDefinitions="150, 8, *">
                        <!-- Left Panel: List of Environments -->
                        <Grid Grid.Column="0" RowDefinitions="*, Auto">
                            <ListBox Grid.Row="0" ItemsSource="{Binding Recorder.TestStudio.Environments}" SelectedItem="{Binding Recorder.TestStudio.SelectedEnvironment, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:TestEnvironmentModel">
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" Margin="0,8,0,0">
                                <Button Content="Create" Command="{Binding Recorder.TestStudio.CreateEnvironmentCommand}" FontSize="10"/>
                                <Button Content="Delete" Command="{Binding Recorder.TestStudio.DeleteEnvironmentCommand}" FontSize="10" Foreground="#ff6b6b"/>
                            </StackPanel>
                        </Grid>

                        <GridSplitter Grid.Column="1" Background="#3c4043"/>

                        <!-- Right Panel: Active Environment Details -->
                        <Grid Grid.Column="2" RowDefinitions="Auto, Auto, *, Auto" Margin="8,0,0,0" IsVisible="{Binding Recorder.TestStudio.SelectedEnvironment, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <Grid Grid.Row="0" ColumnDefinitions="100, *" Margin="0,0,0,8">
                                <TextBlock Grid.Column="0" Text="Name:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                                <TextBox Grid.Column="1" Text="{Binding Recorder.TestStudio.SelectedEnvironment.Name, Mode=TwoWay}" FontSize="11" Height="24" Padding="4,2"/>
                            </Grid>
                            <Grid Grid.Row="1" ColumnDefinitions="*, *" Margin="0,0,0,8">
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock Text="Included Tags (comma-separated):" Foreground="#9aa0a6" FontSize="10" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding Recorder.TestStudio.SelectedEnvironment.IncludedTags, Mode=TwoWay}" FontSize="11" Height="24" Padding="4,2"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <TextBlock Text="Excluded Tags (comma-separated):" Foreground="#9aa0a6" FontSize="10" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding Recorder.TestStudio.SelectedEnvironment.ExcludedTags, Mode=TwoWay}" FontSize="11" Height="24" Padding="4,2"/>
                                </StackPanel>
                            </Grid>
                            
                            <Grid Grid.Row="2" RowDefinitions="Auto, *">
                                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                    <TextBlock Grid.Column="0" Text="Variables:" Foreground="#9aa0a6" FontSize="11" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="Add" Command="{Binding Recorder.TestStudio.AddVariableCommand}" FontSize="9" Padding="4,2"/>
                                </Grid>
                                <DataGrid Grid.Row="1" ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Recorder.TestStudio.SelectedEnvironment.Variables}"
                                          x:DataType="models:EnvironmentVariableModel"
                                          CanUserReorderRows="False" CanUserResizeColumns="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" Background="#202124" BorderBrush="#3c4043" BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Key" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate x:DataType="models:EnvironmentVariableModel">
                                                    <TextBox Text="{Binding Key, Mode=TwoWay}" FontSize="11" BorderThickness="0" Background="Transparent" Padding="4,2" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Value" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate x:DataType="models:EnvironmentVariableModel">
                                                    <TextBox Text="{Binding Value, Mode=TwoWay}" FontSize="11" BorderThickness="0" Background="Transparent" Padding="4,2" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Width="40">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate x:DataType="models:EnvironmentVariableModel">
                                                    <Button Content="✕" Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Recorder.TestStudio.DeleteVariableCommand}" CommandParameter="{Binding}" Foreground="#ff6b6b" FontSize="9" Padding="4,2" HorizontalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Cancel" Command="{Binding Recorder.TestStudio.CancelEnvironmentsCommand}"/>
                        <Button Content="Save" Command="{Binding Recorder.TestStudio.SaveEnvironmentsCommand}" Classes="accent"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
