<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CdpInspectorApp.ViewModels"
             xmlns:models="clr-namespace:CdpInspectorApp.Models;assembly=CDP.Inspector.Shared"
             xmlns:tree="clr-namespace:Avalonia.Controls.DataGridHierarchical;assembly=Avalonia.Controls.DataGrid"
             xmlns:controls="clr-namespace:CdpInspectorApp.Controls"
             xmlns:splits="clr-namespace:CDP.Editor.Splits.Controls;assembly=CDP.Editor.Splits"
             x:Class="CdpInspectorApp.Views.ConsoleView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="True">
    <Grid RowDefinitions="*, Auto" Margin="10">
        <!-- Main Area: SuperSplit layout -->
        <splits:SuperSplit Name="SplitControl"
                           Grid.Row="0"
                           Root="{Binding Console.LayoutRoot}"
                           SelectedNode="{Binding Console.SelectedPane, Mode=TwoWay}"
                           DockGroup="ConsoleGroup"
                           ConstrainDockingToRoot="True"/>

        <Grid Name="HiddenPanel" IsVisible="False">
            <!-- Left Pane: Logs -->
            <Grid Name="ConsoleLogsPanel" RowDefinitions="Auto, *">
                <!-- Filter Toolbar -->
                <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Name="btnClearLogs" AutomationProperties.AutomationId="btnConsoleClear" Command="{Binding Console.ClearLogsCommand}" Content="Clear Console"/>
                        <StackPanel Orientation="Horizontal" Spacing="2" Background="#292a2d" Margin="5,0,0,0">
                            <ToggleButton Content="All" IsChecked="{Binding Console.FilterAll, Mode=TwoWay}" Padding="8,4" FontSize="11"/>
                            <ToggleButton Content="Error" IsChecked="{Binding Console.FilterError, Mode=TwoWay}" Padding="8,4" FontSize="11" Foreground="#f28b82"/>
                            <ToggleButton Content="Warning" IsChecked="{Binding Console.FilterWarning, Mode=TwoWay}" Padding="8,4" FontSize="11" Foreground="#fdd663"/>
                            <ToggleButton Content="Info" IsChecked="{Binding Console.FilterInfo, Mode=TwoWay}" Padding="8,4" FontSize="11" Foreground="#81c995"/>
                            <ToggleButton Content="Verbose" IsChecked="{Binding Console.FilterVerbose, Mode=TwoWay}" Padding="8,4" FontSize="11" Foreground="#9aa0a6"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <TextBox Name="btnConsoleFilter" Grid.Column="1" Text="{Binding Console.FilterQuery, Mode=TwoWay}" PlaceholderText="Filter log entries..." Height="28" Margin="10,0" VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="C# &amp; Traces logs" Foreground="#9aa0a6" VerticalAlignment="Center" FontSize="11"/>
                </Grid>

                <DataGrid Name="listLogs" ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Console.Logs}" Grid.Row="1" x:DataType="models:LogModel"
                          CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          Background="Transparent" BorderThickness="0"
                          DoubleTapped="OnLogEntryDoubleTapped">
                    <DataGrid.ColumnHeaderContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Columns" ItemsSource="{Binding $parent[DataGrid].Columns}">
                                <MenuItem.ItemContainerTheme>
                                     <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}" x:DataType="DataGridColumn">
                                         <Setter Property="Header" Value="{Binding Header}" />
                                         <Setter Property="IsChecked" Value="{Binding IsVisible, Mode=TwoWay}" />
                                         <Setter Property="ToggleType" Value="CheckBox" />
                                     </ControlTheme>
                                </MenuItem.ItemContainerTheme>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ColumnHeaderContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}" Width="90" Foreground="#9aa0a6" FontSize="12"/>
                        <DataGridTemplateColumn Header="Level" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:LogModel">
                                    <controls:LogLevelBadge Level="{Binding Level}" Height="18" Width="55" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Message" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="models:LogModel">
                                    <TextBlock Text="{Binding Text}" Foreground="#e8eaed" TextWrapping="Wrap" Margin="5" FontSize="12" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Right Pane: Watch Panel -->
            <Grid Name="ConsoleWatchPanel" RowDefinitions="Auto, *, Auto">
                <TextBlock Text="Live Pinned Expressions" Classes="panel-header" Margin="0,0,0,8"/>
                
                <ListBox Grid.Row="1" ItemsSource="{Binding Console.PinnedExpressions}" Background="#202124" BorderBrush="#3c4043">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:PinnedExpressionViewModel">
                            <Grid ColumnDefinitions="*, Auto" Margin="0,2">
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Expression}" Foreground="#8ab4f8" FontWeight="SemiBold" FontSize="12" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Result}" Foreground="{Binding ResultBrush}" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" 
                                        Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Console.RemovePinnedExpressionCommand}" 
                                        CommandParameter="{Binding}" 
                                        Background="Transparent" 
                                        BorderThickness="0" 
                                        Padding="4"
                                        VerticalAlignment="Center">
                                    <PathIcon Data="{StaticResource CloseIcon}" Width="12" Height="12" Foreground="#ff5252"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,8,0,0">
                    <TextBox Name="txtPinnedExpression" Text="{Binding Console.PinnedExpressionInputText, Mode=TwoWay}" PlaceholderText="Add expression..." Height="28" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" Command="{Binding Console.AddPinnedExpressionCommand}" Content="Add" Margin="5,0,0,0" Height="28" Padding="10,0"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- Script Evaluator input -->
        <Grid Grid.Row="1" RowDefinitions="Auto, Auto" Margin="0,10,0,0">
            <!-- Evaluations history -->
            <ListBox Name="listConsole" ItemsSource="{Binding Console.ConsoleHistory}" MaxHeight="120" Margin="0,0,0,8" Background="#202124" BorderBrush="#3c4043">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:ConsoleItemModel">
                        <StackPanel Margin="2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="❯ " Foreground="#8ab4f8" FontWeight="Bold" FontSize="12"/>
                                <TextBlock Text="{Binding Expression}" Foreground="#e8eaed" TextWrapping="Wrap" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="15,2,0,0" IsVisible="{Binding !IsObject}">
                                <TextBlock Text="value: " Foreground="#9aa0a6" FontSize="11" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Result}" Foreground="{Binding ResultBrush}" TextWrapping="Wrap" FontSize="12"/>
                            </StackPanel>
                            <DataGrid HierarchicalModel="{Binding HierarchicalResult}"
                                      HierarchicalRowsEnabled="True"
                                      HeadersVisibility="None"
                                      GridLinesVisibility="None"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      IsVisible="{Binding IsObject}"
                                      Margin="15,2,0,0"
                                      MaxHeight="300">
                                <DataGrid.Columns>
                                    <DataGridHierarchicalColumn Width="*">
                                        <DataGridHierarchicalColumn.CellTemplate>
                                            <DataTemplate x:DataType="tree:HierarchicalNode">
                                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,0">
                                                    <TextBlock Text="{Binding ((models:ConsoleObjectNode)Item).Name}" Foreground="#8ab4f8" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock Text=":" Foreground="#9aa0a6" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ((models:ConsoleObjectNode)Item).Value}" Foreground="#e8eaed" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ((models:ConsoleObjectNode)Item).Type, StringFormat='({0})'}" Foreground="#9aa0a6" FontSize="10" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridHierarchicalColumn.CellTemplate>
                                    </DataGridHierarchicalColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            
            <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                <TextBlock Text="❯" Foreground="#8ab4f8" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="5,0,8,0"/>
                <TextBox Grid.Column="1" Name="txtConsoleInput" Text="{Binding Console.ConsoleInputText, Mode=TwoWay}" PlaceholderText="{Binding Console.ConsolePlaceholderText}" Height="28" VerticalContentAlignment="Center"/>
                <Popup Grid.Column="1" IsOpen="{Binding Console.IsCompletionActive, Mode=TwoWay}" PlacementTarget="{Binding ElementName=txtConsoleInput}" Placement="Top" IsLightDismissEnabled="True">
                    <Border Background="#202124" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4" MaxHeight="200" Width="250">
                        <ListBox ItemsSource="{Binding Console.Completions}" SelectedIndex="{Binding Console.SelectedCompletionIndex, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="#e8eaed"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>
                <ToggleButton Grid.Column="2" IsChecked="{Binding Console.IsUiReplMode, Mode=TwoWay}" Content="UI REPL Mode" Margin="5,0,0,0" Height="28" Padding="10,0" FontSize="11" VerticalContentAlignment="Center"/>
                <Button Name="btnSendConsole" AutomationProperties.AutomationId="btnConsoleRun" Command="{Binding Console.EvaluateCommand}" Grid.Column="3" Content="Send" Margin="5,0,0,0" Padding="15,0" Height="28" Classes="accent"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
