<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CdpInspectorApp.ViewModels"
             xmlns:models="clr-namespace:CdpInspectorApp.Models;assembly=CDP.Inspector.Shared"
             xmlns:tree="clr-namespace:Avalonia.Controls.DataGridHierarchical;assembly=Avalonia.Controls.DataGrid"
             xmlns:controls="clr-namespace:CdpInspectorApp.Controls"
             xmlns:splits="clr-namespace:CDP.Editor.Splits.Controls;assembly=CDP.Editor.Splits"
             x:Class="CdpInspectorApp.Views.MemoryView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="True">
    <Grid RowDefinitions="*">
        <!-- SuperSplit Control -->
        <splits:SuperSplit Name="SplitControl"
                            Grid.Row="0"
                            Root="{Binding Memory.LayoutRoot}"
                            SelectedNode="{Binding Memory.SelectedPane, Mode=TwoWay}"
                            DockGroup="Memory"
                            ConstrainDockingToRoot="True"/>
        
        <Grid Name="HiddenPanel" IsVisible="False">
        <!-- Left panel (Snapshots list & controls) -->
        <Grid Name="pnlSnapshotsList" RowDefinitions="Auto, *" Margin="0,0,10,0">
            <StackPanel Spacing="8" Margin="0,0,0,10">
                <Button Name="btnTakeSnapshot" Command="{Binding Memory.TakeSnapshotCommand}" Content="Take Heap Snapshot" Classes="accent" HorizontalAlignment="Stretch"/>
                <Button Name="btnGcCollect" Command="{Binding Memory.CollectGarbageCommand}" Content="Collect Garbage" HorizontalAlignment="Stretch" Background="#2e7d32" Foreground="White" BorderBrush="#2e7d32"/>
                <Button Name="btnExportSnapshot" Command="{Binding Memory.ExportSnapshotCommand}" Content="Export V8 JSON" HorizontalAlignment="Stretch"/>
            </StackPanel>
            
            <Border Grid.Row="1" Classes="panel-card" ClipToBounds="True">
                <Grid RowDefinitions="Auto, *">
                    <TextBlock Text="HEAP SNAPSHOTS" Classes="panel-header" FontSize="11" Foreground="#9aa0a6" Margin="0,5,0,8"/>
                    <DataGrid Name="lstSnapshots" Grid.Row="1" ItemsSource="{Binding Memory.Snapshots}" SelectedItem="{Binding Memory.SelectedSnapshot, Mode=OneWay}" SelectionChanged="LstSnapshots_SelectionChanged" x:DataType="vm:MainWindowViewModel"
                              CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="True"
                              GridLinesVisibility="None" HeadersVisibility="None"
                              Background="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="models:MemorySnapshotModel">
                                        <TextBlock Text="{Binding Name}" Foreground="#e8eaed" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="models:MemorySnapshotModel">
                                        <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss'}" Foreground="#9aa0a6" FontSize="10" VerticalAlignment="Center" Margin="5,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Right panel (Snapshot details) -->
        <Grid Name="pnlSnapshotOverview" RowDefinitions="Auto, Auto, Auto, *">
            <!-- Details Header toolbar -->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto" Margin="0,0,0,10">
                <TextBlock Text="{Binding Memory.SelectedSnapshot.Name, FallbackValue='Select or Take a Snapshot'}" Classes="panel-header" FontSize="16" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" IsVisible="{Binding Memory.SelectedSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <CheckBox Name="btnCompareSnapshots" Content="Comparison mode" IsChecked="{Binding Memory.IsComparisonMode, Mode=TwoWay}" FontSize="12" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="5" IsVisible="{Binding Memory.IsComparisonMode}">
                        <TextBlock Text="Baseline:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                        <ComboBox ItemsSource="{Binding Memory.ComparisonBaselines}" SelectedItem="{Binding Memory.SelectedBaseline, Mode=TwoWay}" Height="28">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:MemorySnapshotModel">
                                    <TextBlock Text="{Binding Name}" FontSize="12"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Memory Allocation Rate Timeline -->
            <StackPanel Grid.Row="1" Spacing="5" Margin="0,0,0,10">
                <TextBlock Text="Memory Allocation Rate Timeline (MB)" Classes="panel-header" FontSize="12"/>
                <Border Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" ClipToBounds="True">
                    <controls:TimelineChart StrokeColor="#ff5252" FillColor="#ff5252" Unit="MB" Height="65" History="{Binding Memory.AllocationHistory}"/>
                </Border>
            </StackPanel>
 
            <!-- Memory Generations Distribution Chart -->
            <StackPanel Grid.Row="2" Spacing="5" Margin="0,0,0,15" IsVisible="{Binding Memory.SelectedSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="Memory Generations Distribution" Classes="panel-header" FontSize="12"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Border Width="8" Height="8" CornerRadius="4" Background="#4caf50" VerticalAlignment="Center"/>
                            <TextBlock Text="Gen 0" FontSize="10" Foreground="#9aa0a6" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Border Width="8" Height="8" CornerRadius="4" Background="#2196f3" VerticalAlignment="Center"/>
                            <TextBlock Text="Gen 1" FontSize="10" Foreground="#9aa0a6" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Border Width="8" Height="8" CornerRadius="4" Background="#ffeb3b" VerticalAlignment="Center"/>
                            <TextBlock Text="Gen 2" FontSize="10" Foreground="#9aa0a6" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Border Width="8" Height="8" CornerRadius="4" Background="#ff9800" VerticalAlignment="Center"/>
                            <TextBlock Text="LOH" FontSize="10" Foreground="#9aa0a6" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
                <Border Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="5" Padding="8,10">
                    <controls:GenerationsBarChart Height="24"
                                                   Gen0Size="{Binding Memory.Gen0Size}"
                                                   Gen1Size="{Binding Memory.Gen1Size}"
                                                   Gen2Size="{Binding Memory.Gen2Size}"
                                                   LohSize="{Binding Memory.LohSize}"/>
                </Border>
            </StackPanel>

            <!-- Table content -->
            <Border Grid.Row="3" Classes="panel-card" ClipToBounds="True">
                <Grid>
                    <Grid IsVisible="{Binding Memory.SelectedSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <!-- Summary mode list -->
                                <Grid IsVisible="{Binding !Memory.IsComparisonMode}">
                                    <DataGrid ItemsSource="{Binding Memory.CurrentEntries}" x:DataType="vm:MainWindowViewModel"
                                              CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="True"
                                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                              Background="Transparent" BorderThickness="0">
                                        <DataGrid.ColumnHeaderContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Columns" ItemsSource="{Binding $parent[DataGrid].Columns}">
                                                    <MenuItem.ItemContainerTheme>
                                                        <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}" x:DataType="DataGridColumn">
                                                            <Setter Property="Header" Value="{Binding Header}" />
                                                            <Setter Property="IsChecked" Value="{Binding IsVisible, Mode=TwoWay}" />
                                                            <Setter Property="ToggleType" Value="CheckBox" />
                                                        </ControlTheme>
                                                    </MenuItem.ItemContainerTheme>
                                                </MenuItem>
                                            </ContextMenu>
                                        </DataGrid.ColumnHeaderContextMenu>
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="Control Type / Constructor" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate x:DataType="models:ControlCountModel">
                                                        <TextBlock Text="{Binding Type}" Foreground="#e8eaed" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Live Instances Count" Width="150">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate x:DataType="models:ControlCountModel">
                                                        <TextBlock Text="{Binding Count}" Foreground="#8ab4f8" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>

                                <!-- Comparison mode list -->
                                <Grid IsVisible="{Binding Memory.IsComparisonMode}">
                                    <DataGrid ItemsSource="{Binding Memory.ComparisonEntries}" x:DataType="vm:MainWindowViewModel"
                                              CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="True"
                                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                              Background="Transparent" BorderThickness="0">
                                        <DataGrid.ColumnHeaderContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Columns" ItemsSource="{Binding $parent[DataGrid].Columns}">
                                                    <MenuItem.ItemContainerTheme>
                                                        <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}" x:DataType="DataGridColumn">
                                                            <Setter Property="Header" Value="{Binding Header}" />
                                                            <Setter Property="IsChecked" Value="{Binding IsVisible, Mode=TwoWay}" />
                                                            <Setter Property="ToggleType" Value="CheckBox" />
                                                        </ControlTheme>
                                                    </MenuItem.ItemContainerTheme>
                                                </MenuItem>
                                            </ContextMenu>
                                        </DataGrid.ColumnHeaderContextMenu>
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="Control Type / Constructor" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate x:DataType="models:MemoryComparisonModel">
                                                        <TextBlock Text="{Binding Type}" Foreground="#e8eaed" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Baseline" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate x:DataType="models:MemoryComparisonModel">
                                                        <TextBlock Text="{Binding BaselineCount}" Foreground="#9aa0a6" FontSize="12" VerticalAlignment="Center" Margin="5,0"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Current" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate x:DataType="models:MemoryComparisonModel">
                                                        <TextBlock Text="{Binding SnapshotCount}" Foreground="#e8eaed" FontSize="12" VerticalAlignment="Center" Margin="5,0"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Delta" Width="100" SortMemberPath="Delta">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate x:DataType="models:MemoryComparisonModel">
                                                        <Border Background="{Binding DeltaBg}" CornerRadius="3" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding DeltaText}" Foreground="{Binding DeltaFg}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Grid>
                    
                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" IsVisible="{Binding Memory.SelectedSnapshot, Converter={x:Static ObjectConverters.IsNull}}">
                        <TextBlock Text="No snapshot selected" Foreground="#9aa0a6" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="Click 'Take Heap Snapshot' on the left to capture control instances footprint." Foreground="#5f6368" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Detached Controls Panel -->
        <Grid Name="pnlDetachedControls" RowDefinitions="*, 4, *">
            <DataGrid Name="dgDetachedControls" Grid.Row="0" ItemsSource="{Binding Memory.DetachedControls}"
                                          SelectedItem="{Binding Memory.SelectedDetachedControl, Mode=OneWay}"
                                          SelectionChanged="DgDetachedControls_SelectionChanged"
                                          x:DataType="vm:MainWindowViewModel"
                                          CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="True"
                                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                          Background="Transparent" BorderThickness="0">
                                    <DataGrid.ColumnHeaderContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Columns" ItemsSource="{Binding $parent[DataGrid].Columns}">
                                                <MenuItem.ItemContainerTheme>
                                                    <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}" x:DataType="DataGridColumn">
                                                        <Setter Property="Header" Value="{Binding Header}" />
                                                        <Setter Property="IsChecked" Value="{Binding IsVisible, Mode=TwoWay}" />
                                                        <Setter Property="ToggleType" Value="CheckBox" />
                                                    </ControlTheme>
                                                </MenuItem.ItemContainerTheme>
                                            </MenuItem>
                                        </ContextMenu>
                                    </DataGrid.ColumnHeaderContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Control Type" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate x:DataType="models:DetachedControlModel">
                                                    <TextBlock Text="{Binding Type}" Foreground="#e8eaed" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Name" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate x:DataType="models:DetachedControlModel">
                                                    <TextBlock Text="{Binding Name}" Foreground="#9aa0a6" FontSize="12" VerticalAlignment="Center" Margin="5,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Detached Duration" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate x:DataType="models:DetachedControlModel">
                                                    <TextBlock Text="{Binding DetachedDurationMs, StringFormat='{}{0} ms'}" Foreground="#f28b82" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="DataContext VM" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate x:DataType="models:DetachedControlModel">
                                                    <TextBlock Text="{Binding DataContextType}" Foreground="#8ab4f8" FontSize="12" VerticalAlignment="Center" Margin="5,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <GridSplitter Grid.Row="1" Background="#3c4043"/>

                                <Grid Grid.Row="2" RowDefinitions="Auto, *">
                                    <Border Grid.Row="0" Background="#202124" BorderBrush="#3c4043" BorderThickness="0,0,0,1" Padding="8,4">
                                        <TextBlock Text="RETAINERS PATH (RETAINED BY)" Foreground="#9aa0a6" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                    <DataGrid Name="treeRetainers" Grid.Row="1"
                                              HierarchicalModel="{Binding Memory.HierarchicalRetainers}"
                                              x:DataType="vm:MainWindowViewModel"
                                              HierarchicalRowsEnabled="True"
                                              HeadersVisibility="None"
                                              GridLinesVisibility="None"
                                              Background="Transparent"
                                              BorderThickness="0">
                                        <DataGrid.Columns>
                                            <DataGridHierarchicalColumn Width="*">
                                                <DataGridHierarchicalColumn.CellTemplate>
                                                    <DataTemplate x:DataType="tree:HierarchicalNode">
                                                        <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,2">
                                                            <TextBlock Text="{Binding ((models:RetainerNodeModel)Item).Name}" Foreground="#e8eaed" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                            <TextBlock Text=":" Foreground="#9aa0a6" FontSize="12" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding ((models:RetainerNodeModel)Item).Type}" Foreground="#8ab4f8" FontSize="12" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding ((models:RetainerNodeModel)Item).HashCode, StringFormat='[0x{0:X8}]'}" Foreground="#9aa0a6" FontSize="10" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridHierarchicalColumn.CellTemplate>
                                            </DataGridHierarchicalColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Grid>
        <!-- Dominator Tree Panel -->
        <Grid Name="pnlDominatorTree" RowDefinitions="*">
            <Border Classes="panel-card" ClipToBounds="True">
                <Grid RowDefinitions="Auto, *">
                    <Border Grid.Row="0" Background="#202124" BorderBrush="#3c4043" BorderThickness="0,0,0,1" Padding="8,4">
                        <TextBlock Text="DOMINATOR TREE (RETAINED SIZES &amp; INSTANCES)" Foreground="#9aa0a6" FontSize="11" FontWeight="Bold"/>
                    </Border>
                    <DataGrid Name="treeDominators" Grid.Row="1"
                              HierarchicalModel="{Binding Memory.HierarchicalDominators}"
                              x:DataType="vm:MainWindowViewModel"
                              HierarchicalRowsEnabled="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="Transparent"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridHierarchicalColumn Header="Control Type / Category" Width="*">
                                <DataGridHierarchicalColumn.CellTemplate>
                                    <DataTemplate x:DataType="tree:HierarchicalNode">
                                        <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,2">
                                            <TextBlock Text="{Binding ((models:DominatorNodeModel)Item).TypeName}" Foreground="#e8eaed" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridHierarchicalColumn.CellTemplate>
                            </DataGridHierarchicalColumn>
                            <DataGridTemplateColumn Header="Retained Size" Width="120" SortMemberPath="Item.RetainedSize">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="tree:HierarchicalNode">
                                        <TextBlock Text="{Binding ((models:DominatorNodeModel)Item).RetainedSize, StringFormat='{}{0} B'}"
                                                   Foreground="#8ab4f8" FontSize="12" FontWeight="Bold" Margin="10,0" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Retained %" Width="100" SortMemberPath="Item.RetainedPct">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="tree:HierarchicalNode">
                                        <TextBlock Text="{Binding ((models:DominatorNodeModel)Item).RetainedPct, StringFormat='{}{0:F2} %'}"
                                                   Foreground="#34a853" FontSize="12" Margin="10,0" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Count" Width="100" SortMemberPath="Item.InstanceCount">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="tree:HierarchicalNode">
                                        <TextBlock Text="{Binding ((models:DominatorNodeModel)Item).InstanceCount}"
                                                   Foreground="#f28b82" FontSize="12" Margin="10,0" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Inspections Panel -->
        <Grid Name="pnlInspections" RowDefinitions="*">
            <Grid IsVisible="{Binding Memory.SelectedSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}" RowDefinitions="*">
                <DataGrid ItemsSource="{Binding Memory.Inspections}"
                          x:DataType="vm:MainWindowViewModel"
                          CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Severity" Width="100" SortMemberPath="Severity">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:MemoryInspectionModel">
                                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="5,0,0,0" VerticalAlignment="Center">
                                        <PathIcon Data="{StaticResource WarningIcon}" Width="12" Height="12" Foreground="{Binding SeverityColor}"/>
                                        <TextBlock Text="{Binding Severity}" Foreground="{Binding SeverityColor}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Issue" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:MemoryInspectionModel">
                                    <TextBlock Text="{Binding Title}" Foreground="#e8eaed" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Description" Width="280">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:MemoryInspectionModel">
                                    <TextBlock Text="{Binding Description}" Foreground="#e8eaed" FontSize="12" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Count" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:MemoryInspectionModel">
                                    <TextBlock Text="{Binding Count}" Foreground="#8ab4f8" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Details / Recommendations" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="vm:MemoryInspectionModel">
                                    <TextBlock Text="{Binding Details}" Foreground="#9aa0a6" FontSize="11" VerticalAlignment="Center" Margin="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Empty state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" IsVisible="{Binding Memory.SelectedSnapshot, Converter={x:Static ObjectConverters.IsNull}}">
                <TextBlock Text="No snapshot selected" Foreground="#9aa0a6" FontSize="13" HorizontalAlignment="Center"/>
                <TextBlock Text="Take or select a snapshot to view automatic memory audit inspections." Foreground="#5f6368" FontSize="11" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
        </Grid>
    </Grid>
</UserControl>
