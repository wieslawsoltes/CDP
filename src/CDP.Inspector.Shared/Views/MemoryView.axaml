<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CdpInspectorApp.ViewModels"
             xmlns:models="clr-namespace:CdpInspectorApp.Models;assembly=CDP.Inspector.Shared"
             xmlns:controls="clr-namespace:CdpInspectorApp.Controls"
             x:Class="CdpInspectorApp.Views.MemoryView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="True">
    <Grid ColumnDefinitions="240, 4, *" Margin="10">
        <!-- Left panel (Snapshots list & controls) -->
        <Grid RowDefinitions="Auto, *" Margin="0,0,10,0">
            <StackPanel Spacing="8" Margin="0,0,0,10">
                <Button Name="btnTakeSnapshot" Command="{Binding Memory.TakeSnapshotCommand}" Content="Take Heap Snapshot" Classes="accent" HorizontalAlignment="Stretch"/>
                <Button Name="btnGcCollect" Command="{Binding Memory.CollectGarbageCommand}" Content="Collect Garbage" HorizontalAlignment="Stretch" Background="#2e7d32" Foreground="White" BorderBrush="#2e7d32"/>
                <Button Name="btnExportSnapshot" Command="{Binding Memory.ExportSnapshotCommand}" Content="Export V8 JSON" HorizontalAlignment="Stretch"/>
            </StackPanel>
            
            <Border Grid.Row="1" Classes="panel-card" ClipToBounds="True">
                <Grid RowDefinitions="Auto, *">
                    <TextBlock Text="HEAP SNAPSHOTS" Classes="panel-header" FontSize="11" Foreground="#9aa0a6" Margin="0,5,0,8"/>
                    <DataGrid Name="lstSnapshots" Grid.Row="1" ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Memory.Snapshots}" SelectedItem="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Memory.SelectedSnapshot, Mode=TwoWay}" x:DataType="models:MemorySnapshotModel"
                              CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="True"
                              GridLinesVisibility="None" HeadersVisibility="None"
                              Background="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Snapshot" Binding="{Binding Name}" Width="*" Foreground="#e8eaed" FontSize="12" FontWeight="Bold"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat='HH:mm:ss'}" Width="80" Foreground="#9aa0a6" FontSize="10"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
 
        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Background="#3c4043"/>
 
        <!-- Right panel (Snapshot details) -->
        <Grid Grid.Column="2" RowDefinitions="Auto, Auto, *" Margin="10,0,0,0">
            <!-- Details Header toolbar -->
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto" Margin="0,0,0,10">
                <TextBlock Text="{Binding Memory.SelectedSnapshot.Name, FallbackValue='Select or Take a Snapshot'}" Classes="panel-header" FontSize="16" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" IsVisible="{Binding Memory.SelectedSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <CheckBox Content="Comparison mode" IsChecked="{Binding Memory.IsComparisonMode, Mode=TwoWay}" FontSize="12" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="5" IsVisible="{Binding Memory.IsComparisonMode}">
                        <TextBlock Text="Baseline:" VerticalAlignment="Center" Foreground="#9aa0a6" FontSize="11"/>
                        <ComboBox ItemsSource="{Binding Memory.ComparisonBaselines}" SelectedItem="{Binding Memory.SelectedBaseline, Mode=TwoWay}" Height="28">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:MemorySnapshotModel">
                                    <TextBlock Text="{Binding Name}" FontSize="12"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Memory Allocation Rate Timeline -->
            <StackPanel Grid.Row="1" Spacing="5" Margin="0,0,0,10">
                <TextBlock Text="Memory Allocation Rate Timeline (MB)" Classes="panel-header" FontSize="12"/>
                <Border Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" ClipToBounds="True">
                    <controls:ChromeTimelineChart StrokeColor="#ff5252" FillColor="#ff5252" Unit="MB" Height="65" History="{Binding Memory.AllocationHistory}"/>
                </Border>
            </StackPanel>
 
            <!-- Table content -->
            <Border Grid.Row="2" Classes="panel-card" ClipToBounds="True">
                <Grid>
                    <TabControl IsVisible="{Binding Memory.SelectedSnapshot, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <!-- Live Counts Tab -->
                        <TabItem Header="Live Counts">
                            <Grid>
                                <!-- Summary mode list -->
                                <Grid IsVisible="{Binding !Memory.IsComparisonMode}">
                                    <DataGrid ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Memory.CurrentEntries}" x:DataType="models:ControlCountModel"
                                              CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="True"
                                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                              Background="Transparent" BorderThickness="0">
                                        <DataGrid.ColumnHeaderContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Columns" ItemsSource="{Binding $parent[DataGrid].Columns}">
                                                    <MenuItem.ItemContainerTheme>
                                                        <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}" x:DataType="DataGridColumn">
                                                            <Setter Property="Header" Value="{Binding Header}" />
                                                            <Setter Property="IsChecked" Value="{Binding IsVisible, Mode=TwoWay}" />
                                                            <Setter Property="ToggleType" Value="CheckBox" />
                                                        </ControlTheme>
                                                    </MenuItem.ItemContainerTheme>
                                                </MenuItem>
                                            </ContextMenu>
                                        </DataGrid.ColumnHeaderContextMenu>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Control Type / Constructor" Binding="{Binding Type}" Width="*" Foreground="#e8eaed" FontSize="12" FontWeight="SemiBold"/>
                                            <DataGridTextColumn Header="Live Instances Count" Binding="{Binding Count}" Width="150" Foreground="#8ab4f8" FontSize="12" FontWeight="Bold"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>

                                <!-- Comparison mode list -->
                                <Grid IsVisible="{Binding Memory.IsComparisonMode}">
                                    <DataGrid ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Memory.ComparisonEntries}" x:DataType="models:MemoryComparisonModel"
                                              CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="True"
                                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                              Background="Transparent" BorderThickness="0">
                                        <DataGrid.ColumnHeaderContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Columns" ItemsSource="{Binding $parent[DataGrid].Columns}">
                                                    <MenuItem.ItemContainerTheme>
                                                        <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}" x:DataType="DataGridColumn">
                                                            <Setter Property="Header" Value="{Binding Header}" />
                                                            <Setter Property="IsChecked" Value="{Binding IsVisible, Mode=TwoWay}" />
                                                            <Setter Property="ToggleType" Value="CheckBox" />
                                                        </ControlTheme>
                                                    </MenuItem.ItemContainerTheme>
                                                </MenuItem>
                                            </ContextMenu>
                                        </DataGrid.ColumnHeaderContextMenu>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Control Type / Constructor" Binding="{Binding Type}" Width="*" Foreground="#e8eaed" FontSize="12" FontWeight="SemiBold"/>
                                            <DataGridTextColumn Header="Baseline" Binding="{Binding BaselineCount}" Width="100" Foreground="#9aa0a6" FontSize="12"/>
                                            <DataGridTextColumn Header="Current" Binding="{Binding SnapshotCount}" Width="100" Foreground="#e8eaed" FontSize="12"/>
                                            <DataGridTextColumn Header="Delta" Binding="{Binding DeltaText}" Width="100" Foreground="#f28b82" FontSize="12" FontWeight="Bold"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <!-- Detached Controls Tab -->
                        <TabItem Header="Detached Controls (Leaked)">
                            <Grid RowDefinitions="*, 4, *">
                                <DataGrid Grid.Row="0" ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Memory.DetachedControls}"
                                          SelectedItem="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Memory.SelectedDetachedControl, Mode=TwoWay}"
                                          x:DataType="models:DetachedControlModel"
                                          CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="True"
                                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                          Background="Transparent" BorderThickness="0">
                                    <DataGrid.ColumnHeaderContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Columns" ItemsSource="{Binding $parent[DataGrid].Columns}">
                                                <MenuItem.ItemContainerTheme>
                                                    <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}" x:DataType="DataGridColumn">
                                                        <Setter Property="Header" Value="{Binding Header}" />
                                                        <Setter Property="IsChecked" Value="{Binding IsVisible, Mode=TwoWay}" />
                                                        <Setter Property="ToggleType" Value="CheckBox" />
                                                    </ControlTheme>
                                                </MenuItem.ItemContainerTheme>
                                            </MenuItem>
                                        </ContextMenu>
                                    </DataGrid.ColumnHeaderContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Control Type" Binding="{Binding Type}" Width="*" Foreground="#e8eaed" FontSize="12" FontWeight="SemiBold"/>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" Foreground="#9aa0a6" FontSize="12"/>
                                        <DataGridTextColumn Header="Detached Duration" Binding="{Binding DetachedDurationMs, StringFormat='{}{0} ms'}" Width="150" Foreground="#f28b82" FontSize="12" FontWeight="Bold"/>
                                        <DataGridTextColumn Header="DataContext VM" Binding="{Binding DataContextType}" Width="150" Foreground="#8ab4f8" FontSize="12"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <GridSplitter Grid.Row="1" Background="#3c4043"/>

                                <Grid Grid.Row="2" RowDefinitions="Auto, *">
                                    <Border Grid.Row="0" Background="#202124" BorderBrush="#3c4043" BorderThickness="0,0,0,1" Padding="8,4">
                                        <TextBlock Text="RETAINERS PATH (RETAINED BY)" Foreground="#9aa0a6" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                    <TreeView Grid.Row="1" ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Memory.RetainerRoots}"
                                              x:DataType="models:RetainerNodeModel">
                                        <TreeView.ItemTemplate>
                                            <TreeDataTemplate DataType="models:RetainerNodeModel" x:DataType="models:RetainerNodeModel" ItemsSource="{Binding Retainers}">
                                                <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,2">
                                                    <TextBlock Text="{Binding Name}" Foreground="#e8eaed" FontSize="12" FontWeight="SemiBold"/>
                                                    <TextBlock Text=":" Foreground="#9aa0a6" FontSize="12"/>
                                                    <TextBlock Text="{Binding Type}" Foreground="#8ab4f8" FontSize="12"/>
                                                    <TextBlock Text="{Binding HashCode, StringFormat='[0x{0:X8}]'}" Foreground="#9aa0a6" FontSize="10" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </TreeDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>
                                </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                    
                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" IsVisible="{Binding Memory.SelectedSnapshot, Converter={x:Static ObjectConverters.IsNull}}">
                        <TextBlock Text="No snapshot selected" Foreground="#9aa0a6" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="Click 'Take Heap Snapshot' on the left to capture control instances footprint." Foreground="#5f6368" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
