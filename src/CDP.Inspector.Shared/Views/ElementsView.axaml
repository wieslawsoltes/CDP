<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CdpInspectorApp.ViewModels"
             xmlns:models="clr-namespace:CdpInspectorApp.Models"
             xmlns:tree="clr-namespace:Avalonia.Controls.DataGridHierarchical;assembly=Avalonia.Controls.DataGrid"
             x:Class="CdpInspectorApp.Views.ElementsView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="True">
    <Grid ColumnDefinitions="*, 4, 1.2*">
        <!-- Left Side (DOM / Accessibility Trees) -->
        <TabControl Margin="10" Padding="0,5,0,0" SelectedIndex="{Binding Elements.SelectedTreeTabIndex, Mode=TwoWay}">
            <!-- DOM Tree Tab -->
            <TabItem Header="DOM Tree">
                <Grid RowDefinitions="Auto, *, Auto" Margin="0,5,0,0">
                    <!-- Search -->
                    <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,8">
                        <TextBox Name="txtSearch" Text="{Binding Elements.SearchQuery, Mode=TwoWay}" PlaceholderText="Search by tag, ID, class, or text content..." Height="28" VerticalContentAlignment="Center"/>
                        <Button Name="btnSearch" Command="{Binding Elements.SearchCommand}" Grid.Column="1" Content="Search" Margin="5,0,0,0" Padding="10,0" Height="28"/>
                    </Grid>

                    <!-- treeDom -->
                    <Border Grid.Row="1" Classes="panel-card" ClipToBounds="True">
                        <DataGrid Name="treeDom"
                                     HierarchicalModel="{Binding Elements.HierarchicalRootNodes}"
                                     SelectedItem="{Binding Elements.SelectedNodeNode, Mode=TwoWay}"
                                     HierarchicalRowsEnabled="True"
                                     GridLinesVisibility="None"
                                     HeadersVisibility="None"
                                     Background="Transparent" BorderThickness="0"
                                     CanUserResizeColumns="True"
                                     CanUserSortColumns="False">
                            <DataGrid.Columns>
                                <DataGridHierarchicalColumn Width="*">
                                    <DataGridHierarchicalColumn.CellTemplate>
                                        <DataTemplate x:DataType="tree:HierarchicalNode">
                                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,0">
                                                <TextBlock Text="{Binding ((models:DomNodeModel)Item).DisplayName}" Foreground="{Binding ((models:DomNodeModel)Item).ForegroundBrush}" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridHierarchicalColumn.CellTemplate>
                                </DataGridHierarchicalColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Actions Footer -->
                    <Grid Grid.Row="2" ColumnDefinitions="Auto, *, Auto" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <TextBlock Text="Inspected:" Foreground="#9aa0a6" FontSize="11"/>
                            <TextBlock Name="txtSelectedNodeId" Text="{Binding Elements.SelectedNodeIdText}" FontWeight="Bold" Foreground="#8ab4f8" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                            <Button Name="btnFocus" Command="{Binding Elements.FocusSelectedNodeCommand}" Content="Scroll Into View" Height="28" Padding="10,0"/>
                            <CheckBox Name="chkVisualTree" IsChecked="{Binding Elements.ShowVisualTree, Mode=TwoWay}" IsEnabled="{Binding Connection.IsConnected}" Content="Visual Tree Mode" FontSize="11" Margin="5,0" VerticalAlignment="Center"/>
                            <CheckBox Name="chkHighlight" IsChecked="{Binding Elements.IsHighlightActive, Mode=TwoWay}" IsEnabled="{Binding Connection.IsConnected}" Content="Inspect Highlight" FontSize="11" Margin="5,0" VerticalAlignment="Center"/>
                            <Button Name="btnDeleteControl" Command="{Binding Elements.DeleteSelectedNodeCommand}" Content="Delete Element" Height="28" Padding="10,0" Background="#b71c1c" Foreground="White" BorderBrush="#b71c1c"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Accessibility Tree Tab -->
            <TabItem Header="Accessibility Tree">
                <Grid RowDefinitions="Auto, *, Auto" Margin="0,5,0,0">
                    <!-- Search -->
                    <Grid ColumnDefinitions="*, Auto, Auto" Margin="0,0,0,8">
                        <TextBox Name="txtAxSearch" Text="{Binding Elements.AxSearchQuery, Mode=TwoWay}" PlaceholderText="Search by role or accessible name..." Height="28" VerticalContentAlignment="Center"/>
                        <Button Name="btnAxSearch" Command="{Binding Elements.AxSearchCommand}" Grid.Column="1" Content="Search" Margin="5,0,0,0" Padding="10,0" Height="28"/>
                        <Button Name="btnRefreshAxTree" Command="{Binding Elements.RefreshAxTreeCommand}" Grid.Column="2" Content="Refresh" Margin="5,0,0,0" Padding="10,0" Height="28"/>
                    </Grid>

                    <Border Grid.Row="1" Classes="panel-card" ClipToBounds="True">
                        <DataGrid Name="treeAx"
                                     HierarchicalModel="{Binding Elements.HierarchicalAxRootNodes}"
                                     SelectedItem="{Binding Elements.SelectedAxNodeNode, Mode=TwoWay}"
                                     HierarchicalRowsEnabled="True"
                                     GridLinesVisibility="None"
                                     HeadersVisibility="None"
                                     Background="Transparent" BorderThickness="0"
                                     CanUserResizeColumns="True"
                                     CanUserSortColumns="False">
                            <DataGrid.Columns>
                                <DataGridHierarchicalColumn Width="*">
                                    <DataGridHierarchicalColumn.CellTemplate>
                                        <DataTemplate x:DataType="tree:HierarchicalNode">
                                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,0">
                                                <TextBlock Text="{Binding ((models:AxNodeModel)Item).DisplayName}" Foreground="{Binding ((models:AxNodeModel)Item).ForegroundBrush}" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridHierarchicalColumn.CellTemplate>
                                </DataGridHierarchicalColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                    
                    <!-- Footer -->
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <TextBlock Text="Selecting an AX node automatically highlights and selects its DOM element." Foreground="#9aa0a6" FontSize="11" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Background="#3c4043"/>

        <!-- Styles & Attributes sidebar (Right Side) -->
        <Grid Grid.Column="2" Margin="10">
            <TabControl Padding="0,5,0,0">
                <!-- Styles subtab -->
                <TabItem Header="Styles">
                    <Grid RowDefinitions="*, Auto" Margin="0,5,0,0">
                        <TabControl Grid.Row="0" Padding="0,5,0,0">
                            <TabItem Header="Inline styles">
                            <Grid RowDefinitions="Auto, Auto, Auto, *, Auto" Margin="0,5,0,0">
                                <Grid ColumnDefinitions="*, Auto, Auto" Margin="0,0,0,5">
                                    <TextBox Name="txtCssSearch" Text="{Binding Elements.CssSearchText, Mode=TwoWay}" PlaceholderText="Filter styles" Height="26" VerticalContentAlignment="Center"/>
                                    <ToggleButton Name="btnHovToggle" Grid.Column="1" IsChecked="{Binding Elements.IsPseudoStatePanelOpen, Mode=TwoWay}" Content=":hov" Margin="5,0,0,0" Padding="8,0" Height="26" FontSize="11" VerticalContentAlignment="Center"/>
                                    <ToggleButton Name="btnClsToggle" Grid.Column="2" IsChecked="{Binding Elements.IsClassPanelOpen, Mode=TwoWay}" Content=".cls" Margin="5,0,0,0" Padding="8,0" Height="26" FontSize="11" VerticalContentAlignment="Center"/>
                                </Grid>
                                
                                <Border Grid.Row="1" Background="#2d2e30" BorderBrush="#3c4043" BorderThickness="0,0,0,1" IsVisible="{Binding Elements.IsPseudoStatePanelOpen}" Padding="10,8" Margin="0,0,0,5">
                                    <Grid ColumnDefinitions="*, *, *" RowDefinitions="Auto, Auto">
                                        <CheckBox Name="chkForcedHover" Content=":hover" IsChecked="{Binding Elements.IsForcedHover, Mode=TwoWay}" FontSize="11" Margin="0,2"/>
                                        <CheckBox Name="chkForcedActive" Grid.Column="1" Content=":active" IsChecked="{Binding Elements.IsForcedActive, Mode=TwoWay}" FontSize="11" Margin="0,2"/>
                                        <CheckBox Name="chkForcedFocus" Grid.Column="2" Content=":focus" IsChecked="{Binding Elements.IsForcedFocus, Mode=TwoWay}" FontSize="11" Margin="0,2"/>
                                        <CheckBox Name="chkForcedFocusWithin" Grid.Row="1" Content=":focus-within" IsChecked="{Binding Elements.IsForcedFocusWithin, Mode=TwoWay}" FontSize="11" Margin="0,2"/>
                                        <CheckBox Name="chkForcedFocusVisible" Grid.Row="1" Grid.Column="1" Content=":focus-visible" IsChecked="{Binding Elements.IsForcedFocusVisible, Mode=TwoWay}" FontSize="11" Margin="0,2"/>
                                        <CheckBox Name="chkForcedDisabled" Grid.Row="1" Grid.Column="2" Content=":disabled" IsChecked="{Binding Elements.IsForcedDisabled, Mode=TwoWay}" FontSize="11" Margin="0,2"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Background="#2d2e30" BorderBrush="#3c4043" BorderThickness="0,0,0,1" IsVisible="{Binding Elements.IsClassPanelOpen}" Padding="10,8" Margin="0,0,0,5">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,4">
                                            <TextBox Name="txtAddClass" Text="{Binding Elements.NewClassNameText, Mode=TwoWay}" PlaceholderText="Add new class..." Height="26" VerticalContentAlignment="Center" KeyDown="OnAddClassTextBoxKeyDown"/>
                                            <Button Name="btnAddClass" Command="{Binding Elements.AddClassCommand}" Grid.Column="1" Content="Add" Margin="5,0,0,0" Padding="10,0" Height="26" FontSize="11" VerticalContentAlignment="Center"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding Elements.Classes}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:ClassItemModel">
                                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsEnabled, Mode=TwoWay}" Margin="0,2,12,2" FontSize="11"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                 <DataGrid Grid.Row="3" Name="listCssProperties" ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Elements.FilteredCssProperties}"
                                           x:DataType="models:CssPropertyModel"
                                           CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="False"
                                           GridLinesVisibility="None" HeadersVisibility="None"
                                           Background="Transparent" BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="*" Foreground="#f28b82" FontSize="12" FontWeight="SemiBold"/>
                                        <DataGridTextColumn Header="Value" Binding="{Binding Value, Mode=TwoWay}" IsReadOnly="False" Width="2*" Foreground="#e8eaed" FontSize="12"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Grid Grid.Row="4" ColumnDefinitions="*, Auto" Margin="0,8,0,0">
                                    <TextBox Name="txtStyleText" Text="{Binding Elements.StyleTextInputText, Mode=TwoWay}" PlaceholderText="Add style rule (e.g. background: red)..." Height="28" VerticalContentAlignment="Center"/>
                                    <Button Name="btnApplyStyleText" Command="{Binding Elements.ApplyStyleTextCommand}" Grid.Column="1" Content="Apply" Margin="5,0,0,0" Padding="10,0" Height="28"/>
                                </Grid>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Computed rules">
                            <Grid RowDefinitions="Auto, *" Margin="0,5,0,0">
                                <TextBox Name="txtComputedSearch" Text="{Binding Elements.ComputedSearchText, Mode=TwoWay}" PlaceholderText="Filter computed styles" Height="26" Margin="0,0,0,5" VerticalContentAlignment="Center"/>
                                 <DataGrid Grid.Row="1" Name="listComputedStyles" ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Elements.FilteredComputedStyles}"
                                           x:DataType="models:CssPropertyModel"
                                           CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="True"
                                           GridLinesVisibility="None" HeadersVisibility="None"
                                           Background="Transparent" BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="*" Foreground="#81c995" FontSize="12" FontWeight="SemiBold"/>
                                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" IsReadOnly="True" Width="2*" Foreground="#e8eaed" FontSize="12"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                    
                    <!-- Concentric Box Model Editor -->
                    <Border Grid.Row="1" BorderBrush="#3c4043" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,10,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Computed Box Model" FontWeight="SemiBold" Foreground="#9aa0a6" FontSize="12"/>
                            
                            <Border Background="#3a2a1c" BorderBrush="#d58512" BorderThickness="1" CornerRadius="4" Padding="4">
                                <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, *, Auto">
                                    <!-- Margin label -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="margin" Foreground="#d58512" FontSize="9" Margin="4,2"/>
                                    
                                    <!-- Margin Top -->
                                    <Grid Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Elements.BoxMarginTop}" IsVisible="{Binding !Elements.IsEditingMarginTop}" DoubleTapped="OnBoxValueDoubleTapped" Tag="MarginTop" Cursor="Hand" Foreground="#d58512" FontSize="10" FontWeight="Bold"/>
                                        <TextBox Name="txtMarginTop" Text="{Binding Elements.BoxMarginTop, Mode=TwoWay}" IsVisible="{Binding Elements.IsEditingMarginTop}" KeyDown="OnBoxTextBoxKeyDown" LostFocus="OnBoxTextBoxLostFocus" Tag="MarginTop" FontSize="10" Height="20" MinWidth="25" Padding="2,0" Margin="0" HorizontalContentAlignment="Center"/>
                                    </Grid>
                                    
                                    <!-- Margin Left -->
                                    <Grid Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0">
                                        <TextBlock Text="{Binding Elements.BoxMarginLeft}" IsVisible="{Binding !Elements.IsEditingMarginLeft}" DoubleTapped="OnBoxValueDoubleTapped" Tag="MarginLeft" Cursor="Hand" Foreground="#d58512" FontSize="10" FontWeight="Bold"/>
                                        <TextBox Name="txtMarginLeft" Text="{Binding Elements.BoxMarginLeft, Mode=TwoWay}" IsVisible="{Binding Elements.IsEditingMarginLeft}" KeyDown="OnBoxTextBoxKeyDown" LostFocus="OnBoxTextBoxLostFocus" Tag="MarginLeft" FontSize="10" Height="20" MinWidth="25" Padding="2,0" Margin="0" HorizontalContentAlignment="Center"/>
                                    </Grid>
                                    
                                    <!-- Margin Right -->
                                    <Grid Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0">
                                        <TextBlock Text="{Binding Elements.BoxMarginRight}" IsVisible="{Binding !Elements.IsEditingMarginRight}" DoubleTapped="OnBoxValueDoubleTapped" Tag="MarginRight" Cursor="Hand" Foreground="#d58512" FontSize="10" FontWeight="Bold"/>
                                        <TextBox Name="txtMarginRight" Text="{Binding Elements.BoxMarginRight, Mode=TwoWay}" IsVisible="{Binding Elements.IsEditingMarginRight}" KeyDown="OnBoxTextBoxKeyDown" LostFocus="OnBoxTextBoxLostFocus" Tag="MarginRight" FontSize="10" Height="20" MinWidth="25" Padding="2,0" Margin="0" HorizontalContentAlignment="Center"/>
                                    </Grid>
                                    
                                    <!-- Margin Bottom -->
                                    <Grid Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Elements.BoxMarginBottom}" IsVisible="{Binding !Elements.IsEditingMarginBottom}" DoubleTapped="OnBoxValueDoubleTapped" Tag="MarginBottom" Cursor="Hand" Foreground="#d58512" FontSize="10" FontWeight="Bold"/>
                                        <TextBox Name="txtMarginBottom" Text="{Binding Elements.BoxMarginBottom, Mode=TwoWay}" IsVisible="{Binding Elements.IsEditingMarginBottom}" KeyDown="OnBoxTextBoxKeyDown" LostFocus="OnBoxTextBoxLostFocus" Tag="MarginBottom" FontSize="10" Height="20" MinWidth="25" Padding="2,0" Margin="0" HorizontalContentAlignment="Center"/>
                                    </Grid>
                                    
                                    <!-- Border Layer (Center of Margin Grid) -->
                                    <Border Grid.Row="1" Grid.Column="1" Background="#2f2e1a" BorderBrush="#e3b505" BorderThickness="1" CornerRadius="4" Padding="4" Margin="6,4">
                                        <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, *, Auto">
                                            <!-- Border label -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="border" Foreground="#e3b505" FontSize="9" Margin="4,2"/>
                                            
                                            <!-- Border Top -->
                                            <Grid Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Elements.BoxBorderTop}" IsVisible="{Binding !Elements.IsEditingBorderTop}" DoubleTapped="OnBoxValueDoubleTapped" Tag="BorderTop" Cursor="Hand" Foreground="#e3b505" FontSize="10" FontWeight="Bold"/>
                                                <TextBox Name="txtBorderTop" Text="{Binding Elements.BoxBorderTop, Mode=TwoWay}" IsVisible="{Binding Elements.IsEditingBorderTop}" KeyDown="OnBoxTextBoxKeyDown" LostFocus="OnBoxTextBoxLostFocus" Tag="BorderTop" FontSize="10" Height="20" MinWidth="25" Padding="2,0" Margin="0" HorizontalContentAlignment="Center"/>
                                            </Grid>
                                            
                                            <!-- Border Left -->
                                            <Grid Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0">
                                                <TextBlock Text="{Binding Elements.BoxBorderLeft}" IsVisible="{Binding !Elements.IsEditingBorderLeft}" DoubleTapped="OnBoxValueDoubleTapped" Tag="BorderLeft" Cursor="Hand" Foreground="#e3b505" FontSize="10" FontWeight="Bold"/>
                                                <TextBox Name="txtBorderLeft" Text="{Binding Elements.BoxBorderLeft, Mode=TwoWay}" IsVisible="{Binding Elements.IsEditingBorderLeft}" KeyDown="OnBoxTextBoxKeyDown" LostFocus="OnBoxTextBoxLostFocus" Tag="BorderLeft" FontSize="10" Height="20" MinWidth="25" Padding="2,0" Margin="0" HorizontalContentAlignment="Center"/>
                                            </Grid>
                                            
                                            <!-- Border Right -->
                                            <Grid Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0">
                                                <TextBlock Text="{Binding Elements.BoxBorderRight}" IsVisible="{Binding !Elements.IsEditingBorderRight}" DoubleTapped="OnBoxValueDoubleTapped" Tag="BorderRight" Cursor="Hand" Foreground="#e3b505" FontSize="10" FontWeight="Bold"/>
                                                <TextBox Name="txtBorderRight" Text="{Binding Elements.BoxBorderRight, Mode=TwoWay}" IsVisible="{Binding Elements.IsEditingBorderRight}" KeyDown="OnBoxTextBoxKeyDown" LostFocus="OnBoxTextBoxLostFocus" Tag="BorderRight" FontSize="10" Height="20" MinWidth="25" Padding="2,0" Margin="0" HorizontalContentAlignment="Center"/>
                                            </Grid>
                                            
                                            <!-- Border Bottom -->
                                            <Grid Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Elements.BoxBorderBottom}" IsVisible="{Binding !Elements.IsEditingBorderBottom}" DoubleTapped="OnBoxValueDoubleTapped" Tag="BorderBottom" Cursor="Hand" Foreground="#e3b505" FontSize="10" FontWeight="Bold"/>
                                                <TextBox Name="txtBorderBottom" Text="{Binding Elements.BoxBorderBottom, Mode=TwoWay}" IsVisible="{Binding Elements.IsEditingBorderBottom}" KeyDown="OnBoxTextBoxKeyDown" LostFocus="OnBoxTextBoxLostFocus" Tag="BorderBottom" FontSize="10" Height="20" MinWidth="25" Padding="2,0" Margin="0" HorizontalContentAlignment="Center"/>
                                            </Grid>
                                            
                                            <!-- Padding Layer (Center of Border Grid) -->
                                            <Border Grid.Row="1" Grid.Column="1" Background="#1d2d1d" BorderBrush="#5d9e5d" BorderThickness="1" CornerRadius="4" Padding="4" Margin="6,4">
                                                <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, *, Auto">
                                                    <!-- Padding label -->
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="padding" Foreground="#5d9e5d" FontSize="9" Margin="4,2"/>
                                                    
                                                    <!-- Padding Top -->
                                                    <Grid Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Elements.BoxPaddingTop}" IsVisible="{Binding !Elements.IsEditingPaddingTop}" DoubleTapped="OnBoxValueDoubleTapped" Tag="PaddingTop" Cursor="Hand" Foreground="#5d9e5d" FontSize="10" FontWeight="Bold"/>
                                                        <TextBox Name="txtPaddingTop" Text="{Binding Elements.BoxPaddingTop, Mode=TwoWay}" IsVisible="{Binding Elements.IsEditingPaddingTop}" KeyDown="OnBoxTextBoxKeyDown" LostFocus="OnBoxTextBoxLostFocus" Tag="PaddingTop" FontSize="10" Height="20" MinWidth="25" Padding="2,0" Margin="0" HorizontalContentAlignment="Center"/>
                                                    </Grid>
                                                    
                                                    <!-- Padding Left -->
                                                    <Grid Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0">
                                                        <TextBlock Text="{Binding Elements.BoxPaddingLeft}" IsVisible="{Binding !Elements.IsEditingPaddingLeft}" DoubleTapped="OnBoxValueDoubleTapped" Tag="PaddingLeft" Cursor="Hand" Foreground="#5d9e5d" FontSize="10" FontWeight="Bold"/>
                                                        <TextBox Name="txtPaddingLeft" Text="{Binding Elements.BoxPaddingLeft, Mode=TwoWay}" IsVisible="{Binding Elements.IsEditingPaddingLeft}" KeyDown="OnBoxTextBoxKeyDown" LostFocus="OnBoxTextBoxLostFocus" Tag="PaddingLeft" FontSize="10" Height="20" MinWidth="25" Padding="2,0" Margin="0" HorizontalContentAlignment="Center"/>
                                                    </Grid>
                                                    
                                                    <!-- Padding Right -->
                                                    <Grid Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0">
                                                        <TextBlock Text="{Binding Elements.BoxPaddingRight}" IsVisible="{Binding !Elements.IsEditingPaddingRight}" DoubleTapped="OnBoxValueDoubleTapped" Tag="PaddingRight" Cursor="Hand" Foreground="#5d9e5d" FontSize="10" FontWeight="Bold"/>
                                                        <TextBox Name="txtPaddingRight" Text="{Binding Elements.BoxPaddingRight, Mode=TwoWay}" IsVisible="{Binding Elements.IsEditingPaddingRight}" KeyDown="OnBoxTextBoxKeyDown" LostFocus="OnBoxTextBoxLostFocus" Tag="PaddingRight" FontSize="10" Height="20" MinWidth="25" Padding="2,0" Margin="0" HorizontalContentAlignment="Center"/>
                                                    </Grid>
                                                    
                                                    <!-- Padding Bottom -->
                                                    <Grid Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Elements.BoxPaddingBottom}" IsVisible="{Binding !Elements.IsEditingPaddingBottom}" DoubleTapped="OnBoxValueDoubleTapped" Tag="PaddingBottom" Cursor="Hand" Foreground="#5d9e5d" FontSize="10" FontWeight="Bold"/>
                                                        <TextBox Name="txtPaddingBottom" Text="{Binding Elements.BoxPaddingBottom, Mode=TwoWay}" IsVisible="{Binding Elements.IsEditingPaddingBottom}" KeyDown="OnBoxTextBoxKeyDown" LostFocus="OnBoxTextBoxLostFocus" Tag="PaddingBottom" FontSize="10" Height="20" MinWidth="25" Padding="2,0" Margin="0" HorizontalContentAlignment="Center"/>
                                                    </Grid>
                                                    
                                                    <!-- Content Layer (Center of Padding Grid) -->
                                                    <Border Grid.Row="1" Grid.Column="1" Background="#1a2333" BorderBrush="#8ab4f8" BorderThickness="1" CornerRadius="4" Padding="6,4" Margin="6,4" MinWidth="90" MinHeight="30">
                                                        <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, *">
                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="content" Foreground="#8ab4f8" FontSize="9"/>
                                                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                                                <!-- Width -->
                                                                <Grid VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Elements.BoxWidth}" IsVisible="{Binding !Elements.IsEditingWidth}" DoubleTapped="OnBoxValueDoubleTapped" Tag="Width" Cursor="Hand" Foreground="#e8eaed" FontSize="10" FontWeight="Bold"/>
                                                                    <TextBox Name="txtWidth" Text="{Binding Elements.BoxWidth, Mode=TwoWay}" IsVisible="{Binding Elements.IsEditingWidth}" KeyDown="OnBoxTextBoxKeyDown" LostFocus="OnBoxTextBoxLostFocus" Tag="Width" FontSize="10" Height="20" MinWidth="25" Padding="2,0" Margin="0" HorizontalContentAlignment="Center"/>
                                                                </Grid>
                                                                <TextBlock Text=" × " Foreground="#9aa0a6" FontSize="10" VerticalAlignment="Center"/>
                                                                <!-- Height -->
                                                                <Grid VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Elements.BoxHeight}" IsVisible="{Binding !Elements.IsEditingHeight}" DoubleTapped="OnBoxValueDoubleTapped" Tag="Height" Cursor="Hand" Foreground="#e8eaed" FontSize="10" FontWeight="Bold"/>
                                                                    <TextBox Name="txtHeight" Text="{Binding Elements.BoxHeight, Mode=TwoWay}" IsVisible="{Binding Elements.IsEditingHeight}" KeyDown="OnBoxTextBoxKeyDown" LostFocus="OnBoxTextBoxLostFocus" Tag="Height" FontSize="10" Height="20" MinWidth="25" Padding="2,0" Margin="0" HorizontalContentAlignment="Center"/>
                                                                </Grid>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                    </Grid>
                </TabItem>

                <!-- Attributes subtab -->
                <TabItem Header="Attributes">
                    <Grid RowDefinitions="Auto, *, Auto" Margin="0,5,0,0">
                        <TextBox Name="txtAttributesSearch" Text="{Binding Elements.AttributeSearchText, Mode=TwoWay}" PlaceholderText="Filter attributes" Height="26" Margin="0,0,0,5" VerticalContentAlignment="Center"/>
                        <DataGrid Grid.Row="1" Name="listAttributes" ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Elements.FilteredAttributes}"
                                  x:DataType="models:AttributeModel"
                                  SelectedItem="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Elements.SelectedAttribute, Mode=TwoWay}"
                                  CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="False"
                                  GridLinesVisibility="None" HeadersVisibility="None"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="*" Foreground="#fdd663" FontSize="12" FontWeight="SemiBold"/>
                                <DataGridTextColumn Header="Value" Binding="{Binding Value, Mode=TwoWay}" IsReadOnly="False" Width="2*" Foreground="#81c995" FontSize="12"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Grid Grid.Row="2" ColumnDefinitions="*, *, Auto, Auto" Margin="0,8,0,0">
                            <TextBox Name="txtAttrName" Text="{Binding Elements.AttributeNameInputText, Mode=TwoWay}" PlaceholderText="Name" Height="28" VerticalContentAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox Grid.Column="1" Name="txtAttrValue" Text="{Binding Elements.AttributeValueInputText, Mode=TwoWay}" PlaceholderText="Value" Height="28" VerticalContentAlignment="Center" Margin="0,0,4,0"/>
                            <Button Grid.Column="2" Name="btnApplyAttr" Command="{Binding Elements.ApplyAttributeCommand}" Content="Apply" Padding="10,0" Height="28" Margin="0,0,4,0"/>
                            <Button Grid.Column="3" Name="btnDeleteAttr" Command="{Binding Elements.DeleteAttributeCommand}" Content="Delete" Padding="10,0" Height="28"/>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Properties subtab -->
                <TabItem Header="Properties">
                    <Grid RowDefinitions="Auto, *, Auto" Margin="0,5,0,0">
                        <TextBox Name="txtPropertiesSearch" Text="{Binding Elements.PropertySearchText, Mode=TwoWay}" PlaceholderText="Filter properties" Height="26" Margin="0,0,0,5" VerticalContentAlignment="Center"/>
                        <DataGrid Grid.Row="1" Name="listProperties" ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Elements.FilteredProperties}"
                                  x:DataType="models:PropertyModel"
                                  SelectedItem="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Elements.SelectedProperty, Mode=TwoWay}"
                                  CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="False"
                                  GridLinesVisibility="None" HeadersVisibility="None"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="1.5*" Foreground="#8ab4f8" FontSize="12" FontWeight="SemiBold"/>
                                <DataGridTextColumn Header="Value" Binding="{Binding Value, Mode=TwoWay}" IsReadOnly="False" Width="2.5*" Foreground="#e8eaed" FontSize="12"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type, StringFormat='({0})'}" IsReadOnly="True" Width="*" Foreground="#9aa0a6" FontSize="10"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Grid Grid.Row="2" ColumnDefinitions="Auto, Auto, *, Auto" Margin="0,8,0,0">
                            <TextBlock Text="Selected:" VerticalAlignment="Center" Foreground="#9aa0a6" Margin="0,0,5,0" FontSize="11"/>
                            <TextBlock Grid.Column="1" Name="lblSelectedProperty" Text="{Binding Elements.SelectedPropertyNameText}" FontWeight="Bold" Foreground="#8ab4f8" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"/>
                            <TextBox Grid.Column="2" Name="txtPropertyValue" Text="{Binding Elements.PropertyValueInputText, Mode=TwoWay}" PlaceholderText="Value..." Height="28" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="3" Name="btnApplyProperty" Command="{Binding Elements.ApplyPropertyCommand}" Content="Set" Margin="5,0,0,0" Padding="10,0" Height="28"/>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Event Listeners subtab -->
                <TabItem Header="Event Listeners">
                    <DataGrid Name="listEventListeners" ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Elements.EventListeners}" Margin="0,5,0,0"
                              x:DataType="models:EventListenerModel"
                              CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="True"
                              GridLinesVisibility="None" HeadersVisibility="None"
                              Background="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" IsReadOnly="True" Width="*" Foreground="#fdd663" FontSize="12" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Handler" Binding="{Binding HandlerName}" IsReadOnly="True" Width="2*" Foreground="#81c995" FontSize="12"/>
                            <DataGridTextColumn Header="Capture" Binding="{Binding CaptureText, StringFormat='(Capture: {0})'}" IsReadOnly="True" Width="*" Foreground="#9aa0a6" FontSize="10"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
                <!-- Accessibility subtab -->
                <TabItem Header="Accessibility">
                    <ScrollViewer Margin="0,5,0,0">
                        <StackPanel Spacing="10" Margin="5">
                            <TextBlock Text="Accessibility Properties" FontWeight="SemiBold" Foreground="#9aa0a6" FontSize="12" Margin="0,0,0,5"/>
                            
                            <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto" Margin="5">
                                <!-- Role -->
                                <TextBlock Text="Role:" Foreground="#9aa0a6" FontSize="11" Margin="0,4" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Elements.AxRoleText}" Foreground="#e8eaed" FontWeight="SemiBold" FontSize="12" Margin="10,4" VerticalAlignment="Center"/>
                                
                                <!-- Name -->
                                <TextBlock Grid.Row="1" Text="Name:" Foreground="#9aa0a6" FontSize="11" Margin="0,4" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Elements.AxNameText}" Foreground="#e8eaed" FontWeight="SemiBold" FontSize="12" Margin="10,4" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                
                                <!-- Description -->
                                <TextBlock Grid.Row="2" Text="Description:" Foreground="#9aa0a6" FontSize="11" Margin="0,4" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Elements.AxDescriptionText}" Foreground="#e8eaed" FontWeight="SemiBold" FontSize="12" Margin="10,4" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                
                                <!-- Ignored -->
                                <TextBlock Grid.Row="3" Text="Ignored:" Foreground="#9aa0a6" FontSize="11" Margin="0,4" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Elements.AxIgnoredText}" Foreground="#f28b82" FontWeight="SemiBold" FontSize="12" Margin="10,4" VerticalAlignment="Center"/>
                                
                                <!-- Parent ID -->
                                <TextBlock Grid.Row="4" Text="Parent AX ID:" Foreground="#9aa0a6" FontSize="11" Margin="0,4" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Elements.AxParentIdText}" Foreground="#8ab4f8" FontWeight="SemiBold" FontSize="12" Margin="10,4" VerticalAlignment="Center"/>
                                
                                <!-- Child IDs -->
                                <TextBlock Grid.Row="5" Text="Child AX IDs:" Foreground="#9aa0a6" FontSize="11" Margin="0,4" VerticalAlignment="Top"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Elements.AxChildIdsText}" Foreground="#8ab4f8" FontWeight="SemiBold" FontSize="12" Margin="10,4" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Layout subtab -->
                <TabItem Header="Layout">
                    <ScrollViewer Margin="0,5,0,0">
                        <StackPanel Spacing="15" Margin="5">
                            <!-- Box Model Visualizer -->
                            <TextBlock Text="Box Model" FontWeight="SemiBold" Foreground="#9aa0a6" FontSize="12" Margin="0,0,0,5"/>
                            
                            <!-- Box Model Diagram -->
                            <Border Background="#3c4043" BorderBrush="#d58512" BorderThickness="1" Padding="12" CornerRadius="4">
                                <Grid RowDefinitions="Auto, *">
                                    <TextBlock Text="margin" Foreground="#d58512" FontSize="9" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding Elements.LayoutMargin}" Foreground="#d58512" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,10"/>
                                    
                                    <Border Grid.Row="1" Background="#323639" BorderBrush="#e3b505" BorderThickness="1" Padding="12" CornerRadius="4">
                                        <Grid RowDefinitions="Auto, *">
                                            <TextBlock Text="border" Foreground="#e3b505" FontSize="9" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                            <TextBlock Text="{Binding Elements.LayoutBorderThickness}" Foreground="#e3b505" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,10"/>
                                            
                                            <Border Grid.Row="1" Background="#282c2f" BorderBrush="#5d9e5d" BorderThickness="1" Padding="12" CornerRadius="4">
                                                <Grid RowDefinitions="Auto, *">
                                                    <TextBlock Text="padding" Foreground="#5d9e5d" FontSize="9" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                                    <TextBlock Text="{Binding Elements.LayoutPadding}" Foreground="#5d9e5d" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,10"/>
                                                    
                                                    <Border Grid.Row="1" Background="#202124" BorderBrush="#8ab4f8" BorderThickness="1" Padding="12" CornerRadius="4" MinWidth="80" MinHeight="40">
                                                        <Grid RowDefinitions="Auto, *">
                                                            <TextBlock Text="content" Foreground="#8ab4f8" FontSize="9" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4,0,4">
                                                                <TextBlock Text="{Binding Elements.LayoutWidth}" Foreground="#e8eaed" FontSize="11" FontWeight="Bold"/>
                                                                <TextBlock Text=" × " Foreground="#9aa0a6" FontSize="11"/>
                                                                <TextBlock Text="{Binding Elements.LayoutHeight}" Foreground="#e8eaed" FontSize="11" FontWeight="Bold"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <Separator Background="#3c4043"/>

                            <!-- Layout Properties Grid -->
                            <TextBlock Text="Layout Properties" FontWeight="SemiBold" Foreground="#9aa0a6" FontSize="12" Margin="0,5,0,5"/>
                            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto" Margin="5">
                                <!-- Bounds -->
                                <StackPanel Margin="0,5">
                                    <TextBlock Text="Bounds (Actual size/pos):" Foreground="#9aa0a6" FontSize="11"/>
                                    <TextBlock Text="{Binding Elements.LayoutBounds}" Foreground="#e8eaed" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                                
                                <!-- Horizontal Alignment -->
                                <StackPanel Grid.Column="1" Margin="0,5">
                                    <TextBlock Text="Horizontal Alignment:" Foreground="#9aa0a6" FontSize="11"/>
                                    <TextBlock Text="{Binding Elements.LayoutHorizontalAlignment}" Foreground="#e8eaed" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                                
                                <!-- Vertical Alignment -->
                                <StackPanel Grid.Row="1" Margin="0,5">
                                    <TextBlock Text="Vertical Alignment:" Foreground="#9aa0a6" FontSize="11"/>
                                    <TextBlock Text="{Binding Elements.LayoutVerticalAlignment}" Foreground="#e8eaed" FontWeight="SemiBold" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
