<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CdpInspectorApp.ViewModels"
             xmlns:models="clr-namespace:CdpInspectorApp.Models;assembly=CDP.Inspector.Shared"
             xmlns:controls="clr-namespace:CdpInspectorApp.Controls"
             x:Class="CdpInspectorApp.Views.NetworkView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="True">
    <Grid RowDefinitions="Auto, Auto, *" Margin="10">
        <!-- Top Toolbar -->
        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
            <Button Name="btnClearNetwork" Command="{Binding Network.ClearNetworkCommand}" Content="Clear Network Log"/>
            <TextBlock Text="Throttling:" Foreground="#9aa0a6" VerticalAlignment="Center" FontSize="12" Margin="10,0,0,0"/>
            <ComboBox Name="cmbThrottling"
                      ItemsSource="{Binding Network.ThrottlingProfiles}"
                      SelectedItem="{Binding Network.SelectedProfile, Mode=TwoWay}"
                      Width="150" Height="28"
                      Background="#202124" BorderBrush="#3c4043" Foreground="#e8eaed">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ThrottlingProfile">
                        <TextBlock Text="{Binding DisplayName}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Captures outbound HTTP requests from HttpClient instances" Foreground="#9aa0a6" VerticalAlignment="Center" FontSize="11" Margin="10,0,0,0"/>
        </StackPanel>

        <!-- Category Filter Toolbar -->
        <ListBox Grid.Row="1" 
                 ItemsSource="{Binding Network.Filters}" 
                 SelectedItem="{Binding Network.ActiveFilter, Mode=TwoWay}"
                 Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,0,8">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="4"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="CornerRadius" Value="4"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Background" Value="#2f3032"/>
                    <Setter Property="Foreground" Value="#e8eaed"/>
                    <Setter Property="Margin" Value="0,0,4,0"/>
                </Style>
                <Style Selector="ListBoxItem:selected">
                    <Setter Property="Background" Value="#1a73e8"/>
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </ListBox.Styles>
        </ListBox>

        <!-- Grid split pane -->
        <Grid Grid.Row="2" ColumnDefinitions="*, 4, 380">
            <!-- List -->
            <DataGrid Name="lstNetworkRequests" ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Network.FilteredNetworkRequests}" SelectedItem="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Network.SelectedRequest, Mode=TwoWay}" x:DataType="models:NetworkRequestModel"
                       CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="True"
                       GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                       Background="#202124" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                <DataGrid.ColumnHeaderContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Columns" ItemsSource="{Binding $parent[DataGrid].Columns}">
                            <MenuItem.ItemContainerTheme>
                                <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}" x:DataType="DataGridColumn">
                                    <Setter Property="Header" Value="{Binding Header}" />
                                    <Setter Property="IsChecked" Value="{Binding IsVisible, Mode=TwoWay}" />
                                    <Setter Property="ToggleType" Value="CheckBox" />
                                </ControlTheme>
                            </MenuItem.ItemContainerTheme>
                        </MenuItem>
                    </ContextMenu>
                </DataGrid.ColumnHeaderContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name / URL" Binding="{Binding Url}" Width="*" Foreground="#e8eaed" FontSize="12"/>
                    <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="80" Foreground="#fdd663" FontSize="12" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" Foreground="#81c995" FontSize="12"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80" Foreground="#9aa0a6" FontSize="12"/>
                    <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="80" Foreground="#8ab4f8" FontSize="12"/>
                    <DataGridTemplateColumn Header="Waterfall" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="models:NetworkRequestModel">
                                <Grid Width="120" HorizontalAlignment="Left" Background="Transparent" VerticalAlignment="Stretch" ToolTip.Tip="{Binding WaterfallToolTip}">
                                    <controls:WaterfallBar StartOffsetPercent="{Binding StartOffsetPercent}"
                                                           TtfbPercent="{Binding TtfbPercent}"
                                                           DownloadPercent="{Binding DownloadPercent}"
                                                           Height="8"
                                                           Width="120"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1" Background="#3c4043"/>

            <!-- Details drawer -->
            <Border Grid.Column="2" BorderBrush="#3c4043" BorderThickness="1,0,0,0" Margin="10,0,0,0" Padding="10,0,0,0">
                <Grid RowDefinitions="Auto, Auto, *">
                    <TextBlock Text="Request Details" FontSize="14" FontWeight="Bold" Foreground="#e8eaed" Margin="0,0,0,10"/>
                    <StackPanel Grid.Row="1" Spacing="3" Margin="0,0,0,10">
                        <TextBlock Text="Request URL:" Foreground="#9aa0a6" FontSize="11"/>
                        <TextBlock Name="lblNetUrl" Text="{Binding Network.SelectedUrl}" TextWrapping="Wrap" FontSize="12" FontWeight="SemiBold" Foreground="#e8eaed"/>
                    </StackPanel>
                    <TabControl Grid.Row="2" Background="#202124" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                        <TabItem Header="Headers">
                            <ScrollViewer Margin="5">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Request Headers:" Foreground="#9aa0a6" FontSize="11"/>
                                    <TextBox Name="txtNetReqHeaders" Text="{Binding Network.SelectedRequestHeaders}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="120" FontSize="11"/>
                                    <TextBlock Text="Response Headers:" Foreground="#9aa0a6" FontSize="11" Margin="0,5,0,0"/>
                                    <TextBox Name="txtNetResHeaders" Text="{Binding Network.SelectedResponseHeaders}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="120" FontSize="11"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Payload" IsVisible="{Binding Network.SelectedRequest, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <ScrollViewer Margin="5">
                                <StackPanel Spacing="10" x:DataType="models:NetworkRequestModel" DataContext="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Network.SelectedRequest}">
                                    <TextBlock Text="Query Parameters" FontWeight="Bold" Foreground="#e8eaed" FontSize="12"
                                               IsVisible="{Binding HasQueryParameters}"/>
                                    <DataGrid Height="120" ItemsSource="{Binding QueryParameters}" CanUserResizeColumns="True" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                              IsVisible="{Binding HasQueryParameters}" Background="#202124" BorderBrush="#3c4043" BorderThickness="1">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="*" Foreground="#e8eaed" FontSize="11"/>
                                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*" Foreground="#9aa0a6" FontSize="11"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <TextBlock Text="Post Parameters" FontWeight="Bold" Foreground="#e8eaed" FontSize="12"
                                               IsVisible="{Binding HasPostParameters}" Margin="0,10,0,0"/>
                                    <DataGrid Height="120" ItemsSource="{Binding PostParameters}" CanUserResizeColumns="True" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                              IsVisible="{Binding HasPostParameters}" Background="#202124" BorderBrush="#3c4043" BorderThickness="1">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="*" Foreground="#e8eaed" FontSize="11"/>
                                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*" Foreground="#9aa0a6" FontSize="11"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <TextBlock Text="No payload parameters" Foreground="#9aa0a6" FontSize="12" IsVisible="{Binding !HasPayload}"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Preview" IsVisible="{Binding Network.SelectedRequest, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <ScrollViewer Margin="5">
                                <StackPanel x:DataType="models:NetworkRequestModel" DataContext="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Network.SelectedRequest}">
                                    <!-- JSON tree view -->
                                    <TreeView ItemsSource="{Binding JsonTree}" IsVisible="{Binding IsJson}" MaxHeight="250">
                                        <TreeView.ItemTemplate>
                                            <TreeDataTemplate x:DataType="models:JsonTreeNode" ItemsSource="{Binding Children}">
                                                <TextBlock Text="{Binding Header}" FontSize="11" Foreground="#e8eaed"/>
                                            </TreeDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>

                                    <!-- Image preview -->
                                    <Image Source="{Binding ResponseImage}" IsVisible="{Binding IsImage}" MaxWidth="250" MaxHeight="250" HorizontalAlignment="Left"/>

                                    <!-- Text box fallback -->
                                    <TextBox Name="txtNetBody" Text="{Binding ResponseBody}" IsVisible="{Binding IsRawText}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" Height="250" FontSize="11"/>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
