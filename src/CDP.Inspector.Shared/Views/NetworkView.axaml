<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CdpInspectorApp.Views.NetworkView"
             x:CompileBindings="False">
    <Grid RowDefinitions="Auto, *" Margin="10">
        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
            <Button Name="btnClearNetwork" Command="{Binding Network.ClearNetworkCommand}" Content="Clear Network Log"/>
            <TextBlock Text="Throttling:" Foreground="#9aa0a6" VerticalAlignment="Center" FontSize="12" Margin="10,0,0,0"/>
            <ComboBox Name="cmbThrottling"
                      ItemsSource="{Binding Network.ThrottlingProfiles}"
                      SelectedItem="{Binding Network.SelectedProfile, Mode=TwoWay}"
                      Width="150" Height="28"
                      Background="#202124" BorderBrush="#3c4043" Foreground="#e8eaed">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="Captures outbound HTTP requests from HttpClient instances" Foreground="#9aa0a6" VerticalAlignment="Center" FontSize="11" Margin="10,0,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="*, 4, 380">
            <!-- List -->
            <DataGrid Name="lstNetworkRequests" ItemsSource="{Binding Network.NetworkRequests}" SelectedItem="{Binding Network.SelectedRequest, Mode=TwoWay}"
                      CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="True"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      Background="#202124" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                <DataGrid.ColumnHeaderContextMenu>
                    <ContextMenu x:CompileBindings="False">
                        <MenuItem Header="Columns" ItemsSource="{Binding $parent[DataGrid].Columns}">
                            <MenuItem.ItemContainerTheme>
                                <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                                    <Setter Property="Header" Value="{Binding Header}" />
                                    <Setter Property="IsChecked" Value="{Binding IsVisible, Mode=TwoWay}" />
                                    <Setter Property="ToggleType" Value="CheckBox" />
                                </ControlTheme>
                            </MenuItem.ItemContainerTheme>
                        </MenuItem>
                    </ContextMenu>
                </DataGrid.ColumnHeaderContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name / URL" Binding="{Binding Url}" Width="*" Foreground="#e8eaed" FontSize="12"/>
                    <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="80" Foreground="#fdd663" FontSize="12" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80" Foreground="#81c995" FontSize="12"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80" Foreground="#9aa0a6" FontSize="12"/>
                    <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="80" Foreground="#8ab4f8" FontSize="12"/>
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1" Background="#3c4043"/>

            <!-- Details drawer -->
            <Border Grid.Column="2" BorderBrush="#3c4043" BorderThickness="1,0,0,0" Margin="10,0,0,0" Padding="10,0,0,0">
                <ScrollViewer>
                    <StackPanel Spacing="15">
                        <TextBlock Text="Headers &amp; Content Preview" FontSize="14" FontWeight="Bold" Foreground="#e8eaed"/>
                        <StackPanel Spacing="3">
                            <TextBlock Text="Request URL:" Foreground="#9aa0a6" FontSize="11"/>
                            <TextBlock Name="lblNetUrl" Text="{Binding Network.SelectedUrl}" TextWrapping="Wrap" FontSize="12" FontWeight="SemiBold" Foreground="#e8eaed"/>
                        </StackPanel>
                        <StackPanel Spacing="5">
                            <TextBlock Text="Request Headers:" Foreground="#9aa0a6" FontSize="11"/>
                            <TextBox Name="txtNetReqHeaders" Text="{Binding Network.SelectedRequestHeaders}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="100" FontSize="11"/>
                            <TextBlock Text="Response Headers:" Foreground="#9aa0a6" FontSize="11" Margin="0,5,0,0"/>
                            <TextBox Name="txtNetResHeaders" Text="{Binding Network.SelectedResponseHeaders}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="100" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Spacing="5">
                            <TextBlock Text="Response Body Preview:" Foreground="#9aa0a6" FontSize="11"/>
                            <TextBox Name="txtNetBody" Text="{Binding Network.SelectedResponseBody}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" Height="150" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
