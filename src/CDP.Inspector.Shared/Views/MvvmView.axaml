<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CdpInspectorApp.ViewModels"
             x:Class="CdpInspectorApp.Views.MvvmView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="True">
    <Grid RowDefinitions="Auto, *">
        <!-- Toolbar -->
        <Border Grid.Row="0" Height="32" Background="#292a2d" BorderBrush="#3c4043" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="6,0,6,0">
                <Button Name="btnRefresh" Command="{Binding Mvvm.RefreshTreeCommand}" Classes="toolbar-button" ToolTip.Tip="Refresh ViewModel Tree">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <PathIcon Data="{StaticResource RefreshIcon}" Width="12" Height="12"/>
                        <TextBlock Text="Refresh" VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                </Button>
                <Separator Width="1" Background="#3c4043" Margin="4,6"/>
                <Button Name="btnClearHistory" Command="{Binding Mvvm.ClearHistoryCommand}" Classes="toolbar-button" ToolTip.Tip="Clear Command History">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <PathIcon Data="{StaticResource DismissIcon}" Width="12" Height="12"/>
                        <TextBlock Text="Clear History" VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1" RowDefinitions="*, 4, 180">
            <!-- Top Half (Left Tree and Right Grid) -->
            <Grid Grid.Row="0" ColumnDefinitions="*, 4, 1.2*">
                <!-- Left Pane: ViewModels Tree -->
                <Border Grid.Column="0" BorderBrush="#3c4043" BorderThickness="0,0,1,0">
                    <Grid RowDefinitions="Auto, *">
                        <Border Background="#202124" Padding="8,4" BorderBrush="#3c4043" BorderThickness="0,0,0,1">
                            <TextBlock Text="ACTIVE VIEWMODELS TREE" FontSize="11" FontWeight="Bold" Foreground="#9aa0a6"/>
                        </Border>
                        <TreeView Grid.Row="1" ItemsSource="{Binding Mvvm.MvvmTree}" SelectedItem="{Binding Mvvm.SelectedNode, Mode=TwoWay}">
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="vm:InspectorViewModelNode">
                                    <StackPanel Orientation="Horizontal" Spacing="6" Height="22">
                                        <PathIcon Data="{StaticResource DiagramIcon}" Width="12" Height="12" Foreground="#8ab4f8"/>
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" FontSize="12" Foreground="#e8eaed"/>
                                    </StackPanel>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                            <TreeView.Styles>
                                <Style Selector="TreeViewItem" x:DataType="vm:InspectorViewModelNode">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                </Style>
                            </TreeView.Styles>
                        </TreeView>
                    </Grid>
                </Border>

                <!-- Column Splitter -->
                <GridSplitter Grid.Column="1" Background="#3c4043"/>

                <!-- Right Pane: Properties Grid -->
                <Grid Grid.Column="2" RowDefinitions="Auto, *">
                    <Border Grid.Row="0" Background="#202124" Padding="8,4" BorderBrush="#3c4043" BorderThickness="0,0,0,1">
                        <TextBlock Text="VIEWMODEL PROPERTIES" FontSize="11" FontWeight="Bold" Foreground="#9aa0a6"/>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Mvvm.SelectedNode.Properties}" x:DataType="vm:InspectorPropertyModel"
                              CanUserResizeColumns="True" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              Background="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Property" Binding="{Binding Name}" Width="150" Foreground="#e8eaed" FontSize="12" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="200" Foreground="#9aa0a6" FontSize="11"/>
                            <DataGridTemplateColumn Header="Value" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="vm:InspectorPropertyModel">
                                        <Grid ColumnDefinitions="*, Auto" Margin="2">
                                            <TextBox Name="txtVal" Text="{Binding DisplayValue, Mode=TwoWay}" IsReadOnly="{Binding !IsWritable}" FontSize="12" Height="24" Padding="4,2"/>
                                            <Button Grid.Column="1" Content="Set" Command="{Binding UpdateValueCommand}" CommandParameter="{Binding #txtVal.Text}" IsVisible="{Binding IsWritable}" FontSize="11" Margin="4,0,0,0" Padding="8,2" Classes="accent"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>

            <!-- Horizontal Splitter -->
            <GridSplitter Grid.Row="1" Background="#3c4043"/>

            <!-- Bottom Pane: Command Execution History -->
            <Grid Grid.Row="2" RowDefinitions="Auto, *">
                <Border Grid.Row="0" Background="#202124" Padding="8,4" BorderBrush="#3c4043" BorderThickness="0,0,0,1">
                    <TextBlock Text="COMMAND EXECUTION HISTORY (REACTIVECOMMANDS)" FontSize="11" FontWeight="Bold" Foreground="#9aa0a6"/>
                </Border>
                <DataGrid Grid.Row="1" ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Mvvm.CommandHistory}" x:DataType="vm:CommandExecutedModel"
                          CanUserResizeColumns="True" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="150" Foreground="#9aa0a6" FontSize="11"/>
                        <DataGridTextColumn Header="ViewModel" Binding="{Binding ViewModelType}" Width="200" Foreground="#e8eaed" FontSize="12"/>
                        <DataGridTextColumn Header="Command Name" Binding="{Binding CommandName}" Width="180" Foreground="#8ab4f8" FontSize="12" FontWeight="Bold"/>
                        <DataGridTextColumn Header="Execution Result" Binding="{Binding Result}" Width="*" Foreground="#e8eaed" FontSize="12"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
