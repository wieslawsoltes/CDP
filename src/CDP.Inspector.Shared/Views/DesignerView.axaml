<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CdpInspectorApp.ViewModels"
             xmlns:wysiwyg="clr-namespace:CDP.Inspector.Wysiwyg.Controls;assembly=CDP.Inspector.Wysiwyg"
             x:Class="CdpInspectorApp.Views.DesignerView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="True">
    <Grid ColumnDefinitions="220,*,280">
        <!-- Left: Toolbox Panel -->
        <Border Grid.Column="0"
                BorderBrush="#333333"
                BorderThickness="0,0,1,0"
                Background="#1e1e1e">
            <Grid RowDefinitions="Auto,*">
                <!-- Toolbox Header -->
                <Border Grid.Row="0" Padding="10,8" Background="#252526">
                    <Grid ColumnDefinitions="Auto,*">
                        <PathIcon Grid.Column="0"
                                  Data="{StaticResource AppsIcon}"
                                  Width="14" Height="14"
                                  Foreground="#e0e0e0"
                                  Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1"
                                   Text="Toolbox"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#e0e0e0"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <!-- Toolbox Items -->
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl Name="lstToolboxItems"
                                  ItemsSource="{Binding Designer.ToolboxItems}"
                                  Margin="4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ToolboxItemViewModel">
                                <Button Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Designer.DropElementCommand}"
                                        CommandParameter="{Binding DefaultXaml}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch">
                                    <Border Padding="8,5"
                                            Margin="1"
                                            CornerRadius="3"
                                            Background="#2d2d30"
                                            Cursor="Hand">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <PathIcon Data="{StaticResource AppsIcon}"
                                                      Width="12" Height="12"
                                                      Foreground="#64b5f6"
                                                      Margin="0,0,8,0"
                                                      VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="11"
                                                           Foreground="#e0e0e0" />
                                                <TextBlock Text="{Binding Category}"
                                                           FontSize="9"
                                                           Foreground="#808080" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Center: Design Canvas -->
        <Border Grid.Column="1"
                Background="#1a1a2e"
                ClipToBounds="True">
            <Grid>
                <!-- Toolbar -->
                <Border VerticalAlignment="Top"
                        Padding="8,4"
                        Background="#252526"
                        ZIndex="10">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ToggleButton Name="btnToggleDesignMode"
                                      IsChecked="{Binding Designer.IsDesignModeActive, Mode=TwoWay}"
                                      Padding="6,4">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="{StaticResource DesignIcon}"
                                          Width="14" Height="14" />
                                <TextBlock Text="Design Mode"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <Button Name="btnDesignerDeleteElement"
                                Command="{Binding Designer.DeleteElementCommand}"
                                Padding="6,4"
                                ToolTip.Tip="Delete selected element">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="{StaticResource DeleteIcon}"
                                          Width="12" Height="12"
                                          Foreground="#ff5252" />
                                <TextBlock Text="Delete"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{Binding Designer.SelectedElementSelector}"
                                   FontSize="10"
                                   Foreground="#808080"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0" />
                    </StackPanel>
                </Border>

                <!-- Preview placeholder when Design Mode is off -->
                <TextBlock Text="Connect to a target and enable Design Mode to begin editing"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#555555"
                           IsVisible="{Binding !Designer.IsDesignModeActive}" />

                <!-- Design Canvas and Overlay when Design Mode is Active -->
                <ScrollViewer Margin="0,35,0,30"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding Designer.IsDesignModeActive}">
                    <Border Background="#292a2d"
                            BorderBrush="#3c4043"
                            BorderThickness="1"
                            CornerRadius="4"
                            Margin="15"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Viewbox Stretch="Uniform">
                            <Grid Width="{Binding Simulation.DeviceWidth}"
                                  Height="{Binding Simulation.DeviceHeight}">
                                <Image Name="imgDesignerScreenshot"
                                       Source="{Binding Simulation.ScreenshotImage}"
                                       Width="{Binding Simulation.DeviceWidth}"
                                       Height="{Binding Simulation.DeviceHeight}"
                                       Stretch="Fill" />
                                <wysiwyg:DesignerOverlay Name="designerOverlay"
                                                         SelectedBounds="{Binding Designer.SelectedBounds}"
                                                         MultiSelectedBounds="{Binding Designer.MultiSelectedBounds}"
                                                         MarginThickness="{Binding Designer.SelectedMarginThickness}"
                                                         PaddingThickness="{Binding Designer.SelectedPaddingThickness}"
                                                         IsOverlayVisible="{Binding Designer.IsOverlayVisible}"
                                                         StackPanelOrientation="{Binding Designer.StackPanelOrientation}"
                                                         SelectedElementBadge="{Binding Designer.SelectedElementBadge}"
                                                         Width="{Binding Simulation.DeviceWidth}"
                                                         Height="{Binding Simulation.DeviceHeight}"/>
                            </Grid>
                        </Viewbox>
                    </Border>
                </ScrollViewer>

                <!-- Breadcrumb Parent Trail -->
                <Border VerticalAlignment="Bottom"
                        Background="#252526"
                        BorderBrush="#333333"
                        BorderThickness="0,1,0,0"
                        Height="30"
                        Padding="10,0"
                        ZIndex="10"
                        IsVisible="{Binding Designer.IsDesignModeActive}">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl Name="lstBreadcrumbs"
                                      ItemsSource="{Binding Designer.Breadcrumbs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:BreadcrumbItemViewModel">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Button Classes="link"
                                                Content="{Binding Name}"
                                                Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Designer.SelectElementCommand}"
                                                CommandParameter="{Binding Selector}"
                                                FontSize="11"
                                                Foreground="#4fc3f7"
                                                Padding="2" />
                                        <TextBlock Text=">"
                                                   FontSize="11"
                                                   Foreground="#888888"
                                                   VerticalAlignment="Center"
                                                   Margin="2,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <!-- Right: Properties Panel -->
        <!-- Right: Properties Panel -->
        <Border Grid.Column="2"
                BorderBrush="#2e2e2e"
                BorderThickness="1,0,0,0"
                Background="#2c2c2c"
                Width="260">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="12,8,12,12" Spacing="16">
                    
                    <!-- Selection Header -->
                    <Border Background="#1e1e1e" Padding="8,6" Margin="-12,-8,-12,0" BorderThickness="0,0,0,1" BorderBrush="#2e2e2e">
                        <TextBlock Text="{Binding Designer.SelectedElementBadge, FallbackValue='NO SELECTION'}"
                                   FontSize="10" FontWeight="Bold" Foreground="#888888" HorizontalAlignment="Center"/>
                    </Border>
                    
                    <!-- Section: Alignment -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="ALIGNMENT" FontSize="9" FontWeight="Bold" Foreground="#888888" LetterSpacing="0.5" />
                        <Border Background="#1e1e1e" CornerRadius="4" Padding="2" BorderThickness="1" BorderBrush="#333333">
                            <StackPanel Name="pnlAlignment" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                <Button ToolTip.Tip="Align Left"
                                        Command="{Binding Designer.ApplyAlignmentCommand}"
                                        CommandParameter="H:Left"
                                        Width="26" Height="26" Padding="6" Background="Transparent" BorderThickness="0">
                                    <PathIcon Data="{StaticResource AlignLeftIcon}" Width="14" Height="14" Foreground="#bbbbbb"/>
                                </Button>
                                <Button ToolTip.Tip="Align Horizontal Center"
                                        Command="{Binding Designer.ApplyAlignmentCommand}"
                                        CommandParameter="H:Center"
                                        Width="26" Height="26" Padding="6" Background="Transparent" BorderThickness="0">
                                    <PathIcon Data="{StaticResource AlignCenterHorizontalIcon}" Width="14" Height="14" Foreground="#bbbbbb"/>
                                </Button>
                                <Button ToolTip.Tip="Align Right"
                                        Command="{Binding Designer.ApplyAlignmentCommand}"
                                        CommandParameter="H:Right"
                                        Width="26" Height="26" Padding="6" Background="Transparent" BorderThickness="0">
                                    <PathIcon Data="{StaticResource AlignRightIcon}" Width="14" Height="14" Foreground="#bbbbbb"/>
                                </Button>
                                <Button ToolTip.Tip="Stretch Horizontally"
                                        Command="{Binding Designer.ApplyAlignmentCommand}"
                                        CommandParameter="H:Stretch"
                                        Width="26" Height="26" Padding="6" Background="Transparent" BorderThickness="0">
                                    <PathIcon Data="{StaticResource AlignStretchHorizontalIcon}" Width="14" Height="14" Foreground="#bbbbbb"/>
                                </Button>
                                
                                <Separator Width="1" Height="16" Background="#333333" Margin="2,0" VerticalAlignment="Center"/>
                                
                                <Button ToolTip.Tip="Align Top"
                                        Command="{Binding Designer.ApplyAlignmentCommand}"
                                        CommandParameter="V:Top"
                                        Width="26" Height="26" Padding="6" Background="Transparent" BorderThickness="0">
                                    <PathIcon Data="{StaticResource AlignTopIcon}" Width="14" Height="14" Foreground="#bbbbbb"/>
                                </Button>
                                <Button ToolTip.Tip="Align Vertical Center"
                                        Command="{Binding Designer.ApplyAlignmentCommand}"
                                        CommandParameter="V:Center"
                                        Width="26" Height="26" Padding="6" Background="Transparent" BorderThickness="0">
                                    <PathIcon Data="{StaticResource AlignCenterVerticalIcon}" Width="14" Height="14" Foreground="#bbbbbb"/>
                                </Button>
                                <Button ToolTip.Tip="Align Bottom"
                                        Command="{Binding Designer.ApplyAlignmentCommand}"
                                        CommandParameter="V:Bottom"
                                        Width="26" Height="26" Padding="6" Background="Transparent" BorderThickness="0">
                                    <PathIcon Data="{StaticResource AlignBottomIcon}" Width="14" Height="14" Foreground="#bbbbbb"/>
                                </Button>
                                <Button ToolTip.Tip="Stretch Vertically"
                                        Command="{Binding Designer.ApplyAlignmentCommand}"
                                        CommandParameter="V:Stretch"
                                        Width="26" Height="26" Padding="6" Background="Transparent" BorderThickness="0">
                                    <PathIcon Data="{StaticResource AlignStretchVerticalIcon}" Width="14" Height="14" Foreground="#bbbbbb"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <Separator Background="#2e2e2e" Height="1" Margin="0,-4"/>
                    
                    <!-- Section: Position & Size -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="LAYOUT &amp; SIZE" FontSize="9" FontWeight="Bold" Foreground="#888888" LetterSpacing="0.5" />
                        <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,6,Auto" Margin="0,2">
                            <!-- X & Y Position -->
                            <Grid Grid.Row="0" Grid.Column="0" ColumnDefinitions="14,*" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="X" FontSize="10" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <NumericUpDown Grid.Column="1"
                                               Value="{Binding Designer.CanvasLeft}"
                                               Minimum="-10000" Maximum="10000" Increment="1"
                                               FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                            </Grid>
                            <Grid Grid.Row="0" Grid.Column="2" ColumnDefinitions="14,*" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="Y" FontSize="10" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <NumericUpDown Grid.Column="1"
                                               Value="{Binding Designer.CanvasTop}"
                                               Minimum="-10000" Maximum="10000" Increment="1"
                                               FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                            </Grid>
                            
                            <!-- W & H Size -->
                            <Grid Grid.Row="2" Grid.Column="0" ColumnDefinitions="14,*" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="W" FontSize="10" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <NumericUpDown Grid.Column="1"
                                               Value="{Binding Designer.SelectedElementWidth}"
                                               Minimum="0" Maximum="10000" Increment="1"
                                               FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                            </Grid>
                            <Grid Grid.Row="2" Grid.Column="2" ColumnDefinitions="14,*" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="H" FontSize="10" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <NumericUpDown Grid.Column="1"
                                               Value="{Binding Designer.SelectedElementHeight}"
                                               Minimum="0" Maximum="10000" Increment="1"
                                               FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                            </Grid>
                        </Grid>
                        
                        <Grid ColumnDefinitions="*,6,*">
                            <Button Grid.Column="0" Content="Apply Position"
                                    Command="{Binding Designer.ApplyCanvasAttachmentCommand}"
                                    HorizontalAlignment="Stretch" Height="24" Padding="0"
                                    Background="#1e1e1e" BorderThickness="1" BorderBrush="#333333"
                                    FontSize="10" Foreground="#cccccc"/>
                            <Button Grid.Column="2" Content="Apply Size"
                                    Command="{Binding Designer.ApplySizeCommand}"
                                    HorizontalAlignment="Stretch" Height="24" Padding="0"
                                    Background="#1e1e1e" BorderThickness="1" BorderBrush="#333333"
                                    FontSize="10" Foreground="#cccccc"/>
                        </Grid>
                    </StackPanel>
                    
                    <Separator Background="#2e2e2e" Height="1" Margin="0,-4"/>
                    
                    <!-- Section: Margins -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="MARGINS" FontSize="9" FontWeight="Bold" Foreground="#888888" LetterSpacing="0.5" />
                        <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,6,Auto" Margin="0,2">
                            <Grid Grid.Row="0" Grid.Column="0" ColumnDefinitions="14,*" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="L" FontSize="10" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <NumericUpDown Grid.Column="1" Value="{Binding Designer.SelectedMarginLeft}"
                                               Minimum="-1000" Maximum="10000" Increment="1" FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                            </Grid>
                            <Grid Grid.Row="0" Grid.Column="2" ColumnDefinitions="14,*" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="T" FontSize="10" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <NumericUpDown Grid.Column="1" Value="{Binding Designer.SelectedMarginTop}"
                                               Minimum="-1000" Maximum="10000" Increment="1" FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                            </Grid>
                            <Grid Grid.Row="2" Grid.Column="0" ColumnDefinitions="14,*" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="R" FontSize="10" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <NumericUpDown Grid.Column="1" Value="{Binding Designer.SelectedMarginRight}"
                                               Minimum="-1000" Maximum="10000" Increment="1" FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                            </Grid>
                            <Grid Grid.Row="2" Grid.Column="2" ColumnDefinitions="14,*" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="B" FontSize="10" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <NumericUpDown Grid.Column="1" Value="{Binding Designer.SelectedMarginBottom}"
                                               Minimum="-1000" Maximum="10000" Increment="1" FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                            </Grid>
                        </Grid>
                        <Button Content="Apply Margin"
                                Command="{Binding Designer.ApplyMarginCommand}"
                                HorizontalAlignment="Stretch" Height="24" Padding="0"
                                Background="#1e1e1e" BorderThickness="1" BorderBrush="#333333"
                                FontSize="10" Foreground="#cccccc"/>
                    </StackPanel>
                    
                    <Separator Background="#2e2e2e" Height="1" Margin="0,-4"/>
                    
                    <!-- Section: Padding -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="PADDING" FontSize="9" FontWeight="Bold" Foreground="#888888" LetterSpacing="0.5" />
                        <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,6,Auto" Margin="0,2">
                            <Grid Grid.Row="0" Grid.Column="0" ColumnDefinitions="14,*" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="L" FontSize="10" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <NumericUpDown Grid.Column="1" Value="{Binding Designer.SelectedPaddingLeft}"
                                               Minimum="0" Maximum="10000" Increment="1" FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                            </Grid>
                            <Grid Grid.Row="0" Grid.Column="2" ColumnDefinitions="14,*" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="T" FontSize="10" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <NumericUpDown Grid.Column="1" Value="{Binding Designer.SelectedPaddingTop}"
                                               Minimum="0" Maximum="10000" Increment="1" FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                            </Grid>
                            <Grid Grid.Row="2" Grid.Column="0" ColumnDefinitions="14,*" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="R" FontSize="10" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <NumericUpDown Grid.Column="1" Value="{Binding Designer.SelectedPaddingRight}"
                                               Minimum="0" Maximum="10000" Increment="1" FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                            </Grid>
                            <Grid Grid.Row="2" Grid.Column="2" ColumnDefinitions="14,*" VerticalAlignment="Center">
                                <TextBlock Grid.Column="0" Text="B" FontSize="10" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <NumericUpDown Grid.Column="1" Value="{Binding Designer.SelectedPaddingBottom}"
                                               Minimum="0" Maximum="10000" Increment="1" FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                            </Grid>
                        </Grid>
                        <Button Content="Apply Padding"
                                Command="{Binding Designer.ApplyPaddingCommand}"
                                HorizontalAlignment="Stretch" Height="24" Padding="0"
                                Background="#1e1e1e" BorderThickness="1" BorderBrush="#333333"
                                FontSize="10" Foreground="#cccccc"/>
                    </StackPanel>
                    
                    <Separator Background="#2e2e2e" Height="1" Margin="0,-4"/>
                    
                    <!-- Section: Container Editors -->
                    <StackPanel Spacing="8" IsVisible="{Binding Designer.IsOverlayVisible}">
                        <TextBlock Text="CONTAINER SETTINGS" FontSize="9" FontWeight="Bold" Foreground="#888888" LetterSpacing="0.5" />
                        
                        <!-- Grid Attachment Editor -->
                        <StackPanel Spacing="6" IsVisible="{Binding Designer.ShowGridAttachmentEditor}">
                            <TextBlock Text="Grid Position" FontSize="10" FontWeight="SemiBold" Foreground="#aaaaaa" />
                            <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,6,Auto" Margin="0,2">
                                <Grid Grid.Row="0" Grid.Column="0" ColumnDefinitions="26,*" VerticalAlignment="Center">
                                    <TextBlock Grid.Column="0" Text="Row" FontSize="9" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    <NumericUpDown Grid.Column="1" Value="{Binding Designer.GridRow}"
                                                   Minimum="0" Maximum="100" Increment="1" FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                                </Grid>
                                <Grid Grid.Row="0" Grid.Column="2" ColumnDefinitions="26,*" VerticalAlignment="Center">
                                    <TextBlock Grid.Column="0" Text="Col" FontSize="9" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    <NumericUpDown Grid.Column="1" Value="{Binding Designer.GridColumn}"
                                                   Minimum="0" Maximum="100" Increment="1" FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                                </Grid>
                                <Grid Grid.Row="2" Grid.Column="0" ColumnDefinitions="26,*" VerticalAlignment="Center">
                                    <TextBlock Grid.Column="0" Text="Span" FontSize="9" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    <NumericUpDown Grid.Column="1" Value="{Binding Designer.GridRowSpan}"
                                                   Minimum="1" Maximum="100" Increment="1" FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                                </Grid>
                                <Grid Grid.Row="2" Grid.Column="2" ColumnDefinitions="26,*" VerticalAlignment="Center">
                                    <TextBlock Grid.Column="0" Text="Span" FontSize="9" Foreground="#888888" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    <NumericUpDown Grid.Column="1" Value="{Binding Designer.GridColumnSpan}"
                                                   Minimum="1" Maximum="100" Increment="1" FormatString="F0" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                                </Grid>
                            </Grid>
                            <Button Content="Apply Grid Position"
                                    Command="{Binding Designer.ApplyGridAttachmentCommand}"
                                    HorizontalAlignment="Stretch" Height="24" Padding="0"
                                    Background="#1e1e1e" BorderThickness="1" BorderBrush="#333333"
                                    FontSize="10" Foreground="#cccccc" />
                        </StackPanel>
                        
                        <!-- Grid Definitions Editor -->
                        <StackPanel Spacing="6" IsVisible="{Binding Designer.ShowGridDefinitionsEditor}">
                            <TextBlock Text="Grid Definitions" FontSize="10" FontWeight="SemiBold" Foreground="#aaaaaa" />
                            <StackPanel Spacing="4">
                                <TextBlock Text="Row Definitions (e.g. Auto,*,2*)" FontSize="9" Foreground="#888888" />
                                <TextBox Text="{Binding Designer.RowDefinitions, Mode=TwoWay}" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Column Definitions (e.g. Auto,*,2*)" FontSize="9" Foreground="#888888" />
                                <TextBox Text="{Binding Designer.ColumnDefinitions, Mode=TwoWay}" FontSize="11" Height="24" Padding="4,2" BorderThickness="1" BorderBrush="#333333" Background="#1e1e1e"/>
                            </StackPanel>
                            <Button Content="Apply Definitions"
                                    Command="{Binding Designer.ApplyGridDefinitionsCommand}"
                                    HorizontalAlignment="Stretch" Height="24" Padding="0"
                                    Background="#1e1e1e" BorderThickness="1" BorderBrush="#333333"
                                    FontSize="10" Foreground="#cccccc" />
                        </StackPanel>
                        
                        <!-- StackPanel Editor -->
                        <StackPanel Spacing="6" IsVisible="{Binding Designer.ShowStackPanelReorderEditor}">
                            <TextBlock Text="StackPanel Order" FontSize="10" FontWeight="SemiBold" Foreground="#aaaaaa" />
                            <Grid ColumnDefinitions="*,6,*">
                                <Button Grid.Column="0" Content="Move Up"
                                        Command="{Binding Designer.MoveChildUpCommand}"
                                        HorizontalAlignment="Stretch" Height="24" Padding="0"
                                        Background="#1e1e1e" BorderThickness="1" BorderBrush="#333333"
                                        FontSize="10" Foreground="#cccccc" />
                                <Button Grid.Column="2" Content="Move Down"
                                        Command="{Binding Designer.MoveChildDownCommand}"
                                        HorizontalAlignment="Stretch" Height="24" Padding="0"
                                        Background="#1e1e1e" BorderThickness="1" BorderBrush="#333333"
                                        FontSize="10" Foreground="#cccccc" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                    
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
