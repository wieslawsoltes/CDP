<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CdpInspectorApp.ViewModels"
             x:Class="CdpInspectorApp.Views.ConnectionToolbar"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="True">
    <Border Background="#292a2d" BorderBrush="#3c4043" BorderThickness="0,0,0,1" Padding="15,8">
        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
            <!-- Hidden Hamburger Toggle Button (maintained for automation compatibility) -->
            <ToggleButton Name="btnTogglePreview"
                           IsChecked="{Binding IsPreviewPanelVisible, Mode=TwoWay}"
                           IsVisible="False"/>

            <!-- Group 2: Host -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,12,4">
                <TextBlock Text="Host:" VerticalAlignment="Center" Foreground="#9aa0a6" Margin="0,0,6,0"/>
                <AutoCompleteBox Name="txtHost"
                                 Text="{Binding Connection.HostAddress, Mode=TwoWay}"
                                 ItemsSource="{Binding Connection.SuggestedHosts}"
                                 FilterMode="None"
                                 MinimumPrefixLength="0"
                                 Width="170" Height="28"
                                 PlaceholderText="e.g. http://localhost:9222"/>
            </StackPanel>

            <!-- Group 3: Target scanning -->
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,4,12,4">
                <Button Name="btnRefreshTargets" Command="{Binding Connection.RefreshTargetsCommand}" ToolTip.Tip="Scan Targets" Classes="accent" Height="28" Width="30" Padding="0" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource RefreshIcon}" Width="13" Height="13"/>
                </Button>
                <TextBox Name="txtTargetSearch" Text="{Binding Connection.TargetSearchText, Mode=TwoWay}" Watermark="Search..." Width="120" Height="28" VerticalContentAlignment="Center" Background="#202124" BorderBrush="#3c4043"/>
                <ComboBox Name="cbTargets" ItemsSource="{Binding Connection.FilteredTargets}" SelectedItem="{Binding Connection.SelectedTarget, Mode=TwoWay}" Width="240" PlaceholderText="Select target window..." Height="28" Background="#202124" BorderBrush="#3c4043"/>
            </StackPanel>

            <!-- Group 4: Connection actions -->
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,4,0,4">
                <Button Name="btnConnect" Command="{Binding Connection.ConnectCommand}" ToolTip.Tip="Connect" Background="#1b5e20" Foreground="White" BorderBrush="#1b5e20" Height="28" Width="30" Padding="0" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource LinkIcon}" Width="13" Height="13"/>
                </Button>
                <Button Name="btnDisconnect" Command="{Binding Connection.DisconnectCommand}" ToolTip.Tip="Disconnect" Background="#b71c1c" Foreground="White" BorderBrush="#b71c1c" Height="28" Width="30" Padding="0" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource DismissIcon}" Width="13" Height="13"/>
                </Button>
                <ToggleButton Name="btnInspect" IsChecked="{Binding Connection.IsInspectModeActive, Mode=TwoWay}" IsEnabled="{Binding Connection.IsConnected}" ToolTip.Tip="Select Element" Background="#e65100" Foreground="White" BorderBrush="#e65100" Height="28" Width="30" Padding="0" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource EyeIcon}" Width="13" Height="13"/>
                </ToggleButton>
                <CheckBox Name="chkUseAutomationSelectors" IsChecked="{Binding Connection.UseAutomationSelectors, Mode=TwoWay}" Content="Use Automation Selectors" Foreground="#9aa0a6" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Button Name="btnReload" Command="{Binding Connection.ReloadCommand}" ToolTip.Tip="Reload" Background="#4a148c" Foreground="White" BorderBrush="#4a148c" Height="28" Width="30" Padding="0" VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource RefreshIcon}" Width="13" Height="13"/>
                </Button>
                <TextBlock Name="txtConnectionStatus" Text="{Binding Connection.ConnectionStatusText}" Foreground="{Binding Connection.ConnectionStatusBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>

            <!-- Group 5: SuperSplit Controls -->
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="30,4,0,4">
                <Button Command="{Binding SplitLeftCommand}" ToolTip.Tip="Split Selected Pane Left" Padding="6" Width="28" Height="28">
                    <PathIcon Data="{StaticResource ArrowLeftIcon}" Width="12" Height="12"/>
                </Button>
                <Button Command="{Binding SplitRightCommand}" ToolTip.Tip="Split Selected Pane Right" Padding="6" Width="28" Height="28">
                    <PathIcon Data="{StaticResource ArrowRightIcon}" Width="12" Height="12"/>
                </Button>
                <Button Command="{Binding SplitUpCommand}" ToolTip.Tip="Split Selected Pane Up" Padding="6" Width="28" Height="28">
                    <PathIcon Data="{StaticResource ArrowUpIcon}" Width="12" Height="12"/>
                </Button>
                <Button Command="{Binding SplitDownCommand}" ToolTip.Tip="Split Selected Pane Down" Padding="6" Width="28" Height="28">
                    <PathIcon Data="{StaticResource ArrowDownIcon}" Width="12" Height="12"/>
                </Button>
                <Button Command="{Binding ClosePaneCommand}" ToolTip.Tip="Close Selected Pane" Padding="6" Width="28" Height="28" Foreground="#ff5252">
                    <PathIcon Data="{StaticResource DismissIcon}" Width="12" Height="12"/>
                </Button>
                <Button Command="{Binding ResetLayoutCommand}" ToolTip.Tip="Reset Split Layout" Padding="6" Width="28" Height="28" Foreground="#4caf50">
                    <PathIcon Data="{StaticResource ArrowUndoIcon}" Width="12" Height="12"/>
                </Button>
            </StackPanel>
        </WrapPanel>
    </Border>
</UserControl>
