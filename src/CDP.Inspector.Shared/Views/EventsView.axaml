<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CdpInspectorApp.ViewModels"
             x:Class="CdpInspectorApp.Views.EventsView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="True">
    <Grid RowDefinitions="Auto, *" Margin="10">
        <!-- Filter and Action Toolbar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, Auto, Auto, *, Auto" Margin="0,0,0,8">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <Button Content="Clear Log" Command="{Binding Events.ClearEventsCommand}" Padding="12,6"/>
                <ToggleButton Content="Pause Logging" IsChecked="{Binding Events.IsPaused, Mode=TwoWay}" Padding="12,6"/>
            </StackPanel>
            
            <CheckBox Grid.Column="1" Content="Ignore Page.screencastFrame" IsChecked="{Binding Events.IgnoreScreencast, Mode=TwoWay}" Margin="16,0,0,0" VerticalAlignment="Center"/>

            <TextBox Grid.Column="3" Text="{Binding Events.SearchQuery, Mode=TwoWay}" Watermark="Filter events by method or payload..." Margin="16,0,0,0" VerticalAlignment="Center"/>
        </Grid>

        <!-- Main Workspace split into List (Left) and Detailed Payload (Right) -->
        <Grid Grid.Row="1" ColumnDefinitions="*, 4, 1.5*">
            <!-- Left Column: DataGrid of Events -->
            <DataGrid Grid.Column="0" ItemsSource="{Binding Events.FilteredEvents}" SelectedItem="{Binding Events.SelectedEvent, Mode=TwoWay}" CanUserResizeColumns="True" GridLinesVisibility="All" Background="#292a2d">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="110" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="*" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Column Splitter -->
            <GridSplitter Grid.Column="1" Background="#1f1f1f" ResizeDirection="Columns"/>

            <!-- Right Column: Formatted JSON Payload Details -->
            <Grid Grid.Column="2" RowDefinitions="Auto, *" Margin="8,0,0,0">
                <TextBlock Grid.Row="0" Text="Event Parameter Payload" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#8ab4f8"/>
                <Border Grid.Row="1" Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4" Padding="6">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <TextBox Text="{Binding Events.SelectedEventPayload}" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Courier New,Consolas,Monospace" Background="Transparent" BorderThickness="0" SelectionBrush="#8ab4f8"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
