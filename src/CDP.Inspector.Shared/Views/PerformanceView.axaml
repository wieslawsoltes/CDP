<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CdpInspectorApp.ViewModels"
             xmlns:models="clr-namespace:CdpInspectorApp.Models;assembly=CDP.Inspector.Shared"
             xmlns:controls="clr-namespace:CdpInspectorApp.Controls"
             x:Class="CdpInspectorApp.Views.PerformanceView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="True">
    <Grid ColumnDefinitions="*, 4, *" RowDefinitions="*, 4, *" Margin="10">
        <!-- Stats (Top Left) -->
        <Grid Grid.Row="0" Grid.Column="0" RowDefinitions="Auto, *" Margin="0,0,10,0">
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                <Button Name="btnRefreshMetrics" Command="{Binding Performance.RefreshMetricsCommand}" Content="Refresh Metrics" Classes="accent"/>
                <Button Name="btnCollectGarbage" Command="{Binding Performance.CollectGarbageCommand}" Content="Collect Garbage" Background="#2e7d32" Foreground="White" BorderBrush="#2e7d32"/>
            </StackPanel>
            <ScrollViewer Grid.Row="1">
                <StackPanel Spacing="12" Margin="0,5,0,0">
                    <TextBlock Text="Diagnostics Info" FontSize="14" FontWeight="Bold" Foreground="#e8eaed" Margin="0,0,0,5"/>
                    <Grid ColumnDefinitions="150, *">
                        <TextBlock Text="Visual Nodes:" Foreground="#9aa0a6"/>
                        <TextBlock Name="lblPerfNodes" Grid.Column="1" Text="{Binding Performance.PerfNodesText}" FontWeight="Bold" Foreground="#e8eaed"/>
                    </Grid>
                    <Grid ColumnDefinitions="150, *">
                        <TextBlock Text="Target Windows:" Foreground="#9aa0a6"/>
                        <TextBlock Name="lblPerfDocuments" Grid.Column="1" Text="{Binding Performance.PerfDocumentsText}" FontWeight="Bold" Foreground="#e8eaed"/>
                    </Grid>
                    <Grid ColumnDefinitions="150, *">
                        <TextBlock Text="Working Set Size:" Foreground="#9aa0a6"/>
                        <TextBlock Name="lblPerfMemory" Grid.Column="1" Text="{Binding Performance.PerfMemoryText}" FontWeight="Bold" Foreground="#e8eaed"/>
                    </Grid>
                    <Grid ColumnDefinitions="150, *">
                        <TextBlock Text="GC Total Memory:" Foreground="#9aa0a6"/>
                        <TextBlock Name="lblPerfGc" Grid.Column="1" Text="{Binding Performance.PerfGcText}" FontWeight="Bold" Foreground="#e8eaed"/>
                    </Grid>
                    <Grid ColumnDefinitions="150, *">
                        <TextBlock Text="Process PID:" Foreground="#9aa0a6"/>
                        <TextBlock Name="lblPerfPid" Grid.Column="1" Text="{Binding Performance.PerfPidText}" FontWeight="Bold" Foreground="#e8eaed"/>
                    </Grid>
                    <Grid ColumnDefinitions="150, *">
                        <TextBlock Text="Operating System:" Foreground="#9aa0a6"/>
                        <TextBlock Name="lblPerfOs" Grid.Column="1" Text="{Binding Performance.PerfOsText}" TextWrapping="Wrap" Foreground="#e8eaed"/>
                    </Grid>
                    <Grid ColumnDefinitions="150, *">
                        <TextBlock Text="CPU Usage:" Foreground="#9aa0a6"/>
                        <TextBlock Name="lblPerfCpu" Grid.Column="1" Text="{Binding Performance.PerfCpuText}" FontWeight="Bold" Foreground="#e8eaed"/>
                    </Grid>
                    <Grid ColumnDefinitions="150, *">
                        <TextBlock Text="Frame Rate (FPS):" Foreground="#9aa0a6"/>
                        <TextBlock Name="lblPerfFps" Grid.Column="1" Text="{Binding Performance.PerfFpsText}" FontWeight="Bold" Foreground="#e8eaed"/>
                    </Grid>
                    <Grid ColumnDefinitions="150, *">
                        <TextBlock Text="Frame Duration:" Foreground="#9aa0a6"/>
                        <TextBlock Name="lblPerfFrameDuration" Grid.Column="1" Text="{Binding Performance.PerfFrameDurationText}" FontWeight="Bold" Foreground="#e8eaed"/>
                    </Grid>
                    <Grid ColumnDefinitions="150, *">
                        <TextBlock Text="Layout passes:" Foreground="#9aa0a6"/>
                        <TextBlock Name="lblPerfLayoutCount" Grid.Column="1" Text="{Binding Performance.PerfLayoutCountText}" FontWeight="Bold" Foreground="#e8eaed"/>
                    </Grid>
                    <Grid ColumnDefinitions="150, *">
                        <TextBlock Text="Layout duration:" Foreground="#9aa0a6"/>
                        <TextBlock Name="lblPerfLayoutDuration" Grid.Column="1" Text="{Binding Performance.PerfLayoutDurationText}" FontWeight="Bold" Foreground="#e8eaed"/>
                    </Grid>
                    <Grid ColumnDefinitions="150, *">
                        <TextBlock Text="Dispatcher Delay:" Foreground="#9aa0a6"/>
                        <TextBlock Name="lblPerfQueueDelay" Grid.Column="1" Text="{Binding Performance.PerfQueueDelayText}" FontWeight="Bold" Foreground="#e8eaed"/>
                    </Grid>
                    <Grid ColumnDefinitions="150, *">
                        <TextBlock Text="UI Thread Blocking:" Foreground="#9aa0a6"/>
                        <TextBlock Name="lblPerfBlockingTime" Grid.Column="1" Text="{Binding Performance.PerfBlockingTimeText}" FontWeight="Bold" Foreground="#e8eaed"/>
                    </Grid>
                    <Button Name="btnCloseTarget" Command="{Binding Performance.CloseTargetCommand}" Content="Kill Target App" Background="#c5221f" Foreground="White" BorderBrush="#c5221f" Margin="0,15,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Chart (Top Right) -->
        <Grid Grid.Row="0" Grid.Column="2" RowDefinitions="Auto, *" Margin="10,0,0,0">
            <TextBlock Text="Performance Monitor" Classes="panel-header"/>
            <ScrollViewer Grid.Row="1">
                <StackPanel Spacing="10" Margin="0,0,10,0">
                    <Border Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" ClipToBounds="True">
                        <controls:ChromeTimelineChart StrokeColor="#ff9800" FillColor="#ff9800" Unit="%" MaxDisplayValue="100.0" Height="65" History="{Binding Performance.CpuHistory}"/>
                    </Border>
                    <Border Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" ClipToBounds="True">
                        <controls:ChromeTimelineChart StrokeColor="#4caf50" FillColor="#4caf50" Unit="FPS" MaxDisplayValue="60.0" Height="65" History="{Binding Performance.FpsHistory}"/>
                    </Border>
                    <Border Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" ClipToBounds="True">
                        <controls:ChromeTimelineChart StrokeColor="#2196f3" FillColor="#2196f3" Unit="MB" Height="65" History="{Binding Performance.MemoryHistory}"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <GridSplitter Grid.Row="1" Grid.ColumnSpan="3" Background="#3c4043"/>

        <!-- Visual Leaks counts (Bottom Half) -->
        <Grid Grid.Row="2" Grid.ColumnSpan="3" RowDefinitions="Auto, *" Margin="0,10,0,0">
            <TextBlock Text="Live Control Type Counts in Memory" Classes="panel-header"/>
            <DataGrid Name="lstLiveControls" ItemsSource="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).Performance.LiveControls}" Grid.Row="1" x:DataType="models:ControlCountModel"
                      CanUserReorderRows="False" CanUserResizeColumns="True" CanUserSortColumns="True" IsReadOnly="True"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      Background="Transparent" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Control Type" Binding="{Binding Type}" Width="*" Foreground="#e8eaed" FontSize="12" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Live Instances Count" Binding="{Binding Count}" Width="150" Foreground="#8ab4f8" FontSize="12" FontWeight="Bold"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
