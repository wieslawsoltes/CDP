        <StreamGeometry x:Key="FlowchartIcon">M5.24756 2.99609C4.00492 2.99609 2.99756 4.00345 2.99756 5.24609L2.99756 7.75337C2.99756 8.99601 4.00492 10.0034 5.24756 10.0034H5.75V13.7096C5.7033 13.7446 5.65849 13.7834 5.61599 13.8259L2.82378 16.6172C2.33547 17.1053 2.33542 17.897 2.82368 18.3852L5.61589 21.1771C6.10412 21.6652 6.89569 21.6651 7.3838 21.1768L10.1745 18.3849C10.217 18.3424 10.2557 18.2977 10.2908 18.251H14.0049V18.7547C14.0049 19.9973 15.0122 21.0047 16.2549 21.0047H18.7488C19.9914 21.0047 20.9988 19.9973 20.9988 18.7547V16.2505C20.9988 15.0078 19.9914 14.0005 18.7488 14.0005H16.2549C15.0122 14.0005 14.0049 15.0078 14.0049 16.2505V16.751H10.2904C10.2554 16.7044 10.2168 16.6598 10.1744 16.6174L7.3837 13.8262C7.34129 13.7838 7.29659 13.745 7.25 13.71V10.0034H7.75456C8.9972 10.0034 10.0046 8.99601 10.0046 7.75337V5.24609C10.0046 4.00345 8.9972 2.99609 7.75456 2.99609H5.24756ZM4.49756 5.24609C4.49756 4.83188 4.83334 4.49609 5.24756 4.49609H7.75456C8.16877 4.49609 8.50456 4.83188 8.50456 5.24609V7.75337C8.50456 8.16758 8.16877 8.50337 7.75456 8.50337H5.24756C4.83334 8.50337 4.49756 8.16758 4.49756 7.75337L4.49756 5.24609ZM4.06111 17.5012L6.49968 15.0635L8.93693 17.5012L6.49968 19.9396L4.06111 17.5012ZM16.2549 15.5005H18.7488C19.163 15.5005 19.4988 15.8363 19.4988 16.2505V18.7547C19.4988 19.1689 19.163 19.5047 18.7488 19.5047H16.2549C15.8407 19.5047 15.5049 19.1689 15.5049 18.7547V16.2505C15.5049 15.8363 15.8407 15.5005 16.2549 15.5005Z</StreamGeometry>
    </Styles.Resources>
    <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
    <StyleInclude Source="avares://CDP.Editor.Minimap/Themes/Generic.axaml" />

    <!-- TabControl Panels styling matching Chrome DevTools tabs bar -->
    <Style Selector="TabControl">
        <Setter Property="Background" Value="#202124"/>
    </Style>
    <Style Selector="TabItem">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="#9aa0a6"/>
        <Setter Property="Padding" Value="16,8"/>
    </Style>
    <Style Selector="TabItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="#e8eaed"/>
    </Style>
    <Style Selector="TabItem:selected">
        <Setter Property="Foreground" Value="#8ab4f8"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="TabItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="#8ab4f8"/>
    </Style>

    <!-- Borders and Card styles matching Chrome DevTools lines/margins -->
    <Style Selector="Border.panel-card">
        <Setter Property="Background" Value="#292a2d"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <!-- TextBlocks -->
    <Style Selector="TextBlock.panel-header">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#e8eaed"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- Form fields and list boxes with Chrome DevTools Dark colors -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="#202124"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="Foreground" Value="#e8eaed"/>
        <Setter Property="CaretBrush" Value="#e8eaed"/>
        <Setter Property="SelectionBrush" Value="#3f5f8f"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="ListBox">
        <Setter Property="Background" Value="#292a2d"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="Foreground" Value="#e8eaed"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Chrome styled buttons -->
    <Style Selector="Button">
        <Setter Property="Background" Value="#35363a"/>
        <Setter Property="Foreground" Value="#e8eaed"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#494c50"/>
        <Setter Property="Foreground" Value="#ffffff"/>
        <Setter Property="BorderBrush" Value="#494c50"/>
    </Style>
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="#1a73e8"/>
        <Setter Property="Foreground" Value="#ffffff"/>
        <Setter Property="BorderBrush" Value="#1a73e8"/>
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#1557b0"/>
        <Setter Property="Foreground" Value="#ffffff"/>
        <Setter Property="BorderBrush" Value="#1557b0"/>
    </Style>
    <Style Selector="ToggleButton">
        <Setter Property="Background" Value="#35363a"/>
        <Setter Property="Foreground" Value="#e8eaed"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>

    <!-- Fix for ProDataGrid Hierarchical expander ToggleButton inheriting global ToggleButton styles -->
    <Style Selector="DataGrid ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
    </Style>
    <Style Selector="DataGrid ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="DataGrid ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="DataGrid ToggleButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <!-- Accordion Styling -->
    <Style Selector="controls|Accordion">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ItemsPresenter ItemsPanel="{TemplateBinding ItemsPanel}"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- AccordionItem Styling -->
    <Style Selector="controls|AccordionItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <Grid RowDefinitions="Auto, *">
                        <!-- Header Toggle Button -->
                        <ToggleButton Name="PART_HeaderButton"
                                      Grid.Row="0"
                                      IsChecked="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsExpanded, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      Background="#2d2d2d"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      Padding="8,6"
                                      CornerRadius="0">
                            <ToggleButton.Styles>
                                <Style Selector="ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="#35363a"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Style>
                                <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="#252526"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#8ab4f8"/>
                                </Style>
                                <Style Selector="ToggleButton TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Foreground" Value="#e8eaed"/>
                                </Style>
                                <Style Selector="ToggleButton:checked TextBlock">
                                    <Setter Property="Foreground" Value="#8ab4f8"/>
                                </Style>
                            </ToggleButton.Styles>
                            <Grid ColumnDefinitions="*, Auto">
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding Header}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                  VerticalAlignment="Center"/>
                                <PathIcon Grid.Column="1"
                                          Data="{StaticResource ChevronDownIcon}"
                                          Width="10"
                                          Height="10"
                                          Foreground="#9aa0a6"
                                          VerticalAlignment="Center">
                                    <PathIcon.Transitions>
                                        <Transitions>
                                            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
                                        </Transitions>
                                    </PathIcon.Transitions>
                                </PathIcon>
                            </Grid>
                        </ToggleButton>
                        
                        <!-- Content Border -->
                        <Border Grid.Row="1"
                                Name="PART_ContentBorder"
                                Background="#202124"
                                IsVisible="{TemplateBinding IsExpanded}">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Padding="8,4,8,8"/>
                        </Border>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="controls|AccordionItem /template/ PathIcon">
        <Setter Property="RenderTransform" Value="rotate(0deg)"/>
    </Style>
    <Style Selector="controls|AccordionItem[IsExpanded=true] /template/ PathIcon">
        <Setter Property="RenderTransform" Value="rotate(180deg)"/>
        <Setter Property="Foreground" Value="#8ab4f8"/>
    </Style>

    <!-- Remove border on the very last AccordionItem -->
    <Style Selector="controls|Accordion > controls|AccordionItem:nth-last-child(1)">
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- EditableComboBox Styling -->
    <Style Selector="controls|EditableComboBox">
        <Setter Property="Background" Value="#2d2d2d"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Name="PART_RootGrid" ColumnDefinitions="*,Auto">
                    <!-- Dropdown Toggle Button under the text box for full clickability -->
                    <ToggleButton Name="PART_ToggleButton"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="2"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  CornerRadius="{TemplateBinding CornerRadius}"
                                  IsChecked="{Binding $parent[controls:EditableComboBox].IsDropDownOpen, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  HorizontalContentAlignment="Right"
                                  Padding="0,0,10,0"
                                  ClickMode="Release"
                                  ZIndex="0">
                        <ToggleButton.Template>
                            <ControlTemplate>
                                <Border Name="templateRoot"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="{TemplateBinding CornerRadius}">
                                    <Grid HorizontalAlignment="Right" VerticalAlignment="Center" Width="30">
                                        <PathIcon Data="{StaticResource ChevronDownIcon}"
                                                  Width="8"
                                                  Height="8"
                                                  Foreground="#9aa0a6"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>

                    <!-- Editable TextBox overlay on the left -->
                    <TextBox Name="PART_EditableTextBox"
                             Grid.Column="0"
                             Text="{Binding $parent[controls:EditableComboBox].Text, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{TemplateBinding Foreground}"
                             Padding="{TemplateBinding Padding}"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Stretch"
                             Margin="2,2,30,2"
                             ZIndex="1"/>

                    <!-- Popup list -->
                    <Popup Name="PART_Popup"
                           Grid.Column="0"
                           IsOpen="{TemplateBinding IsDropDownOpen, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=PART_ToggleButton}"
                           Placement="Bottom"
                           IsLightDismissEnabled="True">
                        <Border Background="#2a2a2b"
                                BorderBrush="#3c4043"
                                BorderThickness="1"
                                CornerRadius="4"
                                MinWidth="{Binding ElementName=PART_ToggleButton, Path=Bounds.Width}"
                                Margin="0,4,0,4">
                            <ScrollViewer MaxHeight="300">
                                <ItemsPresenter Name="PART_ItemsPresenter"
                                                ItemsPanel="{TemplateBinding ItemsPanel}"/>
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="controls|EditableComboBox:focus-within /template/ ToggleButton#PART_ToggleButton">
        <Setter Property="BorderBrush" Value="#8ab4f8"/>
    </Style>

    <!-- AutoCompleteBox Vertical Alignment Fixes -->
    <Style Selector="AutoCompleteBox">
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="AutoCompleteBox /template/ TextBox">
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Padding" Value="4,0"/>
    </Style>

</Styles>
