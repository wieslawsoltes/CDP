        <StreamGeometry x:Key="NavigationIcon">M2.75254 17.9997H21.2525C21.6668 17.9997 22.0025 18.3355 22.0025 18.7497C22.0025 19.1294 21.7204 19.4432 21.3543 19.4928L21.2525 19.4997H2.75254C2.33832 19.4997 2.00254 19.1639 2.00254 18.7497C2.00254 18.37 2.28469 18.0562 2.65077 18.0065L2.75254 17.9997H21.2525H2.75254ZM2.75254 11.5027H21.2525C21.6668 11.5027 22.0025 11.8385 22.0025 12.2527C22.0025 12.6324 21.7204 12.9462 21.3543 12.9959L21.2525 13.0027H2.75254C2.33832 13.0027 2.00168 12.6669 2.00168 12.2527C2.00168 11.873 2.28383 11.5592 2.64991 11.5095L2.75254 11.5027H21.2525H2.75254ZM2.75168 5.00293H21.2517C21.6659 5.00293 22.0017 5.33872 22.0017 5.75293C22.0017 6.13263 21.7195 6.44642 21.3535 6.49608L21.2517 6.50293H2.75168C2.33746 6.50293 2.00168 6.16714 2.00168 5.75293C2.00168 5.37323 2.28383 5.05944 2.64991 5.00978L2.75168 5.00293H21.2517H2.75168ZM2.75254 17.9997Z</StreamGeometry>
        <StreamGeometry x:Key="DiagramIcon">M2 5.25C2 3.45507 3.45507 2 5.25 2H15.75C17.5449 2 19 3.45507 19 5.25V11.2831C18.6263 11.099 18.2113 11 17.7848 11H17.5V5.25C17.5 4.2835 16.7165 3.5 15.75 3.5H5.25C4.2835 3.5 3.5 4.2835 3.5 5.25V16.75C3.5 17.7165 4.2835 18.5 5.25 18.5H8.62007L7.35691 20H5.25C3.45508 20 2 18.5449 2 16.75V5.25ZM6.75 6C6.33579 6 6 6.33579 6 6.75C6 7.16421 6.33579 7.5 6.75 7.5H14.25C14.6642 7.5 15 7.16421 15 6.75C15 6.33579 14.25 6 14.25 6H6.75ZM7.06999 12.4336C7.19304 12.1691 7.45829 12 7.75 12H17.7848C18.301 12 18.7908 12.2279 19.1234 12.6228L22.8237 17.0169C23.0588 17.2961 23.0588 17.7039 22.8237 17.9831L19.1234 22.3772C18.7908 22.7721 18.301 23 17.7848 23H7.75C7.45829 23 7.19304 22.8309 7.06999 22.5664C6.94694 22.3019 6.98841 21.99 7.17632 21.7669L10.7695 17.5L7.17632 13.2331C6.98841 13.01 6.94694 12.6981 7.06999 12.4336ZM9.36208 13.5L12.3237 17.0169C12.5588 17.2961 12.5588 17.7039 12.3237 17.9831L9.36208 21.5H17.7848C17.8585 21.5 17.9285 21.4674 17.976 21.411L21.2695 17.5L17.976 13.589C17.9285 13.5326 17.8585 13.5 17.7848 13.5H9.36208ZM6.75 9C6.33579 9 6 9.33579 6 9.75C6 10.1642 6.33579 10.5 6.75 10.5H11.25C11.6642 10.5 12 10.1642 12 9.75C12 9.33579 11.6642 9 11.25 9H6.75Z</StreamGeometry>
    </Styles.Resources>
    <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
    <StyleInclude Source="avares://CDP.Editor.Minimap/Themes/Generic.axaml" />

    <!-- TabControl Panels styling matching Chrome DevTools tabs bar -->
    <Style Selector="TabControl">
        <Setter Property="Background" Value="#202124"/>
    </Style>
    <Style Selector="TabItem">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="#9aa0a6"/>
        <Setter Property="Padding" Value="12,6"/>
    </Style>
    <Style Selector="TabItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="#e8eaed"/>
    </Style>
    <Style Selector="TabItem:selected">
        <Setter Property="Foreground" Value="#8ab4f8"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="TabItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="#8ab4f8"/>
    </Style>
    <!-- Target the selected highlight pipe in Fluent Theme TabItem template -->
    <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
        <Setter Property="Background" Value="#8ab4f8"/>
        <Setter Property="Height" Value="2"/>
    </Style>

    <!-- ScrollBar styling matching Chrome DevTools slim scrollbars -->
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ScrollBar:vertical">
        <Setter Property="Width" Value="8"/>
    </Style>
    <Style Selector="ScrollBar:horizontal">
        <Setter Property="Height" Value="8"/>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="#3c4043"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector="ScrollBar:pointerover /template/ Thumb">
        <Setter Property="Background" Value="#5f6368"/>
    </Style>
    <Style Selector="ScrollBar /template/ RepeatButton">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- DataGrid Customizations matching Chrome DevTools grids -->
    <Style Selector="DataGrid">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#3c4043"/>
    </Style>
    <Style Selector="DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="DataGridRow:nth-child(2n)">
        <Setter Property="Background" Value="#252629"/>
    </Style>
    <Style Selector="DataGridColumnHeader">
        <Setter Property="Background" Value="#202124"/>
        <Setter Property="Foreground" Value="#9aa0a6"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>
    <Style Selector="DataGridColumnHeader:pointerover /template/ Grid">
        <Setter Property="Background" Value="#2d2e30"/>
    </Style>
    <Style Selector="DataGridRow:selected">
        <Setter Property="Background" Value="#353a45"/>
    </Style>


    <!-- Borders and Card styles matching Chrome DevTools lines/margins -->
    <Style Selector="Border.panel-card">
        <Setter Property="Background" Value="#292a2d"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <!-- TextBlocks -->
    <Style Selector="TextBlock.panel-header">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#e8eaed"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- Form fields and list boxes with Chrome DevTools Dark colors -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="#202124"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="Foreground" Value="#e8eaed"/>
        <Setter Property="CaretBrush" Value="#e8eaed"/>
        <Setter Property="SelectionBrush" Value="#3f5f8f"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="ListBox">
        <Setter Property="Background" Value="#292a2d"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="Foreground" Value="#e8eaed"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Chrome styled buttons -->
    <Style Selector="Button">
        <Setter Property="Background" Value="#35363a"/>
        <Setter Property="Foreground" Value="#e8eaed"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#494c50"/>
        <Setter Property="Foreground" Value="#ffffff"/>
        <Setter Property="BorderBrush" Value="#494c50"/>
    </Style>
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="#1a73e8"/>
        <Setter Property="Foreground" Value="#ffffff"/>
        <Setter Property="BorderBrush" Value="#1a73e8"/>
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#1557b0"/>
        <Setter Property="Foreground" Value="#ffffff"/>
        <Setter Property="BorderBrush" Value="#1557b0"/>
    </Style>
    <Style Selector="ToggleButton">
        <Setter Property="Background" Value="#35363a"/>
        <Setter Property="Foreground" Value="#e8eaed"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>

    <!-- Fix for ProDataGrid Hierarchical expander ToggleButton inheriting global ToggleButton styles -->
    <Style Selector="DataGrid ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
    </Style>
    <Style Selector="DataGrid ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="DataGrid ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="DataGrid ToggleButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <!-- Accordion Styling -->
    <Style Selector="controls|Accordion">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <ItemsPresenter ItemsPanel="{TemplateBinding ItemsPanel}"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- AccordionItem Styling -->
    <Style Selector="controls|AccordionItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <Grid RowDefinitions="Auto, *">
                        <!-- Header Toggle Button -->
                        <ToggleButton Name="PART_HeaderButton"
                                      Grid.Row="0"
                                      IsChecked="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsExpanded, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      Background="#2d2d2d"
                                      BorderBrush="Transparent"
                                      BorderThickness="0"
                                      Padding="8,6"
                                      CornerRadius="0">
                            <ToggleButton.Styles>
                                <Style Selector="ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="#35363a"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Style>
                                <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                                    <Setter Property="Background" Value="#252526"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#8ab4f8"/>
                                </Style>
                                <Style Selector="ToggleButton TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Foreground" Value="#e8eaed"/>
                                </Style>
                                <Style Selector="ToggleButton:checked TextBlock">
                                    <Setter Property="Foreground" Value="#8ab4f8"/>
                                </Style>
                            </ToggleButton.Styles>
                            <Grid ColumnDefinitions="*, Auto">
                                <ContentPresenter Grid.Column="0"
                                                  Content="{TemplateBinding Header}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                  VerticalAlignment="Center"/>
                                <PathIcon Grid.Column="1"
                                          Data="{StaticResource ChevronDownIcon}"
                                          Width="10"
                                          Height="10"
                                          Foreground="#9aa0a6"
                                          VerticalAlignment="Center">
                                    <PathIcon.Transitions>
                                        <Transitions>
                                            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
                                        </Transitions>
                                    </PathIcon.Transitions>
                                </PathIcon>
                            </Grid>
                        </ToggleButton>
                        
                        <!-- Content Border -->
                        <Border Grid.Row="1"
                                Name="PART_ContentBorder"
                                Background="#202124"
                                IsVisible="{TemplateBinding IsExpanded}">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Padding="8,4,8,8"/>
                        </Border>
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="controls|AccordionItem /template/ PathIcon">
        <Setter Property="RenderTransform" Value="rotate(0deg)"/>
    </Style>
    <Style Selector="controls|AccordionItem[IsExpanded=true] /template/ PathIcon">
        <Setter Property="RenderTransform" Value="rotate(180deg)"/>
        <Setter Property="Foreground" Value="#8ab4f8"/>
    </Style>

    <!-- Remove border on the very last AccordionItem -->
    <Style Selector="controls|Accordion > controls|AccordionItem:nth-last-child(1)">
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- EditableComboBox Styling -->
    <Style Selector="controls|EditableComboBox">
        <Setter Property="Background" Value="#2d2d2d"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Grid Name="PART_RootGrid" ColumnDefinitions="*,Auto">
                    <!-- Dropdown Toggle Button under the text box for full clickability -->
                    <ToggleButton Name="PART_ToggleButton"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="2"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}"
                                  CornerRadius="{TemplateBinding CornerRadius}"
                                  IsChecked="{Binding $parent[controls:EditableComboBox].IsDropDownOpen, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  HorizontalContentAlignment="Right"
                                  Padding="0,0,10,0"
                                  ClickMode="Release"
                                  ZIndex="0">
                        <ToggleButton.Template>
                            <ControlTemplate>
                                <Border Name="templateRoot"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="{TemplateBinding CornerRadius}">
                                    <Grid HorizontalAlignment="Right" VerticalAlignment="Center" Width="30">
                                        <PathIcon Data="{StaticResource ChevronDownIcon}"
                                                  Width="8"
                                                  Height="8"
                                                  Foreground="#9aa0a6"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>

                    <!-- Editable TextBox overlay on the left -->
                    <TextBox Name="PART_EditableTextBox"
                             Grid.Column="0"
                             Text="{Binding $parent[controls:EditableComboBox].Text, Mode=TwoWay}"
                             Watermark="{TemplateBinding PlaceholderText}"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{TemplateBinding Foreground}"
                             Padding="{TemplateBinding Padding}"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Stretch"
                             Margin="2,2,30,2"
                             ZIndex="1"/>

                    <!-- Popup list -->
                    <Popup Name="PART_Popup"
                           Grid.Column="0"
                           IsOpen="{TemplateBinding IsDropDownOpen, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=PART_ToggleButton}"
                           Placement="Bottom"
                           IsLightDismissEnabled="True">
                        <Border Background="#2a2a2b"
                                BorderBrush="#3c4043"
                                BorderThickness="1"
                                CornerRadius="4"
                                MinWidth="{Binding ElementName=PART_ToggleButton, Path=Bounds.Width}"
                                Margin="0,4,0,4">
                            <ScrollViewer MaxHeight="300">
                                <ItemsPresenter Name="PART_ItemsPresenter"
                                                ItemsPanel="{TemplateBinding ItemsPanel}"/>
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="controls|EditableComboBox:focus-within /template/ ToggleButton#PART_ToggleButton">
        <Setter Property="BorderBrush" Value="#8ab4f8"/>
    </Style>

    <!-- AutoCompleteBox Vertical Alignment Fixes -->
    <Style Selector="AutoCompleteBox">
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="AutoCompleteBox /template/ TextBox">
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Padding" Value="4,0"/>
    </Style>

    <!-- Activity Bar Button Styling -->
    <Style Selector="Button.activity-btn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="Button.activity-btn PathIcon">
        <Setter Property="Foreground" Value="#858585"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.activity-btn:pointerover PathIcon">
        <Setter Property="Foreground" Value="#cccccc"/>
    </Style>
    <Style Selector="Button.activity-btn.active PathIcon">
        <Setter Property="Foreground" Value="#ffffff"/>
    </Style>

    <!-- Toolbar Small Icon Button Styling -->
    <Style Selector="Button.toolbar-btn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="Button.toolbar-btn:pointerover">
        <Setter Property="Background" Value="#3c3c3c"/>
    </Style>
    <Style Selector="Button.toolbar-btn PathIcon">
        <Setter Property="Foreground" Value="#cccccc"/>
    </Style>
    <Style Selector="Button.toolbar-btn:pointerover PathIcon">
        <Setter Property="Foreground" Value="#ffffff"/>
    </Style>

    <Style Selector="ToggleButton.toolbar-btn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="ToggleButton.toolbar-btn:pointerover">
        <Setter Property="Background" Value="#3c3c3c"/>
    </Style>
    <Style Selector="ToggleButton.toolbar-btn:checked">
        <Setter Property="Background" Value="#37373d"/>
    </Style>
    <Style Selector="ToggleButton.toolbar-btn PathIcon">
        <Setter Property="Foreground" Value="#cccccc"/>
    </Style>
    <Style Selector="ToggleButton.toolbar-btn:checked PathIcon">
        <Setter Property="Foreground" Value="#3794ff"/>
    </Style>

    <!-- ========================================== -->
    <!-- Project Explorer & Workspace Tree Styling  -->
    <!-- ========================================== -->
    <Style Selector="DataGrid#treeWorkspace">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="RowHeight" Value="24"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    </Style>
    <Style Selector="DataGrid#treeWorkspace DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="DataGrid#treeWorkspace DataGridRow:pointerover">
        <Setter Property="Background" Value="#2a2d2e"/>
    </Style>
    <Style Selector="DataGrid#treeWorkspace DataGridRow:selected">
        <Setter Property="Background" Value="#04395e"/>
    </Style>
    <Style Selector="DataGrid#treeWorkspace DataGridRow:selected:pointerover">
        <Setter Property="Background" Value="#04395e"/>
    </Style>
    <Style Selector="DataGrid#treeWorkspace DataGridCell:selected /template/ Border#PART_CellBorder">
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <!-- Custom inline toggle buttons inside TextBox -->
    <Style Selector="ToggleButton.inline-toggle">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="ToggleButton.inline-toggle:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#35363a"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="ToggleButton.inline-toggle:checked /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#0e639c"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ToggleButton.inline-toggle TextBlock">
        <Setter Property="Foreground" Value="#cccccc"/>
    </Style>
    <Style Selector="ToggleButton.inline-toggle:checked TextBlock">
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- Open Editors ListBox & ListBoxItem custom styles -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="#1e1e1e"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="CornerRadius" Value="2"/>
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#2a2d2e"/>
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#2b2d30"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- Color-coded toolbox buttons -->
    <Style Selector="Button.category-btn">
        <Setter Property="Margin" Value="0,0,4,4"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Background" Value="#2d2d2d"/>
    </Style>
    
    <Style Selector="Button.category-btn-interaction">
        <Setter Property="BorderBrush" Value="#0e639c"/>
        <Setter Property="Foreground" Value="#61afef"/>
    </Style>
    <Style Selector="Button.category-btn-interaction:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#0e639c"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#0e639c"/>
    </Style>
    
    <Style Selector="Button.category-btn-assertion">
        <Setter Property="BorderBrush" Value="#4caf50"/>
        <Setter Property="Foreground" Value="#98c379"/>
    </Style>
    <Style Selector="Button.category-btn-assertion:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#4caf50"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#4caf50"/>
    </Style>
    
    <Style Selector="Button.category-btn-device">
        <Setter Property="BorderBrush" Value="#ab47bc"/>
        <Setter Property="Foreground" Value="#c678dd"/>
    </Style>
    <Style Selector="Button.category-btn-device:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#ab47bc"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#ab47bc"/>
    </Style>
    
    <Style Selector="Button.category-btn-logic">
        <Setter Property="BorderBrush" Value="#ff9800"/>
        <Setter Property="Foreground" Value="#d19a66"/>
    </Style>
    <Style Selector="Button.category-btn-logic:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#ff9800"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#ff9800"/>
    </Style>

</Styles>
