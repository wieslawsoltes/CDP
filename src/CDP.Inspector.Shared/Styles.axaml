    </Styles.Resources>
    <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
    <StyleInclude Source="avares://CDP.Editor.Minimap/Themes/Generic.axaml" />
    <StyleInclude Source="avares://CDP.Inspector.Controls/Themes/Generic.axaml" />

    <!-- TabControl Panels styling matching Chrome DevTools tabs bar -->
    <Style Selector="TabControl">
        <Setter Property="Background" Value="#202124"/>
    </Style>
    <Style Selector="TabItem">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="#9aa0a6"/>
        <Setter Property="Padding" Value="12,6"/>
    </Style>
    <Style Selector="TabItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="#e8eaed"/>
    </Style>
    <Style Selector="TabItem:selected">
        <Setter Property="Foreground" Value="#8ab4f8"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="TabItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="#8ab4f8"/>
    </Style>
    <!-- Target the selected highlight pipe in Fluent Theme TabItem template -->
    <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
        <Setter Property="Background" Value="#8ab4f8"/>
        <Setter Property="Height" Value="2"/>
    </Style>

    <!-- ScrollBar styling matching Chrome DevTools slim scrollbars -->
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ScrollBar:vertical">
        <Setter Property="Width" Value="8"/>
    </Style>
    <Style Selector="ScrollBar:horizontal">
        <Setter Property="Height" Value="8"/>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="#3c4043"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector="ScrollBar:pointerover /template/ Thumb">
        <Setter Property="Background" Value="#5f6368"/>
    </Style>
    <Style Selector="ScrollBar /template/ RepeatButton">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- DataGrid Customizations matching Chrome DevTools grids -->
    <Style Selector="DataGrid">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#3c4043"/>
    </Style>
    <Style Selector="DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="DataGridRow:nth-child(2n)">
        <Setter Property="Background" Value="#252629"/>
    </Style>
    <Style Selector="DataGridColumnHeader">
        <Setter Property="Background" Value="#202124"/>
        <Setter Property="Foreground" Value="#9aa0a6"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>
    <Style Selector="DataGridColumnHeader:pointerover /template/ Grid">
        <Setter Property="Background" Value="#2d2e30"/>
    </Style>
    <Style Selector="DataGridRow:selected">
        <Setter Property="Background" Value="#353a45"/>
    </Style>


    <!-- Borders and Card styles matching Chrome DevTools lines/margins -->
    <Style Selector="Border.panel-card">
        <Setter Property="Background" Value="#292a2d"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <!-- TextBlocks -->
    <Style Selector="TextBlock.panel-header">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#e8eaed"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- Form fields and list boxes with Chrome DevTools Dark colors -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="#202124"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="Foreground" Value="#e8eaed"/>
        <Setter Property="CaretBrush" Value="#e8eaed"/>
        <Setter Property="SelectionBrush" Value="#3f5f8f"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="ListBox">
        <Setter Property="Background" Value="#292a2d"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="Foreground" Value="#e8eaed"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Chrome styled buttons -->
    <Style Selector="Button">
        <Setter Property="Background" Value="#35363a"/>
        <Setter Property="Foreground" Value="#e8eaed"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#494c50"/>
        <Setter Property="Foreground" Value="#ffffff"/>
        <Setter Property="BorderBrush" Value="#494c50"/>
    </Style>
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="#1a73e8"/>
        <Setter Property="Foreground" Value="#ffffff"/>
        <Setter Property="BorderBrush" Value="#1a73e8"/>
    </Style>
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#1557b0"/>
        <Setter Property="Foreground" Value="#ffffff"/>
        <Setter Property="BorderBrush" Value="#1557b0"/>
    </Style>
    <Style Selector="ToggleButton">
        <Setter Property="Background" Value="#35363a"/>
        <Setter Property="Foreground" Value="#e8eaed"/>
        <Setter Property="BorderBrush" Value="#3c4043"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>

    <!-- Fix for ProDataGrid Hierarchical expander ToggleButton inheriting global ToggleButton styles -->
    <Style Selector="DataGrid ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
    </Style>
    <Style Selector="DataGrid ToggleButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="DataGrid ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="DataGrid ToggleButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <!-- Custom controls are styled via Generic.axaml stylesheet include -->

    <!-- AutoCompleteBox Vertical Alignment Fixes -->
    <Style Selector="AutoCompleteBox">
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="AutoCompleteBox /template/ TextBox">
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Padding" Value="4,0"/>
    </Style>

    <!-- Activity Bar Button Styling -->
    <Style Selector="Button.activity-btn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="Button.activity-btn PathIcon">
        <Setter Property="Foreground" Value="#858585"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.15"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.activity-btn:pointerover PathIcon">
        <Setter Property="Foreground" Value="#cccccc"/>
    </Style>
    <Style Selector="Button.activity-btn.active PathIcon">
        <Setter Property="Foreground" Value="#ffffff"/>
    </Style>

    <!-- Toolbar Small Icon Button Styling -->
    <Style Selector="Button.toolbar-btn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="Button.toolbar-btn:pointerover">
        <Setter Property="Background" Value="#3c3c3c"/>
    </Style>
    <Style Selector="Button.toolbar-btn PathIcon">
        <Setter Property="Foreground" Value="#cccccc"/>
    </Style>
    <Style Selector="Button.toolbar-btn:pointerover PathIcon">
        <Setter Property="Foreground" Value="#ffffff"/>
    </Style>

    <Style Selector="ToggleButton.toolbar-btn">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="ToggleButton.toolbar-btn:pointerover">
        <Setter Property="Background" Value="#3c3c3c"/>
    </Style>
    <Style Selector="ToggleButton.toolbar-btn:checked">
        <Setter Property="Background" Value="#37373d"/>
    </Style>
    <Style Selector="ToggleButton.toolbar-btn PathIcon">
        <Setter Property="Foreground" Value="#cccccc"/>
    </Style>
    <Style Selector="ToggleButton.toolbar-btn:checked PathIcon">
        <Setter Property="Foreground" Value="#3794ff"/>
    </Style>

    <!-- ========================================== -->
    <!-- Project Explorer & Workspace Tree Styling  -->
    <!-- ========================================== -->
    <Style Selector="DataGrid#treeWorkspace">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="RowHeight" Value="24"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    </Style>
    <Style Selector="DataGrid#treeWorkspace DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="DataGrid#treeWorkspace DataGridRow:pointerover">
        <Setter Property="Background" Value="#2a2d2e"/>
    </Style>
    <Style Selector="DataGrid#treeWorkspace DataGridRow:selected">
        <Setter Property="Background" Value="#04395e"/>
    </Style>
    <Style Selector="DataGrid#treeWorkspace DataGridRow:selected:pointerover">
        <Setter Property="Background" Value="#04395e"/>
    </Style>
    <Style Selector="DataGrid#treeWorkspace DataGridCell:selected /template/ Border#PART_CellBorder">
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <!-- Custom inline toggle buttons inside TextBox -->
    <Style Selector="ToggleButton.inline-toggle">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="Width" Value="22"/>
        <Setter Property="Height" Value="20"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="ToggleButton.inline-toggle:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#35363a"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="ToggleButton.inline-toggle:checked /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#0e639c"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="ToggleButton.inline-toggle TextBlock">
        <Setter Property="Foreground" Value="#cccccc"/>
    </Style>
    <Style Selector="ToggleButton.inline-toggle:checked TextBlock">
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- Open Editors ListBox & ListBoxItem custom styles -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="#1e1e1e"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="ListBoxItem">
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="CornerRadius" Value="2"/>
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#2a2d2e"/>
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#2b2d30"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- Color-coded toolbox buttons -->
    <Style Selector="Button.category-btn">
        <Setter Property="Margin" Value="0,0,4,4"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Background" Value="#2d2d2d"/>
    </Style>
    
    <Style Selector="Button.category-btn-interaction">
        <Setter Property="BorderBrush" Value="#0e639c"/>
        <Setter Property="Foreground" Value="#61afef"/>
    </Style>
    <Style Selector="Button.category-btn-interaction:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#0e639c"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#0e639c"/>
    </Style>
    
    <Style Selector="Button.category-btn-assertion">
        <Setter Property="BorderBrush" Value="#4caf50"/>
        <Setter Property="Foreground" Value="#98c379"/>
    </Style>
    <Style Selector="Button.category-btn-assertion:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#4caf50"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#4caf50"/>
    </Style>
    
    <Style Selector="Button.category-btn-device">
        <Setter Property="BorderBrush" Value="#ab47bc"/>
        <Setter Property="Foreground" Value="#c678dd"/>
    </Style>
    <Style Selector="Button.category-btn-device:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#ab47bc"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#ab47bc"/>
    </Style>
    
    <Style Selector="Button.category-btn-logic">
        <Setter Property="BorderBrush" Value="#ff9800"/>
        <Setter Property="Foreground" Value="#d19a66"/>
    </Style>
    <Style Selector="Button.category-btn-logic:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#ff9800"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#ff9800"/>
    </Style>

</Styles>
