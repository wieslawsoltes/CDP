<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>Chrome.DevTools.Inspector.Shared</PackageId>
    <Title>Chrome.DevTools.Inspector.Shared</Title>
    <Description>Shared UI components and view models for the CDP Inspector client.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageTags>avalonia;cdp;chrome-devtools-protocol;inspector;shared</PackageTags>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="Avalonia.Fonts.Inter" />
    <PackageReference Include="Jint" />
    <PackageReference Include="YamlDotNet" />
    <PackageReference Include="Avalonia.AvaloniaEdit" />
    <PackageReference Include="AvaloniaEdit.TextMate" />
    <PackageReference Include="TextMateSharp.Grammars" />
    <PackageReference Include="ProDataGrid" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../CDP.Integration.Core/CDP.Integration.Core.csproj" />
    <ProjectReference Include="../CDP.Integration.TestMo/CDP.Integration.TestMo.csproj" />
    <ProjectReference Include="../CDP.Integration.TestRail/CDP.Integration.TestRail.csproj" />
    <ProjectReference Include="../CDP.Integration.Qase/CDP.Integration.Qase.csproj" />
    <ProjectReference Include="../CDP.Integration.Xray/CDP.Integration.Xray.csproj" />
    <ProjectReference Include="../CDP.Integration.Zephyr/CDP.Integration.Zephyr.csproj" />
    <ProjectReference Include="../Avalonia.Diagnostics.Cdp/Avalonia.Diagnostics.Cdp.csproj" />
    <ProjectReference Include="../CDP.Editor.Minimap/CDP.Editor.Minimap.csproj" />
    <ProjectReference Include="../CDP.Editor.Nodes/CDP.Editor.Nodes.csproj" />
    <ProjectReference Include="../CDP.Editor.Nodes.Msagl/CDP.Editor.Nodes.Msagl.csproj" />
    <ProjectReference Include="../CDP.Editor.Splits/CDP.Editor.Splits.csproj" />
    <ProjectReference Include="../CDP.Inspector.Controls/CDP.Inspector.Controls.csproj" />
    <ProjectReference Include="../CDP.Profiling.Analysis/CDP.Profiling.Analysis.csproj" />
    <ProjectReference Include="../CDP.Xaml.LanguageServer/CDP.Xaml.LanguageServer.csproj" />
    <ProjectReference Include="../CDP.CSharp.LanguageServer/CDP.CSharp.LanguageServer.csproj" />
    <ProjectReference Include="../CDP.Markdown.Editor/CDP.Markdown.Editor.csproj" />
    <ProjectReference Include="../CDP.Inspector.Wysiwyg/CDP.Inspector.Wysiwyg.csproj" />
    <ProjectReference Include="../CDP.Document.Editor/CDP.Document.Editor.csproj" />
    <ProjectReference Include="../CDP.Pdf.Editor/CDP.Pdf.Editor.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Chrome.DevTools.Protocol" />
  </ItemGroup>

  <ItemGroup>
    <None Include="../../README.md" Pack="true" PackagePath="" />
  </ItemGroup>


</Project>
