<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:CdpInspectorApp.Views"
             xmlns:vm="clr-namespace:CdpInspectorApp.ViewModels"
             xmlns:splits="clr-namespace:CDP.Editor.Splits.Controls;assembly=CDP.Editor.Splits"
             x:Class="CdpInspectorApp.Views.MainView"
             x:DataType="vm:MainWindowViewModel"
             x:CompileBindings="True">

    <Grid RowDefinitions="Auto, *" Background="#202124">
        <!-- 1. Connection, Targets, and Layout Toolbar -->
        <views:ConnectionToolbar Name="Toolbar" Grid.Row="0"/>

        <!-- 2. Dynamic Customizable Split Layout Panel -->
        <splits:SuperSplit Name="SplitControl"
                           Grid.Row="1"
                           Root="{Binding LayoutRoot}"
                           SelectedNode="{Binding SelectedPane, Mode=TwoWay}"/>
    </Grid>
</UserControl>
