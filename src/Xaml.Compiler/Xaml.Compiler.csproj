    <PackageId>Chrome.DevTools.Xaml.Compiler</PackageId>
    <Title>Chrome.DevTools.Xaml.Compiler</Title>
    <Description>Core XAML Type System, Lossless AST Parser, and Mutation Engine.</Description>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
