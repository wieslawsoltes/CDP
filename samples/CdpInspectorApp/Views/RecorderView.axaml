<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CdpInspectorApp.Views.RecorderView"
             x:CompileBindings="False">
    <Grid ColumnDefinitions="*, 4, *" Margin="10">
        <!-- Steps List (Left Side) -->
        <Grid Grid.Column="0" RowDefinitions="Auto, *" Margin="0,0,10,0">
            <!-- Recorder Toolbar -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,12">
                <Button Name="btnToggleRecord" Content="Start Recording" Background="#c5221f" Foreground="White" BorderBrush="#c5221f"/>
                <Button Name="btnReplay" Content="Replay" Background="#0f9d58" Foreground="White" BorderBrush="#0f9d58" IsEnabled="False"/>
                <Button Name="btnClear" Content="Clear" Background="#3c4043" Foreground="White" BorderBrush="#3c4043"/>
            </StackPanel>
            
            <Grid Grid.Row="1" RowDefinitions="Auto, *">
                <TextBlock Text="Recorded Steps" Classes="panel-header" Margin="0,0,0,8" Foreground="#e8eaed" FontSize="14" FontWeight="Bold"/>
                <ListBox Name="lstRecordedSteps" Grid.Row="1" Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4" Padding="10" Background="#202124" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4">
                                <Grid RowDefinitions="Auto, Auto">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Background="#3c4043" CornerRadius="2" Padding="4,2">
                                            <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="Bold" Foreground="#e8eaed"/>
                                        </Border>
                                        <TextBlock Text="{Binding SelectorDisplay}" FontWeight="SemiBold" Foreground="#e8eaed" FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock Grid.Row="1" Text="{Binding DetailDisplay}" FontSize="11" Foreground="#9aa0a6" Margin="0,4,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
        
        <GridSplitter Grid.Column="1" Background="#3c4043"/>
        
        <!-- Puppeteer Code & Export (Right Side) -->
        <Grid Grid.Column="2" RowDefinitions="Auto, *" Margin="10,0,0,0">
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,12">
                <TextBlock Text="Puppeteer Script" VerticalAlignment="Center" Foreground="#e8eaed" FontSize="14" FontWeight="Bold"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Name="btnLoad" Content="Load Recording" Classes="accent"/>
                    <Button Name="btnExportPuppeteer" Content="Export Script" Classes="accent"/>
                    <Button Name="btnExportJson" Content="Export JSON" Classes="accent"/>
                </StackPanel>
            </Grid>
            
            <Border Grid.Row="1" Background="#292a2d" BorderBrush="#3c4043" BorderThickness="1" CornerRadius="4" Padding="10">
                <TextBox Name="txtGeneratedCode" 
                         Background="Transparent" 
                         BorderThickness="0" 
                         Foreground="#e8eaed" 
                         FontFamily="Courier New,Consolas,Monospace" 
                         FontSize="12" 
                         IsReadOnly="True" 
                         AcceptsReturn="True" 
                         TextWrapping="NoWrap"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
