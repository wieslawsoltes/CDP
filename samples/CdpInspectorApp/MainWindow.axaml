<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CdpInspectorApp.MainWindow"
        x:CompileBindings="False"
        Title="Avalonia CDP Inspector Client" Width="1200" Height="750"
        WindowStartupLocation="CenterScreen"
        RequestedThemeVariant="Dark">
    <Window.Styles>
        <Style Selector="TextBlock.panel-header">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="Border.panel-card">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, *">
        <!-- Top Connection Bar -->
        <Border Grid.Row="0" Background="#161616" BorderBrush="#252525" BorderThickness="0,0,0,1" Padding="15,10">
            <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto, Auto">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#00A2FF"/>
                    <TextBlock Text="AVALONIA CDP INSPECTOR" FontSize="15" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center" LetterSpacing="1.2"/>
                </StackPanel>

                <Grid Grid.Column="1" ColumnDefinitions="Auto, *" Margin="25,0,15,0">
                    <TextBlock Text="Target Host:" VerticalAlignment="Center" Foreground="#888888" Margin="0,0,10,0"/>
                    <TextBox Name="txtHost" Grid.Column="1" Text="http://localhost:9222" Watermark="e.g. http://localhost:9222" Width="200" HorizontalAlignment="Left" Height="30" VerticalContentAlignment="Center"/>
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                    <Button Name="btnRefreshTargets" Content="Scan Targets" Classes="accent" Padding="12,5" CornerRadius="4"/>
                    <ComboBox Name="cbTargets" Width="300" PlaceholderText="Select a target window..."/>
                </StackPanel>

                <Button Name="btnConnect" Grid.Column="3" Content="Connect" Background="#2E7D32" Foreground="White" Margin="10,0,0,0" Padding="15,6" CornerRadius="4"/>
                <Button Name="btnDisconnect" Grid.Column="4" Content="Disconnect" Background="#C62828" Foreground="White" Margin="8,0,0,0" Padding="15,6" CornerRadius="4" IsEnabled="False"/>
                <TextBlock Name="txtConnectionStatus" Grid.Column="5" Text="Disconnected" Foreground="#FF5555" FontWeight="SemiBold" VerticalAlignment="Center" Margin="15,0,0,0"/>
            </Grid>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1" ColumnDefinitions="*, 4, 1.3*, 4, *" Background="#121212" Margin="10">
            
            <!-- Left Column: DOM Visual Tree -->
            <Grid Grid.Column="0" RowDefinitions="Auto, Auto, *">
                <TextBlock Text="DOM Visual Tree" Classes="panel-header"/>
                
                <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="0,0,0,10">
                    <TextBox Name="txtSearch" Watermark="Search tree by tag, ID, text..." Height="32" VerticalContentAlignment="Center"/>
                    <Button Name="btnSearch" Grid.Column="1" Content="Search" Margin="5,0,0,0" Padding="10,0"/>
                </Grid>

                <Border Grid.Row="2" Classes="panel-card">
                    <TreeView Name="treeDom">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding DisplayName}" Foreground="{Binding ForegroundBrush}" FontSize="12.5"/>
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
            </Grid>

            <!-- Column Splitter 1 -->
            <GridSplitter Grid.Column="1" Background="Transparent"/>

            <!-- Middle Column: Actions, Console & Screenshots -->
            <Grid Grid.Column="2" RowDefinitions="Auto, *">
                <TextBlock Text="Control &amp; Monitoring Workspace" Classes="panel-header"/>

                <Border Grid.Row="1" Classes="panel-card">
                    <TabControl Padding="0,10,0,0">
                        <!-- Simulation Tab -->
                        <TabItem Header="Simulate Actions">
                            <ScrollViewer Margin="0,10,0,0">
                                <StackPanel Spacing="15">
                                    <!-- Selection Indicator -->
                                    <Border Background="#2C2C2C" CornerRadius="6" Padding="10">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="Selected Node ID:" Foreground="#888888"/>
                                            <TextBlock Name="txtSelectedNodeId" Text="None" FontWeight="Bold" Foreground="#00A2FF"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Focus and Highlight -->
                                    <StackPanel Orientation="Horizontal" Spacing="15">
                                        <Button Name="btnFocus" Content="Focus Control" Padding="12,8" Background="#1976D2" Foreground="White" CornerRadius="4" Width="130" HorizontalContentAlignment="Center"/>
                                        <CheckBox Name="chkHighlight" Content="Highlight Overlay" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Mouse Actions -->
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Mouse Events" FontWeight="SemiBold" Foreground="#888888"/>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Button Name="btnClick" Content="Click Center" Padding="12,8" Background="#43A047" Foreground="White" CornerRadius="4"/>
                                            <TextBlock Text="(Simulates mouse press + release at center coordinates)" VerticalAlignment="Center" Foreground="#666666" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Text Input Simulation -->
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Simulate Keyboard / Text Input" FontWeight="SemiBold" Foreground="#888888"/>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBox Name="txtInputSim" Watermark="Type text to insert..."/>
                                            <Button Name="btnSendText" Grid.Column="1" Content="Send Text" Margin="5,0,0,0" Padding="12,8" Background="#8E24AA" Foreground="White" CornerRadius="4"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Specific Key Press -->
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Simulate Keystroke" FontWeight="SemiBold" Foreground="#888888"/>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <ComboBox Name="cbKeys" Width="150" PlaceholderText="Select Key..."/>
                                            <Button Name="btnSendKey" Content="Press Key" Padding="12,8" Background="#D81B60" Foreground="White" CornerRadius="4"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Separator Background="#2A2A2A"/>

                                    <!-- Emulation Overrides -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Emulation Overrides" FontWeight="SemiBold" Foreground="#888888"/>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="Width:" VerticalAlignment="Center" Foreground="#888888"/>
                                            <TextBox Name="txtWidth" Text="800" Width="60"/>
                                            <TextBlock Text="Height:" VerticalAlignment="Center" Foreground="#888888"/>
                                            <TextBox Name="txtHeight" Text="600" Width="60"/>
                                            <Button Name="btnResize" Content="Resize Window" Padding="10,6" Background="#5E35B1" Foreground="White" CornerRadius="4"/>
                                            <Button Name="btnResizeReset" Content="Reset" Padding="10,6" CornerRadius="4"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- Screenshot Tab -->
                        <TabItem Header="Screenshot">
                            <Grid RowDefinitions="Auto, *">
                                <Button Name="btnCaptureScreenshot" Content="Capture View" Classes="accent" Margin="0,10,0,10"/>
                                <Border Grid.Row="1" Background="#0C0C0C" BorderBrush="#252525" BorderThickness="1" CornerRadius="4">
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                        <Image Name="imgScreenshot" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </TabItem>

                        <!-- Log tab -->
                        <TabItem Header="Console Logs">
                            <Grid RowDefinitions="*, Auto" Margin="0,10,0,0">
                                <ListBox Name="listLogs" Background="#0C0C0C" BorderBrush="#252525" BorderThickness="1" CornerRadius="4">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="Auto, Auto, *">
                                                <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}" Foreground="#555555" Width="90"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Level}" Foreground="{Binding LevelBrush}" FontWeight="Bold" Width="70" Margin="10,0"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Text}" Foreground="#CCCCCC" TextWrapping="Wrap"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Button Name="btnClearLogs" Grid.Row="1" Content="Clear Logs" Margin="0,10,0,0" HorizontalAlignment="Right"/>
                            </Grid>
                        </TabItem>

                        <!-- Performance Tab -->
                        <TabItem Header="Performance">
                            <Grid RowDefinitions="Auto, *" Margin="0,10,0,0">
                                <Button Name="btnRefreshMetrics" Content="Query Metrics" Classes="accent" Margin="0,0,0,10"/>
                                <StackPanel Grid.Row="1" Spacing="15">
                                    <Grid ColumnDefinitions="150, *">
                                        <TextBlock Text="Visual Nodes:" Foreground="#888888"/>
                                        <TextBlock Name="lblPerfNodes" Grid.Column="1" Text="--" FontWeight="Bold"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="150, *">
                                        <TextBlock Text="Memory Working Set:" Foreground="#888888"/>
                                        <TextBlock Name="lblPerfMemory" Grid.Column="1" Text="--" FontWeight="Bold"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="150, *">
                                        <TextBlock Text="GC Total Memory:" Foreground="#888888"/>
                                        <TextBlock Name="lblPerfGc" Grid.Column="1" Text="--" FontWeight="Bold"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="150, *">
                                        <TextBlock Text="System OS:" Foreground="#888888"/>
                                        <TextBlock Name="lblPerfOs" Grid.Column="1" Text="--" TextWrapping="Wrap"/>
                                    </Grid>
                                    <Grid ColumnDefinitions="150, *">
                                        <TextBlock Text="Process PID:" Foreground="#888888"/>
                                        <TextBlock Name="lblPerfPid" Grid.Column="1" Text="--" FontWeight="Bold"/>
                                    </Grid>
                                    <Button Name="btnCloseTarget" Content="Close Target Window (Kill App)" Background="#C62828" Foreground="White" HorizontalAlignment="Left" Margin="0,20,0,0"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>

            <!-- Column Splitter 2 -->
            <GridSplitter Grid.Column="3" Background="Transparent"/>

            <!-- Right Column: Styles & Attributes Editor -->
            <Grid Grid.Column="4" RowDefinitions="Auto, *">
                <TextBlock Text="Inspection Properties" Classes="panel-header"/>

                <Border Grid.Row="1" Classes="panel-card">
                    <TabControl Padding="0,10,0,0">
                        <!-- Attributes Tab -->
                        <TabItem Header="Attributes">
                            <Grid RowDefinitions="*, Auto" Margin="0,10,0,0">
                                <ListBox Name="listAttributes" Background="#0C0C0C" BorderBrush="#252525" BorderThickness="1" CornerRadius="4">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*, Auto">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <TextBlock Text="{Binding Name}" Foreground="#E0A75E" FontWeight="SemiBold"/>
                                                    <TextBlock Text="=" Foreground="#888888"/>
                                                    <TextBlock Text="{Binding Value}" Foreground="#A5D6A7"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel Grid.Row="1" Spacing="8" Margin="0,10,0,0">
                                    <Grid ColumnDefinitions="*, *">
                                        <TextBox Name="txtAttrName" Watermark="Name" Height="30" VerticalContentAlignment="Center"/>
                                        <TextBox Name="txtAttrValue" Grid.Column="1" Watermark="Value" Margin="5,0,0,0" Height="30" VerticalContentAlignment="Center"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                                        <Button Name="btnDeleteAttr" Content="Delete" Background="#C62828" Foreground="White"/>
                                        <Button Name="btnApplyAttr" Content="Set / Add" Background="#2E7D32" Foreground="White"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <!-- CLR Properties Tab -->
                        <TabItem Header="C# Properties">
                            <Grid RowDefinitions="*, Auto" Margin="0,10,0,0">
                                <ListBox Name="listProperties" Background="#0C0C0C" BorderBrush="#252525" BorderThickness="1" CornerRadius="4">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*, Auto">
                                                <StackPanel Spacing="2">
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <TextBlock Text="{Binding Name}" Foreground="#90CAF9" FontWeight="SemiBold"/>
                                                        <TextBlock Text=":" Foreground="#888888"/>
                                                        <TextBlock Text="{Binding Value}" Foreground="#CCCCCC" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Type, StringFormat='({0})'}" Foreground="#555555" FontSize="10"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel Grid.Row="1" Spacing="8" Margin="0,10,0,0">
                                    <Grid ColumnDefinitions="Auto, *">
                                        <TextBlock Text="Selected:" VerticalAlignment="Center" Foreground="#888888" Margin="0,0,10,0"/>
                                        <TextBlock Name="lblSelectedProperty" Grid.Column="1" Text="None" FontWeight="Bold" Foreground="#90CAF9" VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBox Name="txtPropertyValue" Watermark="Enter new property value..."/>
                                    <Button Name="btnApplyProperty" Content="Mutate Property" Background="#2E7D32" Foreground="White" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <!-- CSS Styles Tab -->
                        <TabItem Header="CSS Styles">
                            <Grid RowDefinitions="*, Auto" Margin="0,10,0,0">
                                <ListBox Name="listCssProperties" Background="#0C0C0C" BorderBrush="#252525" BorderThickness="1" CornerRadius="4">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnDefinitions="*, Auto">
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <TextBlock Text="{Binding Name}" Foreground="#FF4081" FontWeight="SemiBold"/>
                                                    <TextBlock Text=":" Foreground="#888888"/>
                                                    <TextBlock Text="{Binding Value}" Foreground="#E0E0E0"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel Grid.Row="1" Spacing="8" Margin="0,10,0,0">
                                    <TextBlock Text="Edit Style Text:" Foreground="#888888" FontSize="11"/>
                                    <TextBox Name="txtStyleText" Watermark="e.g. width: 200px; height: 100px;"/>
                                    <Button Name="btnApplyStyleText" Content="Apply Style Text" Background="#2E7D32" Foreground="White" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
