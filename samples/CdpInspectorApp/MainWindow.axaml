<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CdpInspectorApp.Views"
        x:Class="CdpInspectorApp.MainWindow"
        x:CompileBindings="False"
        Title="Avalonia CDP Inspector Client - Chrome Parity" Width="1280" Height="800"
        WindowStartupLocation="CenterScreen"
        RequestedThemeVariant="Dark">

    <Grid RowDefinitions="Auto, *">
        <!-- 1. Connection and Targets Toolbar -->
        <views:ConnectionToolbar Name="Toolbar" Grid.Row="0"/>

        <!-- 2. DevTools Panels TabControl -->
        <Grid Grid.Row="1" Background="#202124">
            <TabControl Padding="0" Margin="0">
                <!-- Elements Panel -->
                <TabItem Header="Elements">
                    <views:ElementsView Name="ElementsTab"/>
                </TabItem>

                <!-- Console Panel -->
                <TabItem Header="Console">
                    <views:ConsoleView Name="ConsoleTab"/>
                </TabItem>

                <!-- Sources Panel -->
                <TabItem Header="Sources">
                    <views:SourcesView Name="SourcesTab"/>
                </TabItem>

                <!-- Network Panel -->
                <TabItem Header="Network">
                    <views:NetworkView Name="NetworkTab"/>
                </TabItem>

                <!-- Performance Panel -->
                <TabItem Header="Performance">
                    <views:PerformanceView Name="PerformanceTab"/>
                </TabItem>

                <!-- Application Panel -->
                <TabItem Header="Application">
                    <views:ApplicationView Name="ApplicationTab"/>
                </TabItem>

                <!-- Simulation Panel -->
                <TabItem Header="Simulation">
                    <views:SimulationView Name="SimulationTab"/>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
