<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CdpInspectorApp.Views;assembly=CDP.Inspector.Shared"
        x:Class="CdpInspectorApp.MainWindow"
        x:CompileBindings="False"
        Title="Avalonia CDP Inspector Client - Chrome Parity" Width="1280" Height="800"
        WindowStartupLocation="CenterScreen"
        RequestedThemeVariant="Dark">

    <views:MainView Name="MainViewControl"/>
</Window>
