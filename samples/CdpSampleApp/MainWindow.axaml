<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CdpSampleApp.ViewModels"
        x:Class="CdpSampleApp.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Avalonia CDP Inspector Sample" Width="550" Height="520">
    <Grid Margin="10" RowDefinitions="Auto, *">
        <TextBlock Classes="header" Text="Avalonia CDP Inspector Sample" FontSize="20" FontWeight="Bold" Margin="10,0,10,10"/>
        
        <TabControl Name="tabContainer" Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <!-- 1. Home Page (Existing controls) -->
            <TabItem Header="Home" Name="tabHome">
                <ScrollViewer Margin="10">
                    <StackPanel Spacing="15">
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Name="btnClickMe" AutomationProperties.AutomationId="btnClickMe" Command="{Binding ClickCommand}" Content="Click Me" Width="100" Margin="0,0,10,10"/>
                            <Button Name="btnSendHttp" AutomationProperties.AutomationId="btnSendHttp" Command="{Binding SendHttpCommand}" Content="Send HTTP Request" Width="150" Margin="0,0,10,10"/>
                            <Button Name="btnOpenSecond" AutomationProperties.AutomationId="btnOpenSecond" Command="{Binding OpenSecondWindowCommand}" Content="Open Second Window" Width="150" Margin="0,0,10,10"/>
                            <TextBlock Name="txtStatus" Text="{Binding StatusText}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        </WrapPanel>
                        
                        <TextBox Name="txtInput" AutomationProperties.AutomationId="txtTarget" Text="{Binding InputText, Mode=TwoWay}" PlaceholderText="Type text here..." Width="300" HorizontalAlignment="Left"/>
                        
                        <CheckBox Name="chkToggle" AutomationProperties.AutomationId="chkToggle" IsChecked="{Binding IsOptionEnabled, Mode=TwoWay}" Content="Enable Option"/>
                        
                        <Slider Name="sliderValue" AutomationProperties.AutomationId="sliderValue" Minimum="0" Maximum="100" Value="{Binding SliderValue, Mode=TwoWay}" Width="300" HorizontalAlignment="Left"/>
                        
                        <TextBlock Name="txtSliderVal" Text="{Binding SliderValue, StringFormat='Slider Value: {0:0}'}"/>
                        
                        <!-- More controls to satisfy 'add more control but keep existing ones' -->
                        <TextBlock Text="Additional Controls:" FontWeight="SemiBold" Margin="0,10,0,0"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <RadioButton Name="rbOption1" Content="Option 1" IsChecked="True"/>
                            <RadioButton Name="rbOption2" Content="Option 2"/>
                        </StackPanel>
                        <ProgressBar Name="progressVal" Value="{Binding SliderValue}" Minimum="0" Maximum="100" Height="15" Width="300" HorizontalAlignment="Left"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- 2. Scroll Page -->
            <TabItem Header="Scroll Test" Name="tabScroll">
                <Grid RowDefinitions="Auto, *">
                    <TextBlock Text="Use mouse wheel or simulation to scroll the container below:" Margin="10,5" FontSize="11" Foreground="#9aa0a6"/>
                    <ScrollViewer Name="scrollContainer" Grid.Row="1" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Margin="10" Height="250">
                        <StackPanel Spacing="10" Margin="15">
                            <TextBlock Text="Scroll Start" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource SystemControlHighlightAccentBrush}"/>
                            <Button Name="scrollBtn1" Content="Scroll Button 1"/>
                            <Button Name="scrollBtn2" Content="Scroll Button 2"/>
                            <TextBox Name="scrollTxt1" PlaceholderText="Scroll Textbox 1" Width="200" HorizontalAlignment="Left"/>
                            <TextBlock Text="Middle of Scroll Area" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" Margin="0,30"/>
                            <Button Name="scrollBtn3" Content="Scroll Button 3"/>
                            <CheckBox Name="scrollChk1" Content="Scroll Checkbox 1"/>
                            <Slider Name="scrollSlider1" Width="200" HorizontalAlignment="Left"/>
                            <TextBlock Text="Scroll End" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" Margin="0,30,0,0"/>
                            <Button Name="scrollBtn4" Content="Scroll Button 4"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            
            <!-- 3. About Page (Navigation test target) -->
            <TabItem Header="About" Name="tabAbout">
                <StackPanel Spacing="15" Margin="20">
                    <TextBlock Text="About This App" FontSize="18" FontWeight="Bold" Foreground="#8ab4f8"/>
                    <TextBlock Text="This is a CDP sample target application designed for end-to-end testing, visual self-inspection, and layout verifications." TextWrapping="Wrap"/>
                    <TextBlock Text="Use the URL navigation 'http://localhost:9222/about' to reach this page programmatically." TextWrapping="Wrap" FontStyle="Italic" Foreground="#9aa0a6"/>
                    <Button Name="btnGoBack" Command="{Binding GoBackCommand}" Content="Back to Home" Width="120" Margin="0,20,0,0"/>
                </StackPanel>
            </TabItem>
            
            <!-- 4. Gestures Page -->
            <TabItem Header="Gestures" Name="tabGestures" AutomationProperties.AutomationId="tabContainerTabItem">
                <ScrollViewer Margin="10">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Gesture Testing" FontSize="18" FontWeight="Bold" Foreground="#8ab4f8"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Name="btnDoubleClick" Content="Double Click Me" DoubleTapped="BtnDoubleClick_DoubleTapped" Width="150"/>
                            <TextBlock Name="DoubleClickStatus" Text="{Binding DoubleClickStatus}" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Name="btnLongPress" Content="Long Press Me" PointerPressed="BtnLongPress_PointerPressed" PointerReleased="BtnLongPress_PointerReleased" Width="150"/>
                            <TextBlock Name="LongPressStatus" Text="{Binding LongPressStatus}" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <TextBox Name="txtClearTarget" Text="{Binding ClearTargetText, Mode=TwoWay}" PlaceholderText="Clear target text..." Width="300" HorizontalAlignment="Left"/>
                        
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Name="borderDragSource" Background="Gray" Width="120" Height="60" CornerRadius="4" PointerPressed="BorderDragSource_PointerPressed">
                                    <TextBlock Text="Drag Source" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                </Border>
                                <Border Name="borderDropTarget" Background="DarkGray" Width="120" Height="60" CornerRadius="4" PointerReleased="BorderDropTarget_PointerReleased">
                                    <TextBlock Text="Drop Target" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Name="DragDropStatus" Text="{Binding DragDropStatus}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 5. Asserts & Keys Page -->
            <TabItem Header="Asserts &amp; Keys" Name="tabAssertsAndKeys" AutomationProperties.AutomationId="tabContainerTabItem">
                <ScrollViewer Margin="10">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Asserts &amp; Keys Testing" FontSize="18" FontWeight="Bold" Foreground="#8ab4f8"/>
                        <TextBox Name="txtKeyInput" KeyDown="TxtKeyInput_KeyDown" PlaceholderText="Press keys here..." Width="300" HorizontalAlignment="Left"/>
                        <Button Name="btnToggleVisibility" Command="{Binding ToggleVisibilityCommand}" Content="Toggle Visibility" Width="150"/>
                        <TextBlock Name="txtVisibilityTarget" IsVisible="{Binding IsVisibleTarget}" Text="Visibility Target Text" FontSize="16" FontWeight="SemiBold" Foreground="#4caf50"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
