<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CdpGalleryApp.ViewModels"
             xmlns:nodes="clr-namespace:CDP.Editor.Nodes.Views;assembly=CDP.Editor.Nodes"
             x:Class="CdpGalleryApp.Views.NodeEditorPage"
             x:DataType="vm:NodeEditorPageViewModel"
             x:CompileBindings="True">
    
    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Background="#1e1e1e" BorderBrush="#3c4043" BorderThickness="0,0,0,1" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Node Editor" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Foreground="#8ab4f8"/>
                <Separator Width="1" Height="16" Background="#3c4043"/>
                <TextBlock Text="Connect nodes interactively via Bezier curves, drag nodes, and zoom/pan." FontSize="11" Foreground="#9aa0a6" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#121212" Padding="8">
            <Border Background="#1c1c1c" BorderBrush="#2d2d2d" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
                <!-- Custom NodeEditorView embedded with compile-time bindings -->
                <nodes:NodeEditorView DataContext="{Binding NodeEditorVm}"/>
            </Border>
        </Border>
    </Grid>
</UserControl>
