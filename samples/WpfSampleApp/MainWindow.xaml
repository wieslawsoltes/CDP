<Window x:Class="WpfSampleApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF CDP Target Sample Application" Height="450" Width="800"
        Background="#1e1e1e">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="WPF CDP Target Server Demo" FontSize="24" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Use the Chrome DevTools Inspector to connect, query elements, simulate input, and capture screenshots." Foreground="#888888" FontSize="14" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
            <TextBlock Text="Target Controls" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,10"/>
            
            <TextBlock Text="Label element:" Foreground="#aaaaaa" Margin="0,5"/>
            <TextBlock x:Name="lblStatus" Text="Ready to receive commands" FontSize="18" Foreground="#4caf50" Margin="0,0,0,15"/>

            <TextBlock Text="Enter Text:" Foreground="#aaaaaa" Margin="0,5"/>
            <TextBox x:Name="txtInput" FontSize="14" Padding="8" Margin="0,0,0,15" Background="#2d2d2d" Foreground="White" BorderBrush="#555555" CaretBrush="White"/>

            <Button x:Name="btnClickMe" Content="Click Me" Click="BtnClickMe_Click" Padding="12" FontSize="14" FontWeight="Bold" Background="#2196f3" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
